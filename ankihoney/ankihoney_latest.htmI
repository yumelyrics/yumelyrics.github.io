function getSampleCardText(side){
  const rows = currentRows();
  if(!rows.length) return side === 'front' ? 'Contoh teks depan kartu' : 'Contoh teks belakang kartu';
  const note = rows[0];
  if(side === 'front'){
    return stripHtml(note.fields[0] || '') || 'Contoh teks depan kartu';
  }
  const rest = note.fields.slice(1).map(f=>stripHtml(f)).filter(v=>v && v.trim()).join('   •   ');
  return rest || 'Contoh teks belakang kartu';
}

// Buang semua tag HTML KECUALI <b>/<strong>, biar vocab yang di-highlight
// di field asli tetep keliatan bold pas dipreview (buat nunjukkin efek outline/shadow-nya)
function sanitizeKeepBold(str){
  const tmp = document.createElement('div');
  tmp.innerHTML = str || '';
  (function walk(node){
    [...node.childNodes].forEach(child=>{
      if(child.nodeType === 1){
        const tag = child.tagName.toLowerCase();
        if(tag === 'b' || tag === 'strong'){
          walk(child);
        } else {
          node.replaceChild(document.createTextNode(child.textContent), child);
        }
      }
    });
  })(tmp);
  return (tmp.innerHTML || '').replace(/\s+/g,' ').trim();
}

function getSampleCardHtml(side){
  const rows = currentRows();
  let raw = '';
  if(rows.length){
    const note = rows[0];
    raw = side === 'front'
      ? (note.fields[0] || '')
      : note.fields.slice(1).filter(f=>f && f.trim()).join('   •   ');
  }
  let safe = sanitizeKeepBold(raw);
  if(!/<b>|<strong>/i.test(safe)){
    // gak ada vocab yang di-bold di data asli → kasih contoh biar efeknya tetep keliatan
    safe = (safe ? safe + ' — ' : '') + 'contoh: <b>kosakata</b> yang di-bold';
  }
  return safe;
}

function updateBgPreview(){
  const cfg = state.cardBg;
  const sizeMap = { cover:'cover', contain:'contain', stretch:'100% 100%' };
  const side = cfg.previewSide || 'front';
  const active = side === 'front' ? cfg.front : cfg.back;
  const device = cfg.previewDevice || 'desktop';
  const posX = device === 'mobile' ? (cfg.mobilePosX ?? 50) : (cfg.posX ?? 50);
  const posY = device === 'mobile' ? (cfg.mobilePosY ?? 50) : (cfg.posY ?? 50);

  const card = document.getElementById('bgPreviewCard');
  const img = document.getElementById('bgPreviewImg');
  const overlay = document.getElementById('bgPreviewOverlay');
  const sideLabel = document.getElementById('bgPreviewSideLabel');
  const textEl = document.getElementById('bgPreviewText');
  if(!card) return;

  sideLabel.textContent = (side === 'front' ? 'Depan (Front)' : 'Belakang (Back)') + (active ? ' · diterapkan ✅' : ' · belum diterapkan');
  sideLabel.classList.toggle('applied', active);
  textEl.innerHTML = getSampleCardHtml(side);
  updateTextFxPreview();
  document.getElementById('dotFront').classList.toggle('active', side==='front');
  document.getElementById('dotBack').classList.toggle('active', side==='back');

  card.classList.toggle('empty', !ahHasBgImage(cfg));
  card.classList.toggle('device-mobile', device === 'mobile');
  const deviceBadge = document.getElementById('bgPreviewDeviceBadge');
  if(deviceBadge) deviceBadge.textContent = device === 'mobile' ? '📱 Mobile' : '🖥️ Desktop';
  const posReadout = document.getElementById('bgPosReadout');
  if(posReadout) posReadout.textContent = `Posisi: ${Math.round(posX)}%, ${Math.round(posY)}%`;
  const dtDesktop = document.getElementById('bgDeviceDesktop');
  const dtMobile = document.getElementById('bgDeviceMobile');
  if(dtDesktop) dtDesktop.classList.toggle('applied', device !== 'mobile');
  if(dtMobile) dtMobile.classList.toggle('applied', device === 'mobile');

  if(ahHasBgImage(cfg)){
    img.style.backgroundImage = `url('${cfg.mode==='url' ? cfg.imageUrl.trim() : cfg.dataUrl}')`;
    img.style.backgroundSize = sizeMap[cfg.fit] || 'cover';
    img.style.backgroundPosition = `${posX}% ${posY}%`;
    img.style.opacity = String(cfg.opacity/100);
    img.style.filter = `blur(${cfg.blur}px)`;
    overlay.style.backgroundColor = `rgba(0,0,0,${cfg.overlay/100})`;
  }

  document.getElementById('btnApplyFront').classList.toggle('applied', cfg.front);
  document.getElementById('btnApplyBack').classList.toggle('applied', cfg.back);
}

function toggleBgPreviewSide(force){
  state.cardBg.previewSide = force || (state.cardBg.previewSide === 'front' ? 'back' : 'front');
  updateBgPreview();
}

// Versi ringan dari updateBgPreview() -- CUMA nulis ulang background-position &
// angka readout-nya, tanpa nyentuh innerHTML teks/efek FX yang berat. Dipanggil
// terus-menerus SELAMA drag (biar posisi kerasa nempel di jari/kursor), sedangkan
// updateBgPreview() yang lengkap cuma dipanggil sekali di akhir drag. Sebelumnya
// updateBgPreview() penuh dipanggil di TIAP pointermove, yang nge-reset innerHTML
// & CSS teks berkali-kali per detik -> inilah biang glitch/patah-patahnya foto pas digeser.
function updateBgPreviewPositionOnly(){
  const cfg = state.cardBg;
  const device = cfg.previewDevice || 'desktop';
  const posX = device === 'mobile' ? (cfg.mobilePosX ?? 50) : (cfg.posX ?? 50);
  const posY = device === 'mobile' ? (cfg.mobilePosY ?? 50) : (cfg.posY ?? 50);
  const img = document.getElementById('bgPreviewImg');
  const posReadout = document.getElementById('bgPosReadout');
  if(img) img.style.backgroundPosition = `${posX}% ${posY}%`;
  if(posReadout) posReadout.textContent = `Posisi: ${Math.round(posX)}%, ${Math.round(posY)}%`;
}

(function setupBgPreviewInteraction(){
  const card = document.getElementById('bgPreviewCard');
  const MOVE_THRESHOLD = 5; // px -- di bawah ini dianggap tap (ganti sisi), bukan drag (atur posisi)
  let startX = null, startY = null, moved = false, dragActive = false;
  let rafId = null, pendingEvent = null;

  function clampPct(v){ return Math.max(0, Math.min(100, v)); }
  // FIX arah kebalik: background-position CSS itu makin gede % makin nunjukin
  // sisi KANAN/BAWAH dari gambar asli -- efeknya gambar malah KELIATAN geser ke
  // KIRI/ATAS pas persen-nya dinaikin. Kalau posisi dipetain APA ADANYA dari
  // koordinat kursor (kursor makin ke kanan -> % makin gede), hasilnya gambar
  // malah geser ke arah BERLAWANAN dari tarikan jari/kursor. Makanya di sini
  // koordinatnya dibalik (100 - x, 100 - y) dulu, biar geser ke kanan/bawah
  // beneran bikin gambar KELIATAN ikut geser ke kanan/bawah (searah tarikan).
  function posFromEvent(e){
    const rect = card.getBoundingClientRect();
    const rawX = clampPct(((e.clientX - rect.left) / rect.width) * 100);
    const rawY = clampPct(((e.clientY - rect.top) / rect.height) * 100);
    return { x: 100 - rawX, y: 100 - rawY };
  }
  // Nulis posisi ke device yang lagi aktif di tab (Desktop atau Mobile) --
  // 2 device ini disimpen terpisah, jadi geser pas tab Mobile aktif GAK
  // ngubah posisi yang udah diatur buat Desktop, begitu juga sebaliknya.
  function applyDragPosition(e){
    const { x, y } = posFromEvent(e);
    if(state.cardBg.previewDevice === 'mobile'){
      state.cardBg.mobilePosX = Math.round(x);
      state.cardBg.mobilePosY = Math.round(y);
    } else {
      state.cardBg.posX = Math.round(x);
      state.cardBg.posY = Math.round(y);
    }
    // Selama drag cuma update posisi gambar + angka readout (murah & cepat).
    // Rebuild teks/efek FX yang berat baru dijalanin sekali di akhir drag lewat
    // updateBgPreview() penuh (di pointerup) -- ini yang benerin glitch/patah-patah.
    updateBgPreviewPositionOnly();
  }

  card.addEventListener('pointerdown', e=>{
    startX = e.clientX; startY = e.clientY; moved = false;
    dragActive = ahHasBgImage(state.cardBg);
    if(dragActive){ try{ card.setPointerCapture(e.pointerId); }catch(err){} }
  });
  card.addEventListener('pointermove', e=>{
    if(startX === null) return;
    const dist = Math.hypot(e.clientX-startX, e.clientY-startY);
    if(dist > MOVE_THRESHOLD) moved = true;
    if(dragActive && moved){
      // Throttle lewat requestAnimationFrame -- pointermove bisa nembak jauh
      // lebih sering daripada refresh rate layar, dan kalau tiap event langsung
      // micu kerjaan DOM, updatenya numpuk & bikin gambar keliatan patah-patah/
      // glitch pas digeser cepat. Cukup proses event TERBARU tiap 1 frame.
      pendingEvent = e;
      if(rafId === null){
        rafId = requestAnimationFrame(()=>{
          if(pendingEvent) applyDragPosition(pendingEvent);
          rafId = null; pendingEvent = null;
        });
      }
    }
  });
  card.addEventListener('pointerup', e=>{
    if(startX === null) return;
    if(!(dragActive && moved)){
      // Cuma tap (gak digeser signifikan), atau lagi belum ada foto -- perilaku
      // lama tetep jalan: ketuk buat gonta-ganti preview sisi Depan/Belakang.
      toggleBgPreviewSide();
    } else {
      if(rafId !== null){ cancelAnimationFrame(rafId); rafId = null; }
      if(pendingEvent){ applyDragPosition(pendingEvent); pendingEvent = null; }
      updateBgPreview(); // refresh penuh sekali di akhir drag (teks, dot, status, dll)
      toast(`Posisi ${state.cardBg.previewDevice === 'mobile' ? 'Mobile' : 'Desktop'} diupdate~`, '🎯');
    }
    startX = null; startY = null; moved = false; dragActive = false;
  });
  card.addEventListener('pointercancel', ()=>{
    if(rafId !== null){ cancelAnimationFrame(rafId); rafId = null; }
    pendingEvent = null;
    startX = null; startY = null; moved = false; dragActive = false;
  });

  document.getElementById('dotFront').addEventListener('click', e=>{ e.stopPropagation(); toggleBgPreviewSide('front'); });
  document.getElementById('dotBack').addEventListener('click', e=>{ e.stopPropagation(); toggleBgPreviewSide('back'); });
})();

/* ---------------- editor Front Template / Back Template / Styling (realtime) ---------------- */

// Ambil nilai satu field dari note berdasarkan nama field-nya (best-effort,
// dipakai buat rendering preview handlebars Anki di bawah).
function ahFieldValueByName(fields, fieldNames, name){
  const idx = fieldNames.indexOf(name);
  return idx >= 0 ? (fields[idx] || '') : '';
}

// Render 1 tag {{...}} handlebars ala Anki jadi HTML preview. Best-effort:
// dukung {{Field}}, {{FrontSide}}, {{cloze:Field}}, {{Tags}}/{{Type}}/{{Deck}}/{{Card}},
// dan modifier field kayak {{text:Field}}/{{furigana:Field}} (modifier-nya
// diabaikan, langsung tampilin isi field-nya apa adanya).
function ahRenderTemplateTag(tag, fields, fieldNames, extra){
  tag = tag.trim();
  if(tag === 'FrontSide') return extra.frontSide || '';
  if(tag.toLowerCase().startsWith('cloze:')){
    const fname = tag.slice(tag.indexOf(':')+1);
    let val = ahFieldValueByName(fields, fieldNames, fname);
    // best-effort: highlight cloze pertama yang ketemu, sisanya ditampilin apa adanya
    val = val.replace(/\{\{c\d+::(.*?)(::.*?)?\}\}/g, (m, txt)=> `<span style="background:#ffe08a; border-radius:4px; padding:0 3px;">[...${txt}...]</span>`);
    return val;
  }
  const idx = tag.lastIndexOf(':');
  const fname = idx >= 0 ? tag.slice(idx+1) : tag;
  if(fname === 'Tags') return extra.tags || '';
  if(fname === 'Type') return extra.type || '';
  if(fname === 'Deck') return extra.deck || '';
  if(fname === 'Subdeck') return extra.deck || '';
  if(fname === 'Card') return extra.card || '';
  return ahFieldValueByName(fields, fieldNames, fname);
}

// Render qfmt/afmt (handlebars ala Anki) jadi HTML buat preview. Dukung blok
// kondisional {{#Field}}...{{/Field}} (tampil kalau field ISI) dan
// {{^Field}}...{{/Field}} (tampil kalau field KOSONG). Ini rendering
// best-effort buat preview aja, bukan pengganti engine asli Anki.
function ahRenderAnkiTemplate(tpl, fields, fieldNames, extra){
  tpl = tpl || '';
  let prev;
  do{
    prev = tpl;
    tpl = tpl.replace(/\{\{#([^#^\/}]+)\}\}([\s\S]*?)\{\{\/\1\}\}/g, (m, name, inner)=>{
      const val = name === 'FrontSide' ? (extra.frontSide||'') : ahFieldValueByName(fields, fieldNames, name);
      return (val && String(val).trim()) ? inner : '';
    });
    tpl = tpl.replace(/\{\{\^([^#^\/}]+)\}\}([\s\S]*?)\{\{\/\1\}\}/g, (m, name, inner)=>{
      const val = ahFieldValueByName(fields, fieldNames, name);
      return (!val || !String(val).trim()) ? inner : '';
    });
  }while(tpl !== prev);
  tpl = tpl.replace(/\{\{([^#^\/][^}]*)\}\}/g, (m, tag)=> ahRenderTemplateTag(tag, fields, fieldNames, extra));
  return tpl;
}

function ahCurrentTplModel(){
  return state.models[state.currentMid];
}

// Ambil/simpen snapshot "desain asli" model ini SEKALI doang (pas pertama kali
// editor dibuka buat mid itu) -- dipakai tombol "Kembalikan ke Desain Asli".
function ahEnsureTemplateSnapshot(mid, model){
  if(!model || state.templateOriginals[mid]) return;
  state.templateOriginals[mid] = {
    css: model.css || '',
    tmpls: (model.tmpls || []).map(t=> ({ ord: t.ord, qfmt: t.qfmt || '', afmt: t.afmt || '' }))
  };
}

function ahCurrentTplOrd(){
  const model = ahCurrentTplModel();
  if(!model || !model.tmpls || !model.tmpls.length) return 0;
  const exists = model.tmpls.some(t=> t.ord === state.templateEditor.ord);
  return exists ? state.templateEditor.ord : model.tmpls[0].ord;
}

// Panggil pas note type dipilih/diganti (termasuk pas deck baru dibuka) --
// nge-refresh dropdown template & isi ketiga textarea editor dari state.models.
function populateTemplateEditor(){
  const card = document.getElementById('tplCard');
  if(!card || card.classList.contains('hidden')) { /* tetep lanjut isi state walau card masih hidden di render pertama */ }
  const model = ahCurrentTplModel();
  const nameEl = document.getElementById('tplModelName');
  if(nameEl) nameEl.textContent = model ? model.name : '-';
  if(!model || !model.tmpls || !model.tmpls.length){
    const hintsEl = document.getElementById('tplFieldHints');
    if(hintsEl) hintsEl.innerHTML = '<small style="color:var(--ink-soft); font-weight:600;">Desain kartu asli note type ini belum berhasil ditangkap, jadi belum bisa diedit di sini.</small>';
    return;
  }
  ahEnsureTemplateSnapshot(state.currentMid, model);
  state.templateEditor.ord = ahCurrentTplOrd();

  const sel = document.getElementById('tplCardSelect');
  sel.innerHTML = '';
  model.tmpls.forEach(t=>{
    const opt = document.createElement('option');
    opt.value = t.ord;
    opt.textContent = t.name || ('Card ' + (t.ord+1));
    sel.appendChild(opt);
  });
  sel.value = state.templateEditor.ord;
  sel.onchange = ()=>{
    state.templateEditor.ord = parseInt(sel.value);
    loadTemplateEditorTextareas();
    renderTemplateLivePreview();
  };

  const hintsEl = document.getElementById('tplFieldHints');
  if(hintsEl){
    hintsEl.innerHTML = '';
    const names = ['FrontSide', ...model.flds];
    names.forEach(name=>{
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'tpl-field-hint';
      btn.textContent = `{{${name}}}`;
      btn.title = 'Klik buat nyalin ke clipboard';
      btn.addEventListener('click', ()=>{
        navigator.clipboard?.writeText(`{{${name}}}`).catch(()=>{});
        toast(`{{${name}}} disalin ke clipboard~`, '📋');
      });
      hintsEl.appendChild(btn);
    });
  }

  loadTemplateEditorTextareas();
  renderTemplateLivePreview();
}

function loadTemplateEditorTextareas(){
  const model = ahCurrentTplModel();
  if(!model) return;
  const t = model.tmpls.find(t=> t.ord === state.templateEditor.ord) || model.tmpls[0];
  document.getElementById('tplEditorFront').value = t.qfmt || '';
  document.getElementById('tplEditorBack').value = t.afmt || '';
  document.getElementById('tplEditorCss').value = model.css || '';
}

function switchTemplateEditorTab(tab){
  state.templateEditor.tab = tab;
  ['front','back','css'].forEach(name=>{
    document.getElementById('tplEditor' + name.charAt(0).toUpperCase()+name.slice(1)).classList.toggle('hidden', name !== tab);
    document.getElementById('tplTab' + name.charAt(0).toUpperCase()+name.slice(1)).classList.toggle('applied', name === tab);
  });
}

function switchTemplatePreviewSide(side){
  state.templateEditor.side = side;
  document.getElementById('tplPreviewFront').classList.toggle('applied', side === 'front');
  document.getElementById('tplPreviewBack').classList.toggle('applied', side === 'back');
  renderTemplateLivePreview();
}

// Baca manifest 'media' dari zip .apkg yang lagi dibuka (nomor file <-> nama file
// asli), sama kayak logic pas export (termasuk bongkar zstd kalau manifestnya
// sendiri kekompres) -- dipakai biar preview realtime bisa nunjukin gambar &
// muterin audio ASLI dari deck, bukan cuma teks mentah [sound:...]/ikon patah.
async function ahGetMediaNameMap(){
  if(state._mediaMapPromise) return state._mediaMapPromise;
  state._mediaMapPromise = (async ()=>{
    if(!state.zip) return {};
    const entry = state.zip.file('media');
    if(!entry) return {};
    let bytes = await entry.async('uint8array');
    if(bytes.length >= 4 && bytes[0]===0x28 && bytes[1]===0xb5 && bytes[2]===0x2f && bytes[3]===0xfd){
      try{ bytes = zstdDecompressSafe(bytes); }
      catch(e){ console.warn('gagal bongkar manifest media buat preview (best-effort)', e); return {}; }
    }
    try{
      const asText = new TextDecoder().decode(bytes);
      return JSON.parse(asText);
    }catch(e){
      return tryParseMediaProtobuf(bytes) || {};
    }
  })();
  return state._mediaMapPromise;
}

const AH_MEDIA_MIME_MAP = {
  jpg:'image/jpeg', jpeg:'image/jpeg', png:'image/png', gif:'image/gif', webp:'image/webp',
  svg:'image/svg+xml', bmp:'image/bmp', avif:'image/avif',
  mp3:'audio/mpeg', ogg:'audio/ogg', oga:'audio/ogg', wav:'audio/wav', m4a:'audio/mp4',
  flac:'audio/flac', weba:'audio/webm', mp4:'video/mp4', webm:'video/webm'
};

// Ambil (atau bikin & cache) blob: URL buat 1 file media, dibaca langsung dari
// zip .apkg yang lagi dibuka (termasuk bongkar zstd per-file kalau formatnya
// anki21b, sama kayak logic pas export). Balikin null kalau filenya gak ketemu.
async function ahGetMediaBlobUrl(filename){
  if(!filename || !state.zip) return null;
  if(state.mediaBlobUrlCache[filename]) return state.mediaBlobUrlCache[filename];
  const nameMap = await ahGetMediaNameMap();
  let num = null;
  for(const k in nameMap){ if(nameMap[k] === filename){ num = k; break; } }
  if(num === null) return null;
  const entry = state.zip.file(num);
  if(!entry) return null;
  let bytes;
  try{ bytes = await entry.async('uint8array'); }catch(e){ return null; }
  if(bytes.length >= 4 && bytes[0]===0x28 && bytes[1]===0xb5 && bytes[2]===0x2f && bytes[3]===0xfd){
    try{ bytes = zstdDecompressSafe(bytes); }
    catch(e){ console.warn('gagal bongkar media zstd buat preview (best-effort), file='+filename, e); return null; }
  }
  const ext = (filename.split('.').pop() || '').toLowerCase();
  const mime = AH_MEDIA_MIME_MAP[ext] || 'application/octet-stream';
  const url = URL.createObjectURL(new Blob([bytes], { type: mime }));
  state.mediaBlobUrlCache[filename] = url;
  return url;
}

// Ganti referensi media di HTML hasil render (<img src="nama.jpg"> dan tag
// [sound:nama.mp3]) jadi blob: URL yang beneran bisa ditampilin/diputer di
// iframe preview, diambil dari media asli yang ada di dalam .apkg. Kalau
// filenya gak ketemu di deck, dikasih placeholder yang jelas (bukan silently gagal).
async function ahResolveMediaInHtml(html){
  const imgTags = [...new Set((html.match(/<img\b[^>]*\bsrc=["']([^"']+)["'][^>]*>/gi) || []))];
  for(const tag of imgTags){
    const m = tag.match(/\bsrc=["']([^"']+)["']/i);
    if(!m) continue;
    const src = m[1];
    if(/^(https?:|data:|blob:)/i.test(src)) continue;
    const url = await ahGetMediaBlobUrl(decodeURIComponent(src));
    const replaced = url
      ? tag.replace(src, url)
      : tag.replace('<img ', `<img title="⚠️ gambar '${src}' gak ketemu di media deck" style="outline:2px dashed #ff6bb3;" `);
    html = html.split(tag).join(replaced);
  }
  const soundTags = [...new Set((html.match(/\[sound:([^\]]+)\]/gi) || []))];
  for(const tag of soundTags){
    const fname = tag.slice(7, -1);
    const url = await ahGetMediaBlobUrl(decodeURIComponent(fname));
    const replacement = url
      ? `<audio controls src="${url}" style="max-width:100%; margin:6px 0; vertical-align:middle;"></audio>`
      : `<span style="display:inline-block; font-size:.75em; opacity:.65; border:1px dashed #ff6bb3; border-radius:6px; padding:2px 6px;">🔊 audio '${fname}' gak ketemu di media deck</span>`;
    html = html.split(tag).join(replacement);
  }
  return html;
}

async function buildTemplatePreviewDoc(){
  const model = ahCurrentTplModel();
  if(!model || !model.tmpls || !model.tmpls.length) return '<!doctype html><body></body>';
  const t = model.tmpls.find(t=> t.ord === state.templateEditor.ord) || model.tmpls[0];
  const rows = (typeof currentRows === 'function') ? currentRows() : [];
  const fieldNames = model.flds || [];
  const fields = (rows && rows.length) ? rows[0].fields : fieldNames.map(f=> `[Contoh ${f}]`);
  const extra = { tags:'contoh-tag', type: model.name || '', deck: 'Deck Contoh', card: t.name || '' };
  const frontHtml = ahRenderAnkiTemplate(t.qfmt, fields, fieldNames, extra);
  let bodyHtml = frontHtml;
  if(state.templateEditor.side === 'back'){
    extra.frontSide = frontHtml;
    bodyHtml = ahRenderAnkiTemplate(t.afmt, fields, fieldNames, extra);
  }
  bodyHtml = await ahResolveMediaInHtml(bodyHtml);
  const css = model.css || '';
  return `<!doctype html><html><head><meta charset="utf-8"><style>
    html,body{ margin:0; padding:0; }
    body{ padding:18px; box-sizing:border-box; font-family:Arial; }
    ${css}
  </style></head><body class="card">${bodyHtml}</body></html>`;
}

let _tplPreviewDebounce = null;
let _tplPreviewToken = 0;
function renderTemplateLivePreview(){
  // Debounce dikit (~120ms) biar preview tetep kerasa realtime pas ngetik cepat,
  // tapi gak nge-rebuild iframe di TIAP keystroke (yang bisa berat/nge-lag).
  if(_tplPreviewDebounce) clearTimeout(_tplPreviewDebounce);
  _tplPreviewDebounce = setTimeout(async ()=>{
    const myToken = ++_tplPreviewToken;
    const doc = await buildTemplatePreviewDoc();
    if(myToken !== _tplPreviewToken) return; // ada render lain yang nyusul lebih baru, buang hasil yang ini (cegah race condition/flicker)
    const iframe = document.getElementById('tplPreviewFrame');
    if(iframe) iframe.srcdoc = doc;
  }, 120);
}

document.getElementById('tplTabFront').addEventListener('click', ()=> switchTemplateEditorTab('front'));
document.getElementById('tplTabBack').addEventListener('click', ()=> switchTemplateEditorTab('back'));
document.getElementById('tplTabCss').addEventListener('click', ()=> switchTemplateEditorTab('css'));
document.getElementById('tplPreviewFront').addEventListener('click', ()=> switchTemplatePreviewSide('front'));
document.getElementById('tplPreviewBack').addEventListener('click', ()=> switchTemplatePreviewSide('back'));

document.getElementById('tplEditorFront').addEventListener('input', e=>{
  const model = ahCurrentTplModel();
  if(!model) return;
  const t = model.tmpls.find(t=> t.ord === state.templateEditor.ord);
  if(t){ t.qfmt = e.target.value; renderTemplateLivePreview(); }
});
document.getElementById('tplEditorBack').addEventListener('input', e=>{
  const model = ahCurrentTplModel();
  if(!model) return;
  const t = model.tmpls.find(t=> t.ord === state.templateEditor.ord);
  if(t){ t.afmt = e.target.value; renderTemplateLivePreview(); }
});
document.getElementById('tplEditorCss').addEventListener('input', e=>{
  const model = ahCurrentTplModel();
  if(!model) return;
  model.css = e.target.value;
  renderTemplateLivePreview();
});

document.getElementById('tplBtnReset').addEventListener('click', ()=>{
  const model = ahCurrentTplModel();
  const snap = state.templateOriginals[state.currentMid];
  if(!model || !snap){ toast('Belum ada perubahan buat di-reset~', '🤔'); return; }
  model.css = snap.css;
  model.tmpls.forEach(t=>{
    const orig = snap.tmpls.find(o=> o.ord === t.ord);
    if(orig){ t.qfmt = orig.qfmt; t.afmt = orig.afmt; }
  });
  loadTemplateEditorTextareas();
  renderTemplateLivePreview();
  toast('Template & CSS dibalikin ke desain asli~', '↺');
});

function updateBgStatus(){
  const el = document.getElementById('bgStatus');
  if(!el) return;
  const cfg = state.cardBg;
  if(!ahHasBgImage(cfg)){ el.textContent = ''; return; }
  if(!cfg.front && !cfg.back){ el.textContent = 'Belum diterapkan ke sisi manapun — klik "Terapkan ke Depan/Belakang" di atas.'; return; }
  const sides = [cfg.front ? 'Depan' : null, cfg.back ? 'Belakang' : null].filter(Boolean).join(' & ');
  el.textContent = `✅ Background aktif di: ${sides} — bakal ikut kesimpen pas kamu download .apkg`;
}

/* ---- helper deskripsi deck otomatis, dipakai pas save ---- */
const AH_DESC_START = '[AnkiHoney]';
const AH_DESC_END = '[/AnkiHoney]';

function ahBuildDeckDescBlock(){
  const tgl = new Date().toLocaleString('id-ID', { dateStyle:'medium', timeStyle:'short' });
  return `${AH_DESC_START}
<div style="font-family:'Poppins','Segoe UI',sans-serif; line-height:1.6; font-size:13px;">
<style>
.ah-rgb-text{
  background:linear-gradient(90deg,#ff5f6d,#ffc371,#47cf73,#38b6ff,#a855f7,#ff5f6d);
  background-size:300% 100%;
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; color:transparent;
  font-weight:700; letter-spacing:.3px;
  animation:ah-rgb-shift 6s linear infinite;
}
@keyframes ah-rgb-shift{ 0%{background-position:0% 50%;} 100%{background-position:300% 50%;} }
</style>
<span class="ah-rgb-text">✨ yumelyrics / ankihoney</span> — deck ini diupdate otomatis pada ${tgl}.<br>
Gabung <a href="https://discord.gg/SW9bTRHK8H" target="_blank" rel="noopener" style="color:#5865F2; font-weight:700; text-decoration:none; border-bottom:1.5px dashed #5865F2;">Discord</a> kita buat request terjemahan deck &amp; update terbaru ya~
</div>
${AH_DESC_END}`;
}

function ahStripDeckDesc(desc){
  desc = desc || '';
  const re = new RegExp(escapeRegex(AH_DESC_START)+'[\\s\\S]*?'+escapeRegex(AH_DESC_END)+'\\n?', 'g');
  return desc.replace(re, '').trim();
}

// Gabungin deskripsi asli (kalau ada, keterangan lama user tetap dipertahankan) dengan
// blok deskripsi AnkiHoney yang baru — dipanggil ulang tiap export biar tanggalnya update terus.
function ahApplyDeckDesc(origDesc){
  const kept = ahStripDeckDesc(origDesc);
  const block = ahBuildDeckDescBlock();
  return kept ? (kept + '\n\n' + block) : block;
}

/* ---- helper suntik background ke template Anki (qfmt/afmt/css), dipakai pas save ---- */
const AH_BG_START = '/* === AnkiHoney Background START === */';
const AH_BG_END = '/* === AnkiHoney Background END === */';
// Lebar viewport (px) buat mbedain render Desktop vs Mobile pas kartu dibuka
// beneran di Anki -- app Anki di HP (AnkiDroid/AnkiMobile) rendernya webview
// selebar layar device (biasanya jauh di bawah ini), sedangkan Anki desktop
// window-nya biasanya lebih lebar dari ini. Dipakai di @media buat milih
// posisi foto mana (Desktop atau Mobile) yang berlaku.
const AH_MOBILE_BREAKPOINT = 600;
const AH_WRAP_OPEN = '<div class="ankihoney-bg">';
const AH_WRAP_CLOSE = '</div><!-- /ankihoney-bg -->';

function escapeRegex(s){ return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

function ahWrapTemplate(html, enable){
  html = html || '';
  const trimmed = html.trim();
  const alreadyWrapped = trimmed.startsWith(AH_WRAP_OPEN) && trimmed.endsWith(AH_WRAP_CLOSE);
  if(enable){
    if(alreadyWrapped) return html;
    return AH_WRAP_OPEN + html + AH_WRAP_CLOSE;
  }
  if(alreadyWrapped){
    return trimmed.slice(AH_WRAP_OPEN.length, trimmed.length - AH_WRAP_CLOSE.length);
  }
  return html;
}

function ahStripCssBlock(css){
  css = css || '';
  const re = new RegExp(escapeRegex(AH_BG_START)+'[\\s\\S]*?'+escapeRegex(AH_BG_END)+'\\n?', 'g');
  return css.replace(re, '').trim();
}

function ahBuildCssBlock(cfg){
  const sizeMap = { cover:'cover', contain:'contain', stretch:'100% 100%' };
  const opacity = Math.max(0, Math.min(100, cfg.opacity)) / 100;
  const overlay = Math.max(0, Math.min(100, cfg.overlay)) / 100;
  const blur = Math.max(0, Math.min(20, cfg.blur));
  const posX = Math.max(0, Math.min(100, cfg.posX != null ? cfg.posX : 50));
  const posY = Math.max(0, Math.min(100, cfg.posY != null ? cfg.posY : 50));
  // Kalau posisi Mobile belum pernah diatur user, jatuh ke posisi Desktop
  // (bukan default 50/50 mentah) biar hasilnya tetep masuk akal walau user
  // cuma sempet ngatur satu device doang.
  const mobilePosX = Math.max(0, Math.min(100, cfg.mobilePosX != null ? cfg.mobilePosX : posX));
  const mobilePosY = Math.max(0, Math.min(100, cfg.mobilePosY != null ? cfg.mobilePosY : posY));

  const fx = cfg.textFx || { enabled:true, styleMode:'glow', color:'#000000', strength:3, target:'bold' };
  // Selector ini SENGAJA dibatesin ke <b>/<strong> literal doang (yang cuma
  // muncul dari isi field asli kayak SentKanji/VocabDef/Notes -- template ini
  // gak nyisipin <b>/<strong> di tempat lain kayak header/footer/tags), jadi
  // efeknya cuma nempel di kosakata yang emang dikutip/di-bold di dalam field,
  // gak pernah ngerembet ke elemen lain di kartu.
  const fxSelector = fx.target === 'all' ? '.ankihoney-bg, .ankihoney-bg *' : '.ankihoney-bg b, .ankihoney-bg strong';
  const fxDeclarations = ahBuildTextFxCss(cfg).map(d => `  ${d};`).join('\n');
  const fxCss = fx.enabled !== false
    ? `/* Kosakata yang di-bold di dalam field (Notes/Definitions/kalimat) dikasih
   outline/glow custom biar tetep kebaca jelas di atas foto apa pun. Mode
   'outline': isi huruf putih polos, cuma pinggirannya doang yang kena warna
   custom (gak nyebar ke karakter lain). Gaya, warna & ketebalannya bisa
   diatur di form. */
${fxSelector}{
${fxDeclarations}
}
`
    : '';

  // Warna bold/strong BAWAAN deck (--color-headword, biasanya ungu/pink terang di
  // .jpsentence b/strong) sengaja dibikin dulu kontrasnya -- soalnya begitu fitur
  // Outline/Shadow di atas aktif, si outline/glow itu sendiri udah yang jadi
  // "penanda" utama biar kosakata kebaca jelas, jadi warna isi hurufnya gak perlu
  // se-vivid biasanya lagi (kalau tetep vivid, isi teks & outline malah rebutan
  // perhatian / keliatan rame). Cuma jalan pas mode 'glow' -- di mode 'outline'
  // warna isi huruf udah dipaksa putih polos sama fxDeclarations di atas, jadi
  // gak perlu diredam lagi.
  const mutedHeadwordCss = (fx.enabled !== false && fx.styleMode !== 'outline')
    ? `/* Redam warna bold/strong bawaan deck (headword) pas Outline/Shadow aktif,\n   biar gak rebutan kontras sama efeknya. */\n.ankihoney-bg .jpsentence b,\n.ankihoney-bg .jpsentence strong{\n  opacity: 0.72;\n}\n`
    : '';

  // Panel semi-solid di belakang blok teks non-vocab (Notes, Definitions, link footer,
  // kotak "Reveal English translation"). Ini SELALU aktif & TIDAK ikut pengaturan
  // Outline/Shadow Teks Vocab di atas -- fitur itu sengaja cuma buat kosakata yang
  // di-bold. Tanpa panel ini, teks biasa (yang warnanya gelap secara default di
  // template) ketelen sama foto+overlay begitu di atas background gelap.
  const panelCss = `/* Panel semi-solid biar Notes/Definitions/footer/link tetep kebaca jelas di
   atas foto apa pun. Ini terpisah dari Outline/Shadow Vocab di atas (yang cuma
   nyentuh teks bold) -- panel ini nyentuh blok teks non-bold. */
.ankihoney-bg details,
.ankihoney-bg .headword_section,
.ankihoney-bg footer,
.ankihoney-bg div.ensentence > a.hint{
  background: rgba(20,10,20,0.62) !important;
  color: #f5eefb !important;
  border-color: rgba(255,255,255,0.25) !important;
}
.ankihoney-bg details a,
.ankihoney-bg footer a,
.ankihoney-bg summary{
  color: #ffd3ea !important;
}
.ankihoney-bg footer > a:not(:last-child)::after{
  color: #ffd3ea !important;
}
`;

  return `
${AH_BG_START}
.card{ background-color:transparent !important; background-image:none !important; background:transparent !important; }
html, body{ background-color:transparent !important; }
.ankihoney-bg{ position:relative; isolation:isolate; }
.ankihoney-bg::before{
  content:""; position:fixed; inset:0; z-index:-2;
  background-image:url('${ahBgImageRef(cfg)}');
  background-size:${sizeMap[cfg.fit]||'cover'};
  background-position:${posX}% ${posY}%;
  background-repeat:no-repeat;
  opacity:${opacity};
  filter:blur(${blur}px);
}
.ankihoney-bg::after{
  content:""; position:fixed; inset:0; z-index:-1;
  background:rgba(0,0,0,${overlay});
}
/* Posisi foto khusus buat layar sempit (HP -- AnkiDroid/AnkiMobile), diatur
   terpisah dari posisi Desktop di atas lewat tab "📱 Mobile" pas ngatur foto
   di AnkiHoney. Breakpoint ${AH_MOBILE_BREAKPOINT}px dipakai karena app Anki
   di HP biasanya render webview selebar layar device (jauh lebih sempit
   dibanding window Anki desktop). */
@media (max-width:${AH_MOBILE_BREAKPOINT}px){
  .ankihoney-bg::before{
    background-position:${mobilePosX}% ${mobilePosY}%;
  }
}
${fxCss}${mutedHeadwordCss}${panelCss}/* Cegah dobel lapis: kalau Belakang pake {{FrontSide}}, HTML Depan yang udah
   dibungkus .ankihoney-bg ikut ke-embed di dalam Belakang, jadi ada wrapper
   nested. Matiin pseudo-element punya wrapper yang ke-nested itu biar overlay
   & blur cuma ke-apply 1x, gak numpuk 2x. */
.ankihoney-bg .ankihoney-bg::before,
.ankihoney-bg .ankihoney-bg::after{ content:none !important; display:none !important; }
${AH_BG_END}
`;
}

// Suntik/lepas background ke satu objek model Anki (dipakai buat format lama & format rebuild legacy)
function applyCardBackgroundToModel(model, cfg){
  if(!model) return;
  let css = ahStripCssBlock(model.css || '');
  const hasBg = !!(cfg && ahBgImageRef(cfg) && (cfg.front || cfg.back));
  if(hasBg) css = css + ahBuildCssBlock(cfg);
  model.css = css;
  model.tmpls = (model.tmpls || []).map(t=> ({
    ...t,
    qfmt: ahWrapTemplate(t.qfmt, hasBg && cfg.front),
    afmt: ahWrapTemplate(t.afmt, hasBg && cfg.back)
  }));
  // PENTING: kalau note type ini ID-nya udah ada di koleksi Anki user (kepake bareng
  // di banyak deck), Anki cuma nge-update note type pas IMPORT kalau field `mod`
  // (waktu edit) di file yang diimport lebih baru dari yang ada di koleksi. Tanpa ini,
  // perubahan CSS/template bisa "ke-skip" diem-diem walau data notenya tetep masuk.
  model.mod = Math.floor(Date.now()/1000);
  model.usn = -1;
}

/* ---- helper suntik watermark "yumelyrics / ankihoney" ke tiap kartu, dipakai pas save ---- */
const AH_WM_CSS_START = '/* === AnkiHoney Watermark START === */';
const AH_WM_CSS_END = '/* === AnkiHoney Watermark END === */';
const AH_WM_HTML_START = '<!-- AnkiHoney Watermark START -->';
const AH_WM_HTML_END = '<!-- AnkiHoney Watermark END -->';
const AH_WM_TEXT = '🍯 yumelyrics / ankihoney';
const AH_WM_URL = 'https://discord.gg/SW9bTRHK8H';
const AH_WM_HTML = `${AH_WM_HTML_START}<a class="ankihoney-wm" href="${AH_WM_URL}" target="_blank" rel="noopener">${AH_WM_TEXT}</a>${AH_WM_HTML_END}`;
const AH_WM_CSS = `\n${AH_WM_CSS_START}\n.ankihoney-wm{\n  position:fixed; right:8px; bottom:5px; z-index:9999;\n  font-family:'Poppins','Quicksand','Century Gothic','Segoe UI',system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif;\n  font-size:10.5px; font-weight:600; letter-spacing:.3px;\n  color:#a8a8a8; opacity:.6; text-decoration:none; pointer-events:auto; cursor:pointer;\n  transition:opacity .15s ease;\n}\n.ankihoney-wm:hover{ opacity:.95; color:#7a7a7a; text-decoration:underline; }\n${AH_WM_CSS_END}\n`;

function ahStripWmHtml(html){
  html = html || '';
  const re = new RegExp(escapeRegex(AH_WM_HTML_START)+'[\\s\\S]*?'+escapeRegex(AH_WM_HTML_END), 'g');
  return html.replace(re, '');
}

function ahStripWmCss(css){
  css = css || '';
  const re = new RegExp(escapeRegex(AH_WM_CSS_START)+'[\\s\\S]*?'+escapeRegex(AH_WM_CSS_END)+'\\n?', 'g');
  return css.replace(re, '').trim();
}

// Suntik watermark ke satu objek model Anki: tambahin div kecil di pojok tiap
// template (qfmt & afmt) + CSS-nya. Dipanggil otomatis buat semua model pas rebuild.
function applyWatermarkToModel(model){
  if(!model) return;
  model.css = ahStripWmCss(model.css || '') + AH_WM_CSS;
  model.tmpls = (model.tmpls || []).map(t=> ({
    ...t,
    qfmt: ahStripWmHtml(t.qfmt || '') + AH_WM_HTML,
    afmt: ahStripWmHtml(t.afmt || '') + AH_WM_HTML
  }));
  // Sama kayak di applyCardBackgroundToModel: paksa Anki nganggep note type ini
  // "lebih baru" pas import, biar perubahan (watermark & background) gak ke-skip
  // kalau note type dengan ID yang sama udah ada duluan di koleksi user.
  model.mod = Math.floor(Date.now()/1000);
  model.usn = -1;
}

// Suntik watermark ke TAG asli Anki (bukan ke isi field manapun) — jadi gak pernah
// numpang ke field konten (yang bisa aja lagi dipakai template buat nampilin sesuatu,
// misal field "Tags" custom milik user sendiri) dan gak ngerusak tampilan kartu sama
// sekali. Tetep nempel ke DATA note (bukan cuma template), cuma gak keliatan di kartu,
// cuma keliatan di list tag / browser Anki. Dipanggil pas EXPORT aja.
const AH_WM_TAG = 'yumelyrics/ankihoney';
function injectWmIntoTags(tags){
  const parts = (tags || '').trim().split(/\s+/).filter(t=> t && t !== AH_WM_TAG);
  parts.push(AH_WM_TAG);
  return parts.join(' ');
}

// Tambahin file foto background ke media map suatu zip (format lama, media map = JSON)
async function ensureBgMediaInZip(zip, bytes, filename){
  let mediaMap = {};
  const mediaEntry = zip.file('media');
  if(mediaEntry){
    const bytes2 = await mediaEntry.async('uint8array');
    try{ mediaMap = JSON.parse(new TextDecoder().decode(bytes2)); }
    catch(e){ const parsed = tryParseMediaProtobuf(bytes2); if(parsed) mediaMap = parsed; }
  }
  const usedNums = Object.keys(zip.files).filter(n=>/^\d+$/.test(n)).map(n=>parseInt(n));
  const mapNums = Object.keys(mediaMap).map(n=>parseInt(n)).filter(n=>!isNaN(n));
  const maxNum = Math.max(-1, ...usedNums, ...mapNums);
  const key = String(maxNum+1);
  zip.file(key, bytes);
  mediaMap[key] = filename;
  zip.file('media', JSON.stringify(mediaMap));
  return filename;
}

// Suntik background ke note type yang lagi dipilih, langsung ke col.models di db format lama (schema 11/legacy)
// Terapin nama deck custom dari form user ke database format lama (in-place edit).
// PENTING: Anki nyocokin deck pas import berdasarkan ID, bukan nama — kalau ID-nya
// sama kayak deck yang udah ada di koleksi Anki user, nama baru bakal DIABAIKAN dan
// tetep pake nama lama. Makanya di sini bikin ID deck BARU (belum pernah ada) buat
// deck yang namanya diganti, biar Anki nganggep itu deck baru & beneran pake nama
// custom-nya, kartu-kartunya ikut dipindah ke ID baru itu (jadwal belajar tetap aman,
// gak kepengaruh karena disimpen di tabel cards, bukan di deck).
function applyDeckRenamesLegacy(){
  const res = state.db.exec("SELECT decks FROM col");
  if(!res.length || !res[0].values.length) return;
  let decksJson;
  try{ decksJson = JSON.parse(res[0].values[0][0]); }catch(e){ return; }

  // 1. Rename (kasih ID baru) buat deck yang namanya diganti dari form
  let offset = 0;
  const overrides = state.deckNameOverrides || {};
  Object.keys(overrides).forEach(did=>{
    const newName = overrides[did];
    const orig = decksJson[did];
    if(!orig || orig.name === newName) return;
    const newId = Date.now() + (offset++);
    decksJson[String(newId)] = { ...orig, id: newId, name: newName };
    state.db.run("UPDATE cards SET did=? WHERE did=?", [newId, parseInt(did)]);
    delete decksJson[did];
  });

  // 2. Tempelin/refresh deskripsi otomatis AnkiHoney ke semua deck yang ada
  Object.keys(decksJson).forEach(id=>{
    decksJson[id].desc = ahApplyDeckDesc(decksJson[id].desc || '');
  });

  state.db.run("UPDATE col SET decks=?", [JSON.stringify(decksJson)]);
}

// Salin balik perubahan Front/Back Template & Styling (CSS) yang dibikin lewat
// editor -- kesimpen di state.models -- ke JSON models mentah yang baru dibaca
// ulang dari db. Perlu ini karena export format lama baca ulang langsung dari
// db (bukan dari state.models), jadi tanpa ini editan template/CSS user bisa
// "ke-skip" diem-diem walau udah keliatan berubah di preview.
function applyTemplateEditsToModelsJson(modelsJson){
  Object.keys(modelsJson).forEach(mid=>{
    const edited = state.models[mid];
    const raw = modelsJson[mid];
    if(!edited || !raw) return;
    if(typeof edited.css === 'string') raw.css = edited.css;
    (raw.tmpls || []).forEach(rt=>{
      const et = (edited.tmpls || []).find(t=> t.ord === rt.ord);
      if(et){ rt.qfmt = et.qfmt; rt.afmt = et.afmt; }
    });
  });
}

async function applyCardBackgroundLegacy(){
  const res = state.db.exec("SELECT models FROM col");
  if(!res.length || !res[0].values.length) return;
  let modelsJson;
  try{ modelsJson = JSON.parse(res[0].values[0][0]); }catch(e){ return; }
  applyTemplateEditsToModelsJson(modelsJson);
  const model = modelsJson[state.currentMid];
  if(!model) return;

  const cfg = state.cardBg;
  const hasBg = ahHasBgImage(cfg) && (cfg.front || cfg.back);
  if(hasBg){
    if(cfg.mode !== 'url'){
      await ensureBgMediaInZip(state.zip, cfg.bytes, cfg.mediaFilename);
    }
    applyCardBackgroundToModel(model, cfg);
  } else {
    applyCardBackgroundToModel(model, { front:false, back:false });
  }
  Object.keys(modelsJson).forEach(mid=> applyWatermarkToModel(modelsJson[mid]));
  state.db.run("UPDATE col SET models=?", [JSON.stringify(modelsJson)]);
}

/* ---------------- readers yang jalan di semua versi skema Anki ---------------- */

/* ---- decoder protobuf generik minimal (best-effort), dipakai buat baca
   desain kartu asli (qfmt/afmt/css) dari notetypes.config & templates.config
   di skema baru (v15+/v18). Field number di bawah dicocokkan dari source
   rslib Anki (CardTemplateConfig: q_format=1, a_format=2; NotetypeConfig:
   kind=1, sort_field_idx=2, css=3) — bukan API resmi, jadi kalau versi Anki
   ke depan ganti layout protobuf-nya, kode ini fallback aman ke template
   generik biasa (liat hasOriginalDesign di rebuildAsLegacyApkg) ---- */
function pbReadVarint(bytes, pos){
  let result = 0, shift = 0, b;
  do{
    b = bytes[pos.i++];
    result += (b & 0x7f) * Math.pow(2, shift);
    shift += 7;
  } while(b & 0x80);
  return result;
}
function pbDecode(bytes){
  const fields = {};
  const pos = {i:0};
  while(pos.i < bytes.length){
    const tag = pbReadVarint(bytes, pos);
    const fieldNum = tag >>> 3, wireType = tag & 0x7;
    let entry;
    if(wireType === 0){
      entry = { wireType, varint: pbReadVarint(bytes, pos) };
    } else if(wireType === 2){
      const len = pbReadVarint(bytes, pos);
      entry = { wireType, raw: bytes.slice(pos.i, pos.i+len) };
      pos.i += len;
    } else if(wireType === 1){
      entry = { wireType, raw: bytes.slice(pos.i, pos.i+8) }; pos.i += 8;
    } else if(wireType === 5){
      entry = { wireType, raw: bytes.slice(pos.i, pos.i+4) }; pos.i += 4;
    } else {
      throw new Error('wiretype protobuf tak dikenal: '+wireType);
    }
    if(!fields[fieldNum]) fields[fieldNum] = [];
    fields[fieldNum].push(entry);
  }
  return fields;
}
function pbGetString(fields, num){
  const arr = fields[num];
  if(!arr || !arr.length) return '';
  const last = arr[arr.length-1];
  if(last.wireType !== 2) return '';
  try{ return new TextDecoder().decode(last.raw); }catch(e){ return ''; }
}
function pbGetVarint(fields, num){
  const arr = fields[num];
  if(!arr || !arr.length) return null;
  const last = arr[arr.length-1];
  return last.wireType === 0 ? last.varint : null;
}

// Nomor field css di NotetypeConfig (best-effort tebakan = 3) gak sepenuhnya
// bisa diverifikasi dari luar source Anki, jadi biar gak gampang ketuker sama
// string field lain di config yang sama (misal latex_pre/latex_post), kita
// scoring semua kandidat string top-level & pilih yang paling "keliatan CSS".
function pbGuessCss(fields){
  let best = '', bestScore = -Infinity;
  Object.keys(fields).forEach(numStr=>{
    fields[numStr].forEach(entry=>{
      if(entry.wireType !== 2) return;
      let text;
      try{ text = new TextDecoder().decode(entry.raw); }catch(e){ return; }
      if(!text) return;
      let score = 0;
      if(/\.card\b/.test(text)) score += 10;
      if(/\{[^{}]*:[^{}]*;/.test(text)) score += 5; // pola "properti: nilai;"
      if(/\\documentclass|\\usepackage|\\begin\{document\}/.test(text)) score -= 100; // itu latex, bukan css
      if(/\{\{.*?\}\}/.test(text)) score -= 100; // itu qfmt/afmt (handlebars), bukan css
      if(numStr === '3') score += 1; // tie-breaker: field 3 = tebakan awal dari pola proto Anki
      if(score > bestScore){ bestScore = score; best = text; }
    });
  });
  return bestScore > 0 ? best : (pbGetString(fields, 3) || '');
}

// Baca desain kartu asli (css + qfmt/afmt tiap template) dari tabel notetypes/templates
// skema baru. Balikin mid -> {css, type, tmpls:[{name,ord,qfmt,afmt}]}. Best-effort:
// kalau satu blob gagal di-decode, note type itu aja yang dilewatin (gak nge-crash semua).
function getNewSchemaModelDesigns(db){
  const designs = {};
  try{
    const nt = db.exec("SELECT id, config FROM notetypes");
    if(nt.length){
      nt[0].values.forEach(([id, configBlob])=>{
        try{
          const fields = pbDecode(new Uint8Array(configBlob));
          const css = pbGuessCss(fields);
          const kind = pbGetVarint(fields, 1);
          designs[id] = { css: css || '', type: kind===1 ? 1 : 0, tmpls: [] };
        }catch(e){ console.warn('gagal decode notetypes.config (best-effort), mid='+id, e); }
      });
    }
  }catch(e){ console.warn('gagal baca tabel notetypes.config', e); }

  try{
    const tpl = db.exec("SELECT ntid, ord, name, config FROM templates ORDER BY ntid, ord");
    if(tpl.length){
      tpl[0].values.forEach(([ntid, ord, name, configBlob])=>{
        if(!designs[ntid]) designs[ntid] = { css:'', type:0, tmpls:[] };
        try{
          const fields = pbDecode(new Uint8Array(configBlob));
          const qfmt = pbGetString(fields, 1);
          const afmt = pbGetString(fields, 2);
          designs[ntid].tmpls.push({ name: name||('Card '+(ord+1)), ord, qfmt, afmt, bqfmt:'', bafmt:'', did:null, bfont:'', bsize:0 });
        }catch(e){ console.warn('gagal decode templates.config (best-effort), ntid='+ntid, e); }
      });
    }
  }catch(e){ console.warn('gagal baca tabel templates', e); }
  return designs;
}

// Note type / model: skema lama (v11) simpan JSON di col.models, lengkap sama
// desain kartunya (tmpls: qfmt/afmt, css). Skema baru (v15+/v18) pindahin ke
// tabel notetypes+fields+templates, desainnya dibungkus protobuf (getNewSchemaModelDesigns).
function getModelsAnyVersion(db){
  let models = {};
  try{
    const res = db.exec("SELECT models FROM col");
    if(res.length && res[0].values.length){
      const json = res[0].values[0][0];
      if(json && json !== '{}'){
        const parsed = JSON.parse(json);
        Object.keys(parsed).forEach(mid=>{
          const m = parsed[mid];
          models[mid] = {
            name: m.name,
            flds: m.flds.map(f=>f.name),
            type: m.type || 0,
            css: m.css || '',
            tmpls: (m.tmpls||[]).map(t=>({
              name: t.name, ord: t.ord, qfmt: t.qfmt||'', afmt: t.afmt||'',
              bqfmt: t.bqfmt||'', bafmt: t.bafmt||'', did:null, bfont: t.bfont||'', bsize: t.bsize||0
            }))
          };
        });
      }
    }
  }catch(e){ /* skema baru, gapapa lanjut ke fallback */ }

  if(Object.keys(models).length === 0){
    try{
      const nt = db.exec("SELECT id, name FROM notetypes");
      const fl = db.exec("SELECT ntid, ord, name FROM fields ORDER BY ntid, ord");
      if(nt.length){
        const fieldMap = {};
        if(fl.length){
          fl[0].values.forEach(([ntid, ord, name])=>{
            if(!fieldMap[ntid]) fieldMap[ntid] = [];
            fieldMap[ntid][ord] = name;
          });
        }
        const designs = getNewSchemaModelDesigns(db);
        nt[0].values.forEach(([id, name])=>{
          const d = designs[id] || {};
          models[id] = {
            name,
            flds: (fieldMap[id]||[]).filter(n=>n!==undefined),
            type: d.type || 0,
            css: d.css || '',
            tmpls: (d.tmpls||[]).filter(t=> t.qfmt) // buang kalau protobuf gagal / kosong
          };
        });
      }
    }catch(e){ console.warn('gagal baca notetypes', e); }
  }
  return models;
}

// Cek apakah desain kartu asli (qfmt/afmt tiap template) berhasil ditangkap
// buat suatu model — dipakai buat mutusin rebuild pake desain asli vs generik.
function modelHasOriginalDesign(m){
  return !!(m && m.tmpls && m.tmpls.length && m.tmpls.every(t=> t.qfmt));
}

// Nama + deskripsi deck: skema lama -> JSON di col.decks. Skema baru (v18+) -> tabel decks.
function getDecksAnyVersion(db){
  let decks = {};
  let descs = {};
  try{
    const res = db.exec("SELECT decks FROM col");
    if(res.length && res[0].values.length){
      const json = res[0].values[0][0];
      if(json && json !== '{}'){
        const parsed = JSON.parse(json);
        Object.keys(parsed).forEach(id=>{ decks[id] = parsed[id].name; descs[id] = parsed[id].desc || ''; });
      }
    }
  }catch(e){ /* fallback di bawah */ }
  if(Object.keys(decks).length === 0){
    try{
      const dk = db.exec("SELECT id, name FROM decks");
      if(dk.length) dk[0].values.forEach(([id, name])=>{ decks[id] = name; });
    }catch(e){ console.warn('gagal baca decks', e); }
  }
  state.decksDescMap = descs;
  return decks;
}

// Ambil baris tabel apa adanya, dengan kolom eksplisit yang formatnya stabil
// dari skema v11 sampai v18 — dipakai buat mindahin cards/revlog apa adanya
// pas kita harus rebuild collection ke format legacy.
function readRowsSafe(db, sql){
  try{
    const res = db.exec(sql);
    if(!res.length) return [];
    return res[0].values;
  }catch(e){
    console.warn('readRowsSafe gagal:', sql, e);
    return [];
  }
}

function populateDeckNameInputs(){
  state.deckNameOverrides = {};
  const wrap = document.getElementById('deckNameList');
  wrap.innerHTML = '';

  // Cuma tampilin deck yang beneran ditempelin kartu (bukan deck kosong/parent bawaan Anki)
  let idsToShow = (state.usedDeckIds && state.usedDeckIds.length)
    ? state.usedDeckIds.filter(id=> state.decksMap[id] !== undefined)
    : Object.keys(state.decksMap);
  if(idsToShow.length === 0) idsToShow = Object.keys(state.decksMap);
  if(idsToShow.length === 0) return;

  if(idsToShow.length === 1){
    const id = idsToShow[0];
    const origName = state.decksMap[id];
    const row = document.createElement('div');
    row.className = 'deck-name-row';
    row.innerHTML = `<input type="text" class="deckNameInput" data-did="${id}" placeholder="${origName}" value="${origName}" />`;
    wrap.appendChild(row);
  } else {
    idsToShow.forEach(id=>{
      const origName = state.decksMap[id];
      const row = document.createElement('div');
      row.className = 'deck-name-row';
      row.innerHTML = `
        <div class="deck-name-orig">Ganti nama deck: "${origName}"</div>
        <input type="text" class="deckNameInput" data-did="${id}" placeholder="${origName}" value="${origName}" />
      `;
      wrap.appendChild(row);
    });
  }

  wrap.querySelectorAll('.deckNameInput').forEach(inp=>{
    inp.addEventListener('input', ()=>{
      const did = inp.dataset.did;
      const val = inp.value.trim();
      if(val) state.deckNameOverrides[did] = val;
      else delete state.deckNameOverrides[did];
    });
  });
}

function populateModelSelect(){
  const sel = document.getElementById('modelSelect');
  sel.innerHTML = '';
  const midsUsed = [...new Set(state.notes.map(n=>n.mid))];
  midsUsed.forEach(mid=>{
    const model = state.models[mid];
    if(!model) return;
    const count = state.notes.filter(n=>n.mid===mid).length;
    const opt = document.createElement('option');
    opt.value = mid;
    opt.textContent = `${model.name} (${count} notes)`;
    sel.appendChild(opt);
  });
  sel.onchange = ()=>{ state.currentMid = sel.value; state.tablePageIndex = 0; populateFieldSelect(); updateBgModelLabel(); renderTable(); populateTemplateEditor(); ahAtRefreshMappingsForModel(); };
  if(midsUsed.length){
    state.currentMid = midsUsed[0];
    sel.value = midsUsed[0];
  }
  populateFieldSelect();
  updateBgModelLabel();
  renderTable(); // fix: dulu tabel baru muncul kalau field select diutak-atik manual, sekarang langsung render pas upload
  populateTemplateEditor();
  ahAtRefreshMappingsForModel();
}

function updateBgModelLabel(){
  const el = document.getElementById('bgModelName');
  if(!el) return;
  const model = state.models[state.currentMid];
  el.textContent = model ? model.name : '-';
  updateBgPreview();
}

function populateFieldSelect(){
  const container = document.getElementById('fieldChecks');
  container.innerHTML = '';
  const model = state.models[state.currentMid];
  if(!model) return;

  // Inget pilihan field yang dicentang & yang ditandain 🔒 sumber SECARA TERPISAH per
  // note type (mid) -- dulu ini ke-reset total ke default (cuma field pertama) tiap
  // pindah note type, jadi kalau user udah rapiin centang+lock buat note type A lalu
  // ngecek note type B, terus balik lagi ke A, semua pilihannya ilang (bug). Sekarang
  // dipulihin dari cache kalau note type ini udah pernah diatur sebelumnya.
  const cached = state.fieldSelectionByModel[state.currentMid];
  if(cached){
    state.selectedFieldIdxs = cached.selected.filter(i=> i < model.flds.length);
    state.referenceFieldIdxs = cached.reference.filter(i=> i < model.flds.length && state.selectedFieldIdxs.includes(i));
    if(!state.selectedFieldIdxs.length) state.selectedFieldIdxs = model.flds.length ? [0] : [];
  } else {
    state.selectedFieldIdxs = model.flds.length ? [0] : [];
    state.referenceFieldIdxs = [];
  }
  function saveFieldSelectionCache(){
    state.fieldSelectionByModel[state.currentMid] = {
      selected: state.selectedFieldIdxs.slice(),
      reference: state.referenceFieldIdxs.slice()
    };
  }

  model.flds.forEach((name, idx)=>{
    const isSelected = state.selectedFieldIdxs.includes(idx);
    const isRef = state.referenceFieldIdxs.includes(idx);
    const chip = document.createElement('label');
    chip.className = 'field-chip' + (isSelected ? ' active' : '');
    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.checked = isSelected;
    chip.appendChild(cb);
    chip.appendChild(document.createTextNode(`${idx+1}. ${name}`));

    // Toggle "field sumber": field yang dipakai AI buat konteks (misal Kanji asli) tapi
    // HARUSNYA gak ikut berubah pas ditranslate -- beda sama field target yang emang diisi
    // hasil terjemahan. Ini bikin tool bisa ngedeteksi kalau field sumber ternyata ikut berubah
    // (tanda ke-translate/ke-swap gak sengaja), tanpa perlu nebak-nebak nama field.
    const lockBtn = document.createElement('span');
    lockBtn.className = 'field-lock' + (isRef ? ' active' : '');
    lockBtn.textContent = isRef ? '🔒' : '🔓';
    lockBtn.title = 'Tandain sebagai field SUMBER/REFERENSI (misal Kanji asli) yang harusnya GAK berubah pas ditranslate — beda sama field target yang emang diisi hasil terjemahan.';
    chip.appendChild(lockBtn);

    // Tombol instruksi khusus per field: field target (misal "Notes") bisa dikasih perintah
    // tambahan buat AI translator -- ikut kecopy ke teks yang ditempel ke AI, jadi AI-nya tau
    // persis mau diisi apa di field itu (misal minta penjelasan lengkap kosakata + furigana).
    const instrBtn = document.createElement('span');
    instrBtn.className = 'field-lock field-instr';
    instrBtn.textContent = '📝';
    instrBtn.title = 'Tambahin instruksi khusus buat AI translator pas ngisi field ini (misal: minta penjelasan lengkap kosakata, format furigana, dst). Instruksi ini ikut kecopy ke teks yang ditempel ke AI.';
    chip.appendChild(instrBtn);
    function refreshInstrBtn(){
      const has = !!(ahCurrentFieldInstructions()[idx] && ahCurrentFieldInstructions()[idx].trim());
      instrBtn.classList.toggle('active', has);
    }
    refreshInstrBtn();
    instrBtn.addEventListener('click', (e)=>{
      e.preventDefault(); e.stopPropagation();
      if(!cb.checked){ toast('Centang field-nya dulu, baru bisa dikasih instruksi khusus~', '⚠️'); return; }
      openFieldInstructionModal(idx, name, refreshInstrBtn);
    });

    cb.addEventListener('change', ()=>{
      let idxs = state.selectedFieldIdxs.slice();
      if(cb.checked){
        if(!idxs.includes(idx)) idxs.push(idx);
      } else {
        idxs = idxs.filter(i=> i!==idx);
      }
      if(idxs.length === 0){
        cb.checked = true;
        idxs = [idx];
        toast('Minimal 1 field harus dicentang ya~', '⚠️');
      }
      idxs.sort((a,b)=>a-b);
      state.selectedFieldIdxs = idxs;
      chip.classList.toggle('active', cb.checked);
      if(!cb.checked){
        state.referenceFieldIdxs = state.referenceFieldIdxs.filter(i=> i!==idx);
        lockBtn.textContent = '🔓';
        lockBtn.classList.remove('active');
      }
      saveFieldSelectionCache();
      renderTable();
    });

    lockBtn.addEventListener('click', (e)=>{
      e.preventDefault(); e.stopPropagation();
      if(!cb.checked){ toast('Centang field-nya dulu, baru bisa ditandain sumber~', '⚠️'); return; }
      let refs = state.referenceFieldIdxs.slice();
      if(refs.includes(idx)){
        refs = refs.filter(i=> i!==idx);
        lockBtn.textContent = '🔓';
        lockBtn.classList.remove('active');
      } else {
        refs.push(idx);
        lockBtn.textContent = '🔒';
        lockBtn.classList.add('active');
        toast(`"${name}" ditandain sebagai field sumber — harusnya gak berubah pas ditranslate~`, '🔒');
      }
      state.referenceFieldIdxs = refs;
      saveFieldSelectionCache();
    });

    container.appendChild(chip);
  });
  updateStats();
}

function updateStats(){
  const row = document.getElementById('statsRow');
  const total = state.notes.filter(n=>n.mid===state.currentMid).length;
  const dirty = state.notes.filter(n=>n.mid===state.currentMid && n.dirty).length;
  row.innerHTML = `
    <div class="stat-pill">📚 ${total} notes tipe ini</div>
    <div class="stat-pill">✏️ ${dirty} sudah diedit</div>
    <div class="stat-pill">🗂️ ${Object.keys(state.models).length} note type di deck</div>
  `;
  document.getElementById('dirtyBadge').textContent = `${state.notes.filter(n=>n.dirty).length} diubah`;
  updateBatchUI();
}

/* ---------------- batch copy ---------------- */
function getBatchBounds(total){
  const size = Math.max(1, state.batchSize|0 || 1);
  const totalBatches = Math.max(1, Math.ceil(total / size));
  if(state.batchIndex < 0) state.batchIndex = 0;
  if(state.batchIndex > totalBatches-1) state.batchIndex = totalBatches-1;
  const start = state.batchIndex * size;
  const end = Math.min(total, start + size);
  return { size, totalBatches, start, end };
}

function getBatchRows(){
  const rows = currentRows();
  const { start, end } = getBatchBounds(rows.length);
  return rows.slice(start, end);
}

// Kunci unik buat satu "batch" berdasarkan gabungan ID kartunya (bukan cuma nomor index batch),
// biar tetep valid walau jumlah kartu per batch diubah-ubah. Dipakai buat nandain batch yang
// udah pernah di-apply, jadi kalau di-paste ulang bisa diingetin dulu sebelum ke-overwrite diam-diam.
function batchKeyFor(rows){
  return (rows||[]).map(n=> String(n.id)).sort((a,b)=> a.localeCompare(b, undefined, {numeric:true})).join(',');
}

function updateBatchUI(){
  const infoEl = document.getElementById('batchInfo');
  if(!infoEl) return;
  const rows = currentRows();
  const total = rows.length;
  const { totalBatches, start, end } = getBatchBounds(total);
  if(total === 0){
    infoEl.textContent = 'Belum ada kartu buat di-batch.';
  } else {
    const curBatchRows = getBatchRows();
    const isDone = state.doneBatches.has(batchKeyFor(curBatchRows));
    infoEl.innerHTML = `Batch <b>${state.batchIndex+1} / ${totalBatches}</b> — kartu ke <b>${start+1}–${end}</b> dari total <b>${total}</b>` +
      (isDone ? ` <span style="color:#3fae80;">✅ sudah di-apply</span>` : '');
  }
  const prevBtn = document.getElementById('btnBatchPrev');
  const nextBtn = document.getElementById('btnBatchNext');
  if(prevBtn) prevBtn.disabled = state.batchIndex <= 0;
  if(nextBtn) nextBtn.disabled = state.batchIndex >= totalBatches-1;
}

document.getElementById('batchSizeInput').addEventListener('input', (e)=>{
  let v = parseInt(e.target.value, 10);
  if(!Number.isFinite(v) || v < 1) v = 1;
  state.batchSize = v;
  state.batchIndex = 0; // balik ke batch pertama biar gak ketinggalan/kelewatan kartu
  updateBatchUI();
});
document.getElementById('btnBatchPrev').addEventListener('click', ()=>{
  state.batchIndex = Math.max(0, state.batchIndex - 1);
  updateBatchUI();
});
document.getElementById('btnBatchNext').addEventListener('click', ()=>{
  state.batchIndex += 1;
  updateBatchUI();
});
/* ---------------- translate otomatis (opsional, langsung manggil API translate) ---------------- */

const AH_AT_STORAGE_PREFIX = 'ankihoney_autotranslate_';
function ahAtLoadSetting(key, fallback){
  try{ const v = localStorage.getItem(AH_AT_STORAGE_PREFIX+key); return v === null ? fallback : v; }catch(e){ return fallback; }
}
function ahAtSaveSetting(key, val){
  try{ localStorage.setItem(AH_AT_STORAGE_PREFIX+key, val); }catch(e){}
}

const AT_HINT_INPLACE = '⚠️ Yang ditranslate cuma field yang <b>dicentang tapi BUKAN ditandain 🔒 sumber</b> (isinya bakal DITIMPA sama hasil terjemahan). API key (kalau diisi) cuma kesimpen lokal di browser kamu sendiri, dan teksnya dikirim LANGSUNG dari browser kamu ke server engine yang dipilih (bukan lewat server AnkiHoney) — jadi dobel-cek hasilnya sebelum disimpen, apalagi buat field yang banyak tag HTML/gambar/audio.';
const AT_HINT_MAPPED = '⚠️ Field <b>Sumber</b> DIBACA doang (gak diubah), hasil terjemahannya ditaruh/nimpa isi field <b>Tujuan</b> yang kamu pilih. API key (kalau diisi) cuma kesimpen lokal di browser kamu sendiri, dan teksnya dikirim LANGSUNG dari browser kamu ke server engine yang dipilih (bukan lewat server AnkiHoney) — jadi dobel-cek hasilnya sebelum disimpen.';
const AT_HINT_INPLACE_EXPLAIN = '⚠️ Field yang dicentang di atas bakal DITIMPA sama hasil penjelasan AI-nya sendiri (jarang kepake buat mode ini -- biasanya field sumbernya masih dibutuhin apa adanya). Lebih disaranin pakai mode "Field beda" di bawah. API key cuma kesimpen lokal di browser kamu sendiri.';
const AT_HINT_MAPPED_EXPLAIN = '⚠️ Field <b>Sumber</b> DIBACA doang buat bahan AI jelasin (gak diubah), hasil penjelasannya ditaruh/nimpa isi field <b>Tujuan</b> yang kamu pilih -- ini yang paling cocok, misal Sumber="Kosakata" &amp; Tujuan="Notes". API key cuma kesimpen lokal di browser kamu sendiri, dan teksnya dikirim LANGSUNG ke server engine yang dipilih (bukan lewat server AnkiHoney) — dobel-cek hasilnya sebelum disimpen.';

function ahAtCurrentHint(){
  const mapped = state.autoTranslate.mode === 'mapped';
  const explain = state.autoTranslate.op === 'explain';
  if(explain) return mapped ? AT_HINT_MAPPED_EXPLAIN : AT_HINT_INPLACE_EXPLAIN;
  return mapped ? AT_HINT_MAPPED : AT_HINT_INPLACE;
}

// Kosongin & sembunyiin tombol "Mulai Ulang yang Gagal" -- dipanggil tiap kali user
// ganti pengaturan (op/mode) yang bikin daftar kegagalan lama gak relevan lagi, atau
// pas mulai proses translate/jelasin BARU dari awal (bukan retry).
function ahAtClearFailedRetry(){
  state.autoTranslate.lastFailedEntries = [];
  const btn = document.getElementById('btnAutoTranslateRetryFailed');
  if(btn) btn.classList.add('hidden');
}
document.getElementById('btnAutoTranslateRetryFailed').addEventListener('click', ()=>{
  const entries = state.autoTranslate.lastFailedEntries || [];
  if(!entries.length){ toast('Gak ada yang gagal buat diulang~', '⚠️'); return; }
  runAutoTranslate(null, entries);
});

// Inget pilihan terakhir user (engine/API key/bahasa) -- CUMA kesimpen lokal di
// browser dia sendiri (localStorage), gak pernah dikirim ke server manapun selain
// pas beneran manggil API translate-nya langsung.
(function initAutoTranslatePanel(){
  const engineSel = document.getElementById('atEngineSelect');
  const apiKeyWrap = document.getElementById('atApiKeyWrap');
  const apiKeyInput = document.getElementById('atApiKey');
  const sourceInput = document.getElementById('atSourceLang');
  const targetInput = document.getElementById('atTargetLang');
  const explainArea = document.getElementById('atExplainInstrArea');

  engineSel.value = ahAtLoadSetting('engine', 'google-free');
  sourceInput.value = ahAtLoadSetting('source', 'auto');
  targetInput.value = ahAtLoadSetting('target', 'id');
  explainArea.value = ahAtLoadSetting('explainInstr', AH_DEFAULT_EXPLAIN_INSTRUCTION);

  function refreshApiKeyVisibility(){
    apiKeyWrap.classList.toggle('hidden', engineSel.value === 'google-free');
    apiKeyInput.value = ahAtLoadSetting('apikey_'+engineSel.value, '');
  }
  refreshApiKeyVisibility();

  engineSel.addEventListener('change', ()=>{ ahAtSaveSetting('engine', engineSel.value); refreshApiKeyVisibility(); });
  apiKeyInput.addEventListener('input', ()=> ahAtSaveSetting('apikey_'+engineSel.value, apiKeyInput.value));
  sourceInput.addEventListener('input', ()=> ahAtSaveSetting('source', sourceInput.value));
  targetInput.addEventListener('input', ()=> ahAtSaveSetting('target', targetInput.value));
  explainArea.addEventListener('input', ()=> ahAtSaveSetting('explainInstr', explainArea.value));

  document.getElementById('atExplainUseTemplate').addEventListener('click', ()=>{
    explainArea.value = AH_DEFAULT_EXPLAIN_INSTRUCTION;
    ahAtSaveSetting('explainInstr', explainArea.value);
    toast('Instruksi dibalikin ke template default~', '📋');
  });

  ahAtSetOp(ahAtLoadSetting('op', 'translate'));
})();

function ahAtSetMode(mode){
  state.autoTranslate.mode = mode;
  ahAtClearFailedRetry();
  document.getElementById('atModeInplace').classList.toggle('applied', mode === 'inplace');
  document.getElementById('atModeMapped').classList.toggle('applied', mode === 'mapped');
  document.getElementById('atMappedWrap').classList.toggle('hidden', mode !== 'mapped');
  document.getElementById('atModeHint').innerHTML = ahAtCurrentHint();
  if(mode === 'mapped' && !document.querySelectorAll('.at-mapping-row').length){
    ahAtAddMappingRow();
  }
}
document.getElementById('atModeInplace').addEventListener('click', ()=> ahAtSetMode('inplace'));
document.getElementById('atModeMapped').addEventListener('click', ()=> ahAtSetMode('mapped'));
document.getElementById('atAddMapping').addEventListener('click', ()=> ahAtAddMappingRow());

// Toggle antara mode "Terjemahin" (dispatcher lama, ahTranslateDispatch) dan "Jelasin
// Kosakata" (dispatcher baru, ahExplainDispatch pakai instruksi custom). Ganti-ganti label
// tombol/hint biar gak bikin bingung, dan matiin opsi engine yang gak support mode explain
// (Google Translate gratis/Cloud, karena itu API terjemahan literal bukan AI chat model).
function ahAtSetOp(op){
  state.autoTranslate.op = op;
  ahAtSaveSetting('op', op);
  ahAtClearFailedRetry();
  document.getElementById('atOpTranslate').classList.toggle('applied', op === 'translate');
  document.getElementById('atOpExplain').classList.toggle('applied', op === 'explain');
  document.getElementById('atExplainInstrWrap').classList.toggle('hidden', op !== 'explain');
  document.getElementById('atEngineExplainNote').classList.toggle('hidden', op !== 'explain');
  document.getElementById('atEngineLabel').textContent = op === 'explain' ? 'Engine AI' : 'Engine Translate';
  document.getElementById('atSourceLangLabel').textContent = op === 'explain' ? 'Bahasa Kosakata Sumber (opsional, buat konteks)' : 'Bahasa Sumber';
  document.getElementById('atTargetLangLabel').textContent = op === 'explain' ? 'Bahasa Penjelasan' : 'Bahasa Target';
  document.getElementById('atFieldSectionLabel').textContent = op === 'explain' ? 'Field yang Dijelasin' : 'Field yang Ditranslate';

  const engineSel = document.getElementById('atEngineSelect');
  const optGoogleFree = document.getElementById('atEngineOptGoogleFree');
  const optGoogleCloud = document.getElementById('atEngineOptGoogleCloud');
  const explainOnly = op === 'explain';
  optGoogleFree.disabled = explainOnly;
  optGoogleCloud.disabled = explainOnly;
  if(explainOnly && !AH_EXPLAIN_ENGINES.includes(engineSel.value)){
    engineSel.value = ahAtLoadSetting('lastExplainEngine', 'openai');
    engineSel.dispatchEvent(new Event('change'));
  }

  const runLabel = op === 'explain' ? '🧠 Jelasin Kosakata Semua Field yang Dicentang' : '🌐 Translate Semua Field yang Dicentang';
  const undoLabel = op === 'explain' ? '↩️ Undo Jelasin Kosakata Terakhir' : '↩️ Undo Translate Terakhir';
  const batchLabel = op === 'explain' ? '🧠 Jelasin Kosakata Batch Ini' : '🌐 Translate Batch Ini';
  document.getElementById('btnAutoTranslateLabel').textContent = runLabel;
  document.getElementById('btnAutoTranslateUndoLabel').textContent = undoLabel;
  const batchLabelEl = document.getElementById('btnAutoTranslateBatchLabel');
  if(batchLabelEl) batchLabelEl.textContent = batchLabel;

  document.getElementById('atModeHint').innerHTML = ahAtCurrentHint();
}
document.getElementById('atOpTranslate').addEventListener('click', ()=> ahAtSetOp('translate'));
document.getElementById('atOpExplain').addEventListener('click', ()=> ahAtSetOp('explain'));
document.getElementById('atEngineSelect').addEventListener('change', function(){
  if(state.autoTranslate.op === 'explain' && AH_EXPLAIN_ENGINES.includes(this.value)){
    ahAtSaveSetting('lastExplainEngine', this.value);
  }
});

// Bikin 1 baris pasangan "ambil dari field X -> taruh ke field Y" buat mode
// translate "Field beda". Dipakai pas user nambah pasangan baru, atau pas note
// type diganti (dropdown-nya di-refresh biar sesuai daftar field yang baru).
function ahAtBuildFieldSelect(model, preferIdx){
  const sel = document.createElement('select');
  (model.flds||[]).forEach((name, idx)=>{
    const opt = document.createElement('option');
    opt.value = idx;
    opt.textContent = `${idx+1}. ${name}`;
    sel.appendChild(opt);
  });
  if(preferIdx !== undefined && preferIdx !== null && preferIdx < (model.flds||[]).length) sel.value = preferIdx;
  return sel;
}
function ahAtAddMappingRow(srcIdx, dstIdx){
  const model = state.models[state.currentMid];
  if(!model || !model.flds || model.flds.length < 2){
    toast('Note type ini cuma punya 1 field, jadi gak bisa translate ke field beda~', '⚠️');
    return;
  }
  const list = document.getElementById('atMappedList');
  const row = document.createElement('div');
  row.className = 'grid2 at-mapping-row';
  row.style.cssText = 'align-items:end; margin-bottom:8px;';

  const srcWrap = document.createElement('div');
  srcWrap.innerHTML = '<label class="field-label">Ambil dari (Sumber)</label>';
  const srcSel = ahAtBuildFieldSelect(model, srcIdx ?? 0);
  srcSel.className = 'atMapSrc';
  srcWrap.appendChild(srcSel);

  const dstWrap = document.createElement('div');
  dstWrap.style.cssText = 'display:flex; gap:8px; align-items:end;';
  const dstInner = document.createElement('div');
  dstInner.style.flex = '1';
  dstInner.innerHTML = '<label class="field-label">Taruh ke (Tujuan)</label>';
  const dstSel = ahAtBuildFieldSelect(model, dstIdx ?? Math.min(1, model.flds.length-1));
  dstSel.className = 'atMapDst';
  dstInner.appendChild(dstSel);
  const removeBtn = document.createElement('button');
  removeBtn.type = 'button';
  removeBtn.className = 'btn ghost';
  removeBtn.style.padding = '10px 14px';
  removeBtn.textContent = '🗑️';
  removeBtn.addEventListener('click', ()=>{
    row.remove();
    if(!document.querySelectorAll('.at-mapping-row').length) ahAtAddMappingRow();
  });
  dstWrap.appendChild(dstInner);
  dstWrap.appendChild(removeBtn);

  row.appendChild(srcWrap);
  row.appendChild(dstWrap);
  list.appendChild(row);
}
// Refresh dropdown mapping tiap ganti note type -- field lama udah gak relevan
// buat note type baru, jadi list mapping-nya direset.
function ahAtRefreshMappingsForModel(){
  const list = document.getElementById('atMappedList');
  if(!list) return;
  list.innerHTML = '';
  if(state.autoTranslate.mode === 'mapped') ahAtAddMappingRow();
  ahAtRefreshExplainContextField();
}

// Field opsional buat "Jelasin Kosakata (AI)" -- isinya DIBACA doang dan dikirim ke AI
// sebagai KONTEKS TAMBAHAN (misal kalimat lengkap "SentKanji" pas field Sumber-nya cuma
// kosakata tunggal "VocabKanji"), biar penjelasannya nyambung sama pemakaian aslinya di
// kalimat, bukan cuma makna umum kamus. Dropdown-nya di-refresh tiap ganti note type,
// dan coba dipertahanin (by NAMA field, bukan index) kalau field yang sama masih ada.
function ahAtRefreshExplainContextField(){
  const sel = document.getElementById('atExplainContextField');
  if(!sel) return;
  const model = state.models[state.currentMid];
  const prevName = sel.value !== '' && sel.selectedIndex > 0 ? sel.options[sel.selectedIndex].textContent.replace(/^\d+\.\s/, '') : ahAtLoadSetting('explainContextFieldName', '');
  sel.innerHTML = '';
  const emptyOpt = document.createElement('option');
  emptyOpt.value = '';
  emptyOpt.textContent = '(Gak pakai field konteks tambahan)';
  sel.appendChild(emptyOpt);
  (model && model.flds || []).forEach((name, idx)=>{
    const opt = document.createElement('option');
    opt.value = idx;
    opt.textContent = `${idx+1}. ${name}`;
    sel.appendChild(opt);
  });
  if(prevName){
    const match = [...sel.options].find(o=> o.value !== '' && (model.flds[+o.value] === prevName));
    if(match) sel.value = match.value;
  }
}
document.getElementById('atExplainContextField')?.addEventListener('change', function(){
  const model = state.models[state.currentMid];
  const name = (this.value !== '' && model) ? (model.flds[+this.value] || '') : '';
  ahAtSaveSetting('explainContextFieldName', name);
});

function ahSleep(ms){ return new Promise(r=> setTimeout(r, ms)); }

// Helper bareng buat semua engine AI (OpenAI/Claude/Gemini/DeepSeek): provider-provider ini
// SERING banget ganti/hapus nama model (kejadian beberapa kali cuma dalam beberapa bulan),
// jadi kalau request gagal, kita coba tebak apa penyebabnya "model ini udah gak didukung lagi"
// (HTTP 404, atau pesan error nyebut kata "model" bareng "not found/deprecated/decommissioned/dst")
// biar user dikasih tau JELAS kalau ini bukan salah mereka -- tool ini yang butuh diupdate,
// bukan cuma error generik yang bikin bingung.
function ahMakeEngineError(provider, status, bodyText){
  const snippet = (bodyText||'').slice(0,200);
  const lower = (bodyText||'').toLowerCase();
  const modelIssue = status === 404
    || /model[a-z_"'\s]{0,20}(not[ _]?found|does not exist|deprecat|decommission|discontinu|no longer|unsupported|unrecognized|invalid|unknown)/i.test(lower)
    || /(deprecat|decommission|discontinu|retired)[a-z_"'\s]{0,20}model/i.test(lower);
  const err = new Error(provider+' error: HTTP '+status+' '+snippet);
  err.modelIssue = modelIssue;
  err.provider = provider;
  return err;
}

// Engine #1: endpoint Google Translate versi gratis/gak resmi (trik yang sama dipakai
// banyak tool client-side lain) -- gak butuh API key sama sekali, tapi sifatnya
// BEST-EFFORT: bisa aja kena rate-limit atau diblokir sewaktu-waktu sama Google
// karena ini bukan endpoint publik resmi. Kalau gagal terus, disaranin pindah ke
// engine yang pakai API key.
async function ahTranslateGoogleFree(text, sl, tl){
  if(!text || !text.trim()) return text;
  const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${encodeURIComponent(sl||'auto')}&tl=${encodeURIComponent(tl||'id')}&dt=t&q=${encodeURIComponent(text)}`;
  const res = await fetch(url);
  if(!res.ok) throw new Error('Google Translate (gratis) error: HTTP '+res.status);
  const data = await res.json();
  return ((data && data[0]) || []).map(seg=> (seg && seg[0]) || '').join('');
}

// Engine #2: Google Cloud Translate API resmi (v2), butuh API key sendiri dari Google
// Cloud Console. format:'html' dipakai biar tag HTML di field Anki (bold, ruby
// furigana, dst) gak ikut kena terjemahin/rusak -- cuma teks di dalamnya aja.
async function ahTranslateGoogleCloud(text, sl, tl, apiKey){
  if(!text || !text.trim()) return text;
  const body = { q:text, target: tl||'id', format:'html' };
  if(sl && sl !== 'auto') body.source = sl;
  const res = await fetch('https://translation.googleapis.com/language/translate/v2?key='+encodeURIComponent(apiKey), {
    method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('Google Cloud Translate', res.status, t); }
  const data = await res.json();
  return data?.data?.translations?.[0]?.translatedText ?? text;
}

// Engine #3: OpenAI API (butuh API key sendiri) -- paling aman dipakai buat field yang
// isinya banyak tag HTML/furigana/[sound:...], karena model-nya diinstruksiin eksplisit
// buat mempertahankan semua tag persis apa adanya & cuma nerjemahin teks yang kebaca doang.
async function ahTranslateOpenAI(text, sl, tl, apiKey){
  if(!text || !text.trim()) return text;
  const sys = 'Kamu mesin translate profesional. Terjemahin teks yang dikasih ke bahasa target. ATURAN: (1) PERTAHANKAN semua tag HTML/atribut serta tag [sound:...] PERSIS apa adanya, cuma terjemahin teks yang kebaca manusia. (2) Jangan nambahin penjelasan/catatan apapun. (3) Balikin CUMA hasil terjemahannya, tanpa embel-embel lain.';
  const srcNote = (sl && sl !== 'auto') ? (' (bahasa asal kira-kira: '+sl+')') : '';
  const user = 'Terjemahin teks berikut'+srcNote+' ke bahasa "'+(tl||'id')+'":\n\n'+text;
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method:'POST',
    headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+apiKey },
    body: JSON.stringify({ model:'gpt-5-mini', temperature:0.2, messages:[{role:'system',content:sys},{role:'user',content:user}] })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('OpenAI', res.status, t); }
  const data = await res.json();
  return data?.choices?.[0]?.message?.content?.trim() || text;
}

const AH_AI_TRANSLATE_SYS = 'Kamu mesin translate profesional. Terjemahin teks yang dikasih ke bahasa target. ATURAN: (1) PERTAHANKAN semua tag HTML/atribut serta tag [sound:...] PERSIS apa adanya, cuma terjemahin teks yang kebaca manusia. (2) Jangan nambahin penjelasan/catatan apapun. (3) Balikin CUMA hasil terjemahannya, tanpa embel-embel lain.';

// Engine #4: Anthropic Claude API (butuh API key sendiri dari console.anthropic.com).
// Header 'anthropic-dangerous-direct-browser-access' dibutuhin karena API-nya dipanggil
// LANGSUNG dari browser (bukan lewat server), sama kayak engine lain di tool ini.
async function ahTranslateClaude(text, sl, tl, apiKey){
  if(!text || !text.trim()) return text;
  const srcNote = (sl && sl !== 'auto') ? (' (bahasa asal kira-kira: '+sl+')') : '';
  const user = 'Terjemahin teks berikut'+srcNote+' ke bahasa "'+(tl||'id')+'":\n\n'+text;
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method:'POST',
    headers:{
      'Content-Type':'application/json',
      'x-api-key': apiKey,
      'anthropic-version':'2023-06-01',
      'anthropic-dangerous-direct-browser-access':'true'
    },
    body: JSON.stringify({ model:'claude-haiku-4-5-20251001', max_tokens:4096, temperature:0.2, system:AH_AI_TRANSLATE_SYS, messages:[{role:'user',content:user}] })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('Claude', res.status, t); }
  const data = await res.json();
  return (data?.content||[]).map(b=> b.text || '').join('').trim() || text;
}

// Engine #5: Google Gemini API (butuh API key sendiri dari Google AI Studio).
async function ahTranslateGemini(text, sl, tl, apiKey){
  if(!text || !text.trim()) return text;
  const srcNote = (sl && sl !== 'auto') ? (' (bahasa asal kira-kira: '+sl+')') : '';
  const user = 'Terjemahin teks berikut'+srcNote+' ke bahasa "'+(tl||'id')+'":\n\n'+text;
  const res = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key='+encodeURIComponent(apiKey), {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ systemInstruction:{ parts:[{text:AH_AI_TRANSLATE_SYS}] }, contents:[{role:'user', parts:[{text:user}]}], generationConfig:{ temperature:0.2 } })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('Gemini', res.status, t); }
  const data = await res.json();
  return (data?.candidates?.[0]?.content?.parts||[]).map(p=> p.text || '').join('').trim() || text;
}

// Engine #6: DeepSeek API (kompatibel format OpenAI, butuh API key sendiri dari platform.deepseek.com).
async function ahTranslateDeepSeek(text, sl, tl, apiKey){
  if(!text || !text.trim()) return text;
  const srcNote = (sl && sl !== 'auto') ? (' (bahasa asal kira-kira: '+sl+')') : '';
  const user = 'Terjemahin teks berikut'+srcNote+' ke bahasa "'+(tl||'id')+'":\n\n'+text;
  const res = await fetch('https://api.deepseek.com/chat/completions', {
    method:'POST',
    headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+apiKey },
    body: JSON.stringify({ model:'deepseek-v4-flash', temperature:0.2, messages:[{role:'system',content:AH_AI_TRANSLATE_SYS},{role:'user',content:user}] })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('DeepSeek', res.status, t); }
  const data = await res.json();
  return data?.choices?.[0]?.message?.content?.trim() || text;
}

async function ahTranslateDispatch(engine, text, sl, tl, apiKey){
  if(engine === 'google-cloud') return ahTranslateGoogleCloud(text, sl, tl, apiKey);
  if(engine === 'openai') return ahTranslateOpenAI(text, sl, tl, apiKey);
  if(engine === 'claude') return ahTranslateClaude(text, sl, tl, apiKey);
  if(engine === 'gemini') return ahTranslateGemini(text, sl, tl, apiKey);
  if(engine === 'deepseek') return ahTranslateDeepSeek(text, sl, tl, apiKey);
  return ahTranslateGoogleFree(text, sl, tl);
}

/* ---------------- mode "Jelasin Kosakata (AI)" ----------------
   Sama kayak engine translate di atas, tapi system prompt-nya DIGANTI pakai instruksi
   custom dari user (default-nya sama kayak template Notes) alih-alih instruksi "translate
   apa adanya". Cuma didukung sama engine yang beneran AI chat model (OpenAI/Claude/Gemini/
   DeepSeek) -- Google Translate (gratis/Cloud) itu API terjemahan literal, gak bisa disuruh
   "jelasin kosakata" karena bukan model bahasa, jadi sengaja gak disediain di sini. */
function ahBuildExplainPrompt(text, instruction, lang, contextText){
  const langNote = lang ? `\n\nJawab pakai bahasa "${lang}".` : '';
  const contextNote = (contextText && contextText.trim())
    ? `\n\nKonteks tambahan (kalimat/konteks pemakaian aslinya -- DIBACA doang buat bantu mahamin, JANGAN dijelasin/diterjemahin sendiri, cuma dipake buat mastiin penjelasan kosakata di atas nyambung sama konteks ini):\n\n${contextText.trim()}`
    : '';
  return `${instruction}${langNote}\n\nBerikut teks/kosakata yang mau dijelasin:\n\n${text}${contextNote}`;
}

/* ---------------- Post-processing hasil "Jelasin Kosakata (AI)" ----------------
   PENTING (revisi ke-2): field ini biasanya kepake bareng filter furigana bawaan note
   type (atau addon sejenis) yang kerjanya nge-scan teks field buat pola "kanji[bacaan]"
   -- dan filter kayak gitu pada dasarnya nge-anggep field-nya PLAIN TEXT, jadi kalau field-nya
   udah keisi tag HTML asli (<b>, <ul>, <ruby>, dst -- percobaan sebelumnya), tag-nya malah
   ke-escape/keliatan literal kayak "<b>" pas dirender (persis laporan user). Makanya SEKARANG
   hasil AI-nya CUMA dibersihin dari tanda markdown-nya doang (jadi plain text biasa), TANPA
   nambahin tag HTML apapun -- paragraf/section udah otomatis kepisah sendiri sama baris kosong
   dari jawaban AI-nya (gak perlu <br>/<p>). Format furigana "kanji[bacaan]" DIBIARIN PERSIS
   apa adanya, gak disentuh sama sekali -- itu emang formatnya yang diminta di instruksi
   default Notes, biar filter furigana note type (atau tampilan manual sesuai instruksi) yang
   urus renderingnya sendiri. */
function ahFormatExplainResult(text){
  if(!text) return text;
  let out = text.replace(/\r\n?/g, '\n');
  out = out.replace(/\*\*(.+?)\*\*/g, '$1');            // **bold** -> teks polos (tanda bintangnya doang yang ilang)
  out = out.replace(/^([ \t]*)[*\-][ \t]+/gm, '$1• ');  // baris bullet "*"/"-" -> "•" (bukan tag <li>)
  out = out.replace(/\*([^*\n]+)\*/g, '$1');            // sisa *italic* tunggal -> teks polos juga
  return out.trim();
}

async function ahExplainOpenAI(text, instruction, lang, apiKey, contextText){
  if(!text || !text.trim()) return text;
  const sys = 'Kamu asisten yang jelasin kosakata/kalimat sesuai instruksi dari user. Balikin CUMA hasil penjelasannya dalam PLAIN TEXT (boleh pakai ** buat bold & "-" buat bullet point kalau perlu struktur) -- JANGAN PAKAI TAG HTML SAMA SEKALI (kayak <b>, <ul>, <li>, <br>, <ruby>, dst), soalnya field ini bakal diproses filter furigana bawaan note type yang nge-anggep isinya plain text, jadi tag HTML apapun bakal keliatan literal/rusak. Pisahin tiap bagian/kalimat pakai BARIS KOSONG (paragraf) aja, JANGAN pakai tag apapun buat itu. Format furigana "kanji[bacaan]" (kalau instruksinya minta) WAJIB ditulis PERSIS sesuai instruksi, jangan diubah/dihapus/diringkas. Jangan pakai embel-embel pembuka/penutup kayak "Berikut penjelasannya:".';
  const user = ahBuildExplainPrompt(text, instruction, lang, contextText);
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method:'POST',
    headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+apiKey },
    body: JSON.stringify({ model:'gpt-5-mini', temperature:0.4, messages:[{role:'system',content:sys},{role:'user',content:user}] })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('OpenAI', res.status, t); }
  const data = await res.json();
  return data?.choices?.[0]?.message?.content?.trim() || text;
}

const AH_AI_EXPLAIN_SYS = 'Kamu asisten yang jelasin kosakata/kalimat sesuai instruksi dari user. Balikin CUMA hasil penjelasannya dalam PLAIN TEXT (boleh pakai ** buat bold & "-" buat bullet point kalau perlu struktur) -- JANGAN PAKAI TAG HTML SAMA SEKALI (kayak <b>, <ul>, <li>, <br>, <ruby>, dst), soalnya field ini bakal diproses filter furigana bawaan note type yang nge-anggep isinya plain text, jadi tag HTML apapun bakal keliatan literal/rusak. Pisahin tiap bagian/kalimat pakai BARIS KOSONG (paragraf) aja, JANGAN pakai tag apapun buat itu. Format furigana "kanji[bacaan]" (kalau instruksinya minta) WAJIB ditulis PERSIS sesuai instruksi, jangan diubah/dihapus/diringkas. Jangan pakai embel-embel pembuka/penutup kayak "Berikut penjelasannya:".';

async function ahExplainClaude(text, instruction, lang, apiKey, contextText){
  if(!text || !text.trim()) return text;
  const user = ahBuildExplainPrompt(text, instruction, lang, contextText);
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method:'POST',
    headers:{
      'Content-Type':'application/json',
      'x-api-key': apiKey,
      'anthropic-version':'2023-06-01',
      'anthropic-dangerous-direct-browser-access':'true'
    },
    body: JSON.stringify({ model:'claude-haiku-4-5-20251001', max_tokens:4096, temperature:0.4, system:AH_AI_EXPLAIN_SYS, messages:[{role:'user',content:user}] })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('Claude', res.status, t); }
  const data = await res.json();
  return (data?.content||[]).map(b=> b.text || '').join('').trim() || text;
}

async function ahExplainGemini(text, instruction, lang, apiKey, contextText){
  if(!text || !text.trim()) return text;
  const user = ahBuildExplainPrompt(text, instruction, lang, contextText);
  const res = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key='+encodeURIComponent(apiKey), {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ systemInstruction:{ parts:[{text:AH_AI_EXPLAIN_SYS}] }, contents:[{role:'user', parts:[{text:user}]}], generationConfig:{ temperature:0.4 } })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('Gemini', res.status, t); }
  const data = await res.json();
  return (data?.candidates?.[0]?.content?.parts||[]).map(p=> p.text || '').join('').trim() || text;
}

async function ahExplainDeepSeek(text, instruction, lang, apiKey, contextText){
  if(!text || !text.trim()) return text;
  const user = ahBuildExplainPrompt(text, instruction, lang, contextText);
  const res = await fetch('https://api.deepseek.com/chat/completions', {
    method:'POST',
    headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+apiKey },
    body: JSON.stringify({ model:'deepseek-v4-flash', temperature:0.4, messages:[{role:'system',content:AH_AI_EXPLAIN_SYS},{role:'user',content:user}] })
  });
  if(!res.ok){ const t = await res.text().catch(()=>''); throw ahMakeEngineError('DeepSeek', res.status, t); }
  const data = await res.json();
  return data?.choices?.[0]?.message?.content?.trim() || text;
}

async function ahExplainDispatch(engine, text, instruction, lang, apiKey, contextText){
  if(engine === 'openai') return ahExplainOpenAI(text, instruction, lang, apiKey, contextText);
  if(engine === 'claude') return ahExplainClaude(text, instruction, lang, apiKey, contextText);
  if(engine === 'gemini') return ahExplainGemini(text, instruction, lang, apiKey, contextText);
  if(engine === 'deepseek') return ahExplainDeepSeek(text, instruction, lang, apiKey, contextText);
  throw new Error('Engine "'+engine+'" gak support mode Jelasin Kosakata -- pilih OpenAI/Claude/Gemini/DeepSeek ya~');
}

// Translate SEMUA field yang dicentang (minus yang ditandain 🔒 sumber) buat SEMUA
// note dari note type yang lagi aktif, sekali klik. Jalan sekuensial (bukan paralel)
// biar gak ngebejek endpoint/rate-limit, dan bisa dibatalin di tengah jalan.
// Dukung 2 mode: 'inplace' (timpa isi field yang sama) dan 'mapped' (baca dari
// field A, tulis hasilnya ke field B yang beda -- A gak ikut berubah).
async function runAutoTranslate(rowsOverride, retryEntries){
  const model = state.models[state.currentMid];
  if(!model) return;
  const isRetry = !!(retryEntries && retryEntries.length);
  let rows = rowsOverride && rowsOverride.length ? rowsOverride : currentRows();
  if(isRetry){
    // Retry cuma peduli sama note yang tadi ada field-nya yang gagal -- ambil dari
    // state.notes langsung (bukan cuma currentRows()) biar tetep ketemu walau user
    // udah pindah batch/scroll dari posisi pas run pertama gagal.
    const idSet = new Set(retryEntries.map(e=> e.id));
    rows = state.notes.filter(n=> n.mid === state.currentMid && idSet.has(n.id));
  }
  if(!rows.length){ toast('Gak ada note buat ditranslate~', '⚠️'); return; }
  const isBatchScoped = !!(rowsOverride && rowsOverride.length) && !isRetry;

  const mode = state.autoTranslate.mode;
  let pairs = []; // array of {src, dst} field index -- buat 'inplace', src===dst

  if(mode === 'mapped'){
    document.querySelectorAll('.at-mapping-row').forEach(row=>{
      const src = parseInt(row.querySelector('.atMapSrc').value);
      const dst = parseInt(row.querySelector('.atMapDst').value);
      if(!Number.isNaN(src) && !Number.isNaN(dst)) pairs.push({ src, dst });
    });
    const badPair = pairs.find(p=> p.src === p.dst);
    if(badPair){ toast('Field Sumber & Tujuan gak boleh sama di mode "Field beda" ya~', '⚠️'); return; }
    if(!pairs.length){ toast('Tambahin minimal 1 pasangan field dulu~', '⚠️'); return; }
  } else {
    const targetIdxs = (state.selectedFieldIdxs||[]).filter(i=> !(state.referenceFieldIdxs||[]).includes(i));
    if(!targetIdxs.length){ toast('Semua field yang dicentang ditandain 🔒 sumber -- gak ada field target buat ditranslate~', '⚠️'); return; }
    pairs = targetIdxs.map(i=> ({ src:i, dst:i }));
  }

  const op = state.autoTranslate.op;
  const engine = document.getElementById('atEngineSelect').value;
  const targetLang = document.getElementById('atTargetLang').value.trim() || 'id';
  const sourceLang = document.getElementById('atSourceLang').value.trim() || 'auto';
  const apiKey = document.getElementById('atApiKey').value.trim();
  const explainInstruction = document.getElementById('atExplainInstrArea').value.trim();
  // Field opsional "Konteks Tambahan" -- CUMA relevan buat mode 'explain', dibaca doang
  // per-note dan dikirim ke AI sebagai konteks pemakaian (lihat ahBuildExplainPrompt).
  const explainContextSel = document.getElementById('atExplainContextField');
  const explainContextIdx = (op === 'explain' && explainContextSel && explainContextSel.value !== '') ? parseInt(explainContextSel.value) : -1;

  if(op === 'explain' && !AH_EXPLAIN_ENGINES.includes(engine)){
    toast('Mode "Jelasin Kosakata" cuma support engine OpenAI/Claude/Gemini/DeepSeek~', '⚠️');
    return;
  }
  if(op === 'explain' && !explainInstruction){
    toast('Isi dulu instruksi buat AI-nya (atau pencet "Reset ke template default")~', '⚠️');
    return;
  }
  if(engine !== 'google-free' && !apiKey){ toast('Isi API key dulu ya buat pakai engine ini~', '🔑'); return; }

  // Kunci unik per (note, src, dst) -- dipakai buat mode retry, biar CUMA pasangan
  // field yang gagal tadi doang yang diulang (bukan semua field di note itu, biar
  // gak mubazir manggil API buat field yang udah berhasil).
  const retryKeySet = isRetry ? new Set(retryEntries.map(e=> e.id+'#'+e.src+'#'+e.dst)) : null;

  // Retry: gak perlu nanya konfirmasi timpa lagi (field yang diulang emang niatnya
  // ditimpa sama hasil yang baru, itu emang tujuan "ulang yang gagal"-nya).
  if(!isRetry){
    // Cek dulu: ada berapa note yang field TUJUAN-nya udah ada isi -- karena hasilnya
    // bakal NIMPA TOTAL isi lama (bukan digabung/append jadi dua). Kalau ada yang bakal
    // ketimpa, user harus konfirmasi dulu sebelum lanjut.
    const dstIdxsForCheck = [...new Set(pairs.map(p=> p.dst))];
    const willOverwriteCount = rows.filter(n=> dstIdxsForCheck.some(i=> (n.fields[i]||'').trim() !== '')).length;
    if(willOverwriteCount > 0){
      const dstNames = dstIdxsForCheck.map(i=> `"${model.flds[i] || ('Field '+(i+1))}"`).join(', ');
      const resultLabel = op === 'explain' ? 'hasil penjelasan AI' : 'hasil terjemahan';
      const undoLabel = op === 'explain' ? 'Undo Jelasin Kosakata Terakhir' : 'Undo Translate Terakhir';
      const lanjut = confirm(
        `${willOverwriteCount} dari ${rows.length} note udah ada isi di field tujuan (${dstNames}).\n\n`+
        `Isi lamanya bakal DITIMPA TOTAL sama ${resultLabel} (bukan digabung jadi 2).\n\n`+
        `Yakin mau lanjut? (Tenang, ada tombol "${undoLabel}" kalau berubah pikiran)`
      );
      if(!lanjut) return;
    }
  }

  // Snapshot SEMUA note note type ini SEBELUM mulai nimpa -- biar bisa di-undo utuh
  // kalau ternyata hasilnya berantakan / salah pilih field tujuan.
  state.autoTranslateSnapshot = {
    mid: state.currentMid,
    entries: rows.map(n=> ({ id: n.id, fields: n.fields.slice(), dirty: n.dirty }))
  };
  document.getElementById('btnAutoTranslateUndo').disabled = true;

  const btn = document.getElementById('btnAutoTranslate');
  const cancelBtn = document.getElementById('btnAutoTranslateCancel');
  const progEl = document.getElementById('atProgress');
  const progTrackWrap = document.getElementById('atProgressTrackWrap');
  const progFill = progTrackWrap.querySelector('.at-progress-fill');
  state.autoTranslate.cancel = false;
  btn.disabled = true;
  cancelBtn.classList.remove('hidden');
  progTrackWrap.classList.remove('hidden');
  progFill.classList.remove('done');
  progFill.style.width = '0%';
  // Sembunyiin tombol "Mulai Ulang yang Gagal" selama proses baru jalan -- baru
  // dimunculin lagi di akhir kalau emang masih ada yang gagal (lihat bawah).
  document.getElementById('btnAutoTranslateRetryFailed').classList.add('hidden');

  // totalOps: normal = semua kombinasi note x pasangan field. Retry = CUMA kombinasi
  // yang beneran ada di daftar kegagalan tadi (biar progress bar-nya akurat, gak
  // ngitung field yang emang gak diulang).
  let totalOps = 0;
  if(isRetry){
    rows.forEach(note=> pairs.forEach(p=>{ if(retryKeySet.has(note.id+'#'+p.src+'#'+p.dst)) totalOps++; }));
  } else {
    totalOps = rows.length * pairs.length;
  }
  let done = 0, failed = 0, noteIdx = 0;
  // Nangkep KEJADIAN PERTAMA doang dari error yang kecium "model AI-nya udah usang/
  // dihapus provider" (lihat ahMakeEngineError) -- dipopup-in sekali di akhir proses,
  // bukan tiap field gagal, biar gak spam modal berkali-kali padahal penyebabnya sama.
  let modelIssueInfo = null;
  // Detail tiap field yang gagal di proses INI (id note, field src/dst, pesan error)
  // -- dipake buat isi popup "Ada bagian yang gagal" & tombol "Mulai Ulang yang Gagal".
  const newFailedEntries = [];
  const opVerbing = op === 'explain' ? 'jelasin' : 'translate';
  const opEmojiRun = op === 'explain' ? '🧠' : '🌐';
  const loaderHtml = '<span class="loader"><span></span><span></span><span></span></span>';

  outer:
  for(const note of rows){
    noteIdx++;
    for(const { src, dst } of pairs){
      if(state.autoTranslate.cancel) break outer;
      if(isRetry && !retryKeySet.has(note.id+'#'+src+'#'+dst)) continue; // bukan yang gagal tadi, skip -- jangan dipanggil ulang
      const original = note.fields[src] || '';
      if(original.trim()){
        // Tampilin animasi loading SEBELUM manggil API, biar keliatan jelas AI-nya lagi
        // beneran kerja di kartu ke berapa (bukan cuma diem nunggu tanpa progress).
        progEl.innerHTML = `<span style="display:inline-flex; align-items:center; gap:7px;">${loaderHtml} ${opEmojiRun} Lagi ${opVerbing} kartu ${noteIdx}/${rows.length}...</span>`;
        try{
          const contextText = (op === 'explain' && explainContextIdx >= 0) ? (note.fields[explainContextIdx] || '') : '';
          const rawResult = (op === 'explain')
            ? await ahExplainDispatch(engine, original, explainInstruction, targetLang, apiKey, contextText)
            : await ahTranslateDispatch(engine, original, sourceLang, targetLang, apiKey);
          // Rapihin hasil AI khusus mode "Jelasin Kosakata": bersihin markdown-nya jadi
          // plain text (furigana "kanji[bacaan]" dibiarin persis, gak diapa-apain).
          const result = (op === 'explain' && rawResult) ? ahFormatExplainResult(rawResult) : rawResult;
          if(result && note.fields[dst] !== result){
            note.fields[dst] = result;
            note.dirty = true;
          }
        }catch(e){
          failed++;
          const errMsg = (e && e.message) || String(e);
          newFailedEntries.push({ id: note.id, src, dst, err: errMsg });
          console.warn((op === 'explain' ? 'Auto-explain' : 'Auto-translate')+' gagal buat note '+note.id+' field '+src+'->'+dst, e);
          if(!modelIssueInfo && e && e.modelIssue){
            modelIssueInfo = { provider: e.provider || engine, message: e.message || String(e) };
          }
        }
      }
      done++;
      progFill.style.width = Math.round((done/totalOps)*100) + '%';
      progEl.innerHTML = `<span style="display:inline-flex; align-items:center; gap:7px;">${loaderHtml} Kartu ${noteIdx}/${rows.length} — Progress: ${done}/${totalOps}` + (failed ? ` (${failed} gagal)` : '') + `</span>`;
      if(engine === 'google-free') await ahSleep(200); // jaga-jaga rate limit di endpoint gratisan
    }
  }
  progTrackWrap.classList.add('hidden');
  progFill.classList.add('done');
  progEl.innerHTML = state.autoTranslate.cancel
    ? `⏹️ Dibatalin — ${done}/${totalOps} field udah sempet diproses` + (failed ? ` (${failed} gagal)` : '')
    : `✅ Selesai — ${done}/${totalOps} field diproses` + (failed ? ` (${failed} gagal)` : '');

  // Mode 'mapped': pastiin field Tujuan ikut kecentang biar hasilnya langsung
  // keliatan & bisa dicek di tabel Preview & Edit tanpa perlu centang manual.
  if(mode === 'mapped'){
    const dstIdxs = [...new Set(pairs.map(p=> p.dst))];
    const merged = new Set(state.selectedFieldIdxs || []);
    dstIdxs.forEach(i=> merged.add(i));
    state.selectedFieldIdxs = [...merged].sort((a,b)=>a-b);
    document.querySelectorAll('#fieldChecks .field-chip input[type=checkbox]').forEach((cb,idx)=>{
      if(dstIdxs.includes(idx)){ cb.checked = true; cb.closest('.field-chip').classList.add('active'); }
    });
  }

  renderTable();
  updateStats();
  btn.disabled = false;
  cancelBtn.classList.add('hidden');
  document.getElementById('btnAutoTranslateUndo').disabled = (done === 0);

  if(isBatchScoped){
    state.doneBatches.add(batchKeyFor(rows));
    updateBatchUI();
  }

  // Simpen daftar kegagalan proses INI (nge-timpa daftar lama) -- kalau masih ada
  // yang gagal, munculin lagi tombol "Mulai Ulang yang Gagal" biar user bisa langsung
  // nyoba ulang CUMA buat yang gagal doang tanpa nembak ulang semua kartu.
  state.autoTranslate.lastFailedEntries = newFailedEntries;
  const retryBtnRow = document.getElementById('btnAutoTranslateRetryFailed');
  const retryBtnRowLabel = document.getElementById('btnAutoTranslateRetryFailedLabel');
  if(newFailedEntries.length){
    const verbUlang = op === 'explain' ? 'Jelasin' : 'Translate';
    retryBtnRowLabel.textContent = `Mulai ${verbUlang} Ulang yang Gagal (${newFailedEntries.length})`;
    retryBtnRow.classList.remove('hidden');
  } else {
    retryBtnRow.classList.add('hidden');
  }

  const batchLabel = isBatchScoped ? `Batch ${state.batchIndex+1}: ` : (isRetry ? 'Ulang yang gagal: ' : '');
  const verbDone = op === 'explain' ? 'dijelasin' : 'ditranslate';
  const verbNoun = op === 'explain' ? 'Jelasin Kosakata' : 'Translate';
  const opEmoji = op === 'explain' ? '🧠' : '🌐';
  if(state.autoTranslate.cancel){
    toast(`${batchLabel}${verbNoun} dibatalin di tengah jalan. ${done}/${totalOps} field udah sempet diproses~`, '⏹️');
  } else if(modelIssueInfo){
    // Kasus spesial: kegagalannya kedeteksi gara-gara nama model AI-nya udah usang/
    // dihapus provider, bukan error acak biasa -- kasih tau JELAS lewat popup + toast
    // singkat, biar user gak salah kira ini salah API key/koneksi mereka.
    toast(`${batchLabel}${failed} field gagal, kayaknya model AI-nya udah usang 🤖`, '⚠️');
    ahShowModelIssuePopup(modelIssueInfo.provider, modelIssueInfo.message);
  } else if(failed){
    toast(`${batchLabel}${verbNoun} selesai, tapi ${failed} field gagal 😿`, '⚠️');
    ahShowFailedRetryPopup(op, newFailedEntries, ()=> runAutoTranslate(null, state.autoTranslate.lastFailedEntries));
  } else {
    toast(`${batchLabel}${done} field berhasil ${verbDone}! Cek dulu di tabel sebelum disimpen ya~`, opEmoji);
  }
}

document.getElementById('btnAutoTranslateUndo').addEventListener('click', ()=>{
  const snap = state.autoTranslateSnapshot;
  if(!snap){ toast('Gak ada translate otomatis yang bisa di-undo~', '⚠️'); return; }
  const byId = {};
  state.notes.forEach(n=>{ if(n.mid === snap.mid) byId[n.id] = n; });
  snap.entries.forEach(e=>{
    const note = byId[e.id];
    if(note){ note.fields = e.fields.slice(); note.dirty = e.dirty; }
  });
  state.autoTranslateSnapshot = null;
  document.getElementById('btnAutoTranslateUndo').disabled = true;
  ahAtClearFailedRetry();
  renderTable();
  updateStats();
  toast('Translate otomatis terakhir dibatalin, field balik kayak sebelumnya~', '↩️');
});

// Sama kayak "Translate Semua Field yang Dicentang", tapi cuma buat kartu di batch
// yang lagi aktif (pakai ukuran batch & posisi batch yang sama kayak Copy/Paste
// Batch) -- cocok buat deck gede biar gak nembak semua note sekaligus / bisa
// dicek per batch kayak workflow translate manual yang lain.
document.getElementById('btnAutoTranslateBatch').addEventListener('click', ()=>{
  const rows = getBatchRows();
  if(!rows.length){ toast('Batch ini kosong~', '⚠️'); return; }
  runAutoTranslate(rows);
});

document.getElementById('btnAutoTranslate').addEventListener('click', runAutoTranslate);
document.getElementById('btnAutoTranslateCancel').addEventListener('click', ()=>{ state.autoTranslate.cancel = true; });

document.getElementById('btnCopyBatch').addEventListener('click', async ()=>{
  const rows = getBatchRows();
  if(!rows.length){ toast('Batch ini kosong~', '⚠️'); return; }
  const text = buildBlockText(rows);
  const { totalBatches } = getBatchBounds(currentRows().length);
  try{
    await navigator.clipboard.writeText(text);
  }catch(e){
    const ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
  }
  toast(`Batch ${state.batchIndex+1}/${totalBatches} (${rows.length} kartu) dicopy!`, '📋');
  say(`Batch ${state.batchIndex+1} dari ${totalBatches} udah aku copy! Translate ini dulu ya, jangan digabung sama batch lain biar ID-nya gak ketuker~ 🍯`);
});

/* ---------------- table render ---------------- */
function renderTable(){
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = '';
  const model = state.models[state.currentMid];
  if(!model) return;
  const allRows = state.notes.filter(n=>n.mid===state.currentMid);
  const frag = document.createDocumentFragment();
  const selIdxs = (state.selectedFieldIdxs && state.selectedFieldIdxs.length) ? state.selectedFieldIdxs : [0];

  // Pagination -- CUMA buat batasin JUMLAH BARIS YANG DI-RENDER ke DOM sekali render,
  // biar gak ngelag di deck gede (ribuan notes bikin ribuan textarea sekaligus tiap kali
  // renderTable() dipanggil, misal tiap centang/uncentang field). Translate/Jelasin/Copy-
  // Paste tetep jalan ke SEMUA note yang dicentang (lewat currentRows()), gak kepengaruh
  // sama pagination ini -- ini murni soal apa yang KELIATAN & bisa diedit manual di layar.
  const pageSize = Math.max(1, state.tablePageSize|0 || 50);
  const totalPages = Math.max(1, Math.ceil(allRows.length / pageSize));
  if(state.tablePageIndex >= totalPages) state.tablePageIndex = totalPages - 1;
  if(state.tablePageIndex < 0) state.tablePageIndex = 0;
  const startIdx = state.tablePageIndex * pageSize;
  const rows = allRows.slice(startIdx, startIdx + pageSize);

  const pageInfoEl = document.getElementById('tablePageInfo');
  if(pageInfoEl){
    pageInfoEl.textContent = allRows.length
      ? `Halaman ${state.tablePageIndex+1}/${totalPages} — note ke ${startIdx+1}–${Math.min(startIdx+pageSize, allRows.length)} dari total ${allRows.length}`
      : 'Belum ada note.';
  }
  const prevBtn = document.getElementById('btnTablePagePrev');
  const nextBtn = document.getElementById('btnTablePageNext');
  if(prevBtn) prevBtn.disabled = state.tablePageIndex <= 0;
  if(nextBtn) nextBtn.disabled = state.tablePageIndex >= totalPages - 1;

  rows.forEach(note=>{
    const tr = document.createElement('tr');

    const dotTd = document.createElement('td');
    const dot = document.createElement('span');
    dot.className = 'row-dot ' + (note.dirty ? 'dirty':'clean');
    dot.id = 'dot-'+note.id;
    dotTd.appendChild(dot);
    tr.appendChild(dotTd);

    const idTd = document.createElement('td');
    idTd.className = 'id-cell';
    idTd.textContent = note.id;
    tr.appendChild(idTd);

    const previewTd = document.createElement('td');
    previewTd.className = 'preview-cell';
    const otherFields = note.fields
      .map((v,i)=> selIdxs.includes(i) ? null : stripHtml(v))
      .filter(v=>v!==null && v.trim()!=='')
      .join(' · ');
    const mini = document.createElement('span');
    mini.className = 'mini';
    mini.textContent = otherFields || '(kosong)';
    previewTd.appendChild(mini);
    tr.appendChild(previewTd);

    const editTd = document.createElement('td');
    editTd.className = 'edit-cell';
    selIdxs.forEach(fi=>{
      if(selIdxs.length > 1){
        const lbl = document.createElement('div');
        lbl.className = 'field-mini-label';
        lbl.textContent = model.flds[fi] || `Field ${fi+1}`;
        editTd.appendChild(lbl);
      }
      const ta = document.createElement('textarea');
      ta.value = note.fields[fi] || '';
      ta.dataset.noteId = note.id;
      ta.dataset.fieldIdx = fi;
      if(note.dirty) ta.classList.add('dirty');
      ta.addEventListener('input', ()=>{
        note.fields[fi] = ta.value;
        note.dirty = true;
        ta.classList.add('dirty');
        const dotEl = document.getElementById('dot-'+note.id);
        if(dotEl){ dotEl.className='row-dot dirty'; }
        updateStats();
      });
      editTd.appendChild(ta);
    });
    tr.appendChild(editTd);

    frag.appendChild(tr);
  });

  tbody.appendChild(frag);
  updateStats();
}

document.getElementById('btnTablePagePrev').addEventListener('click', ()=>{
  if(state.tablePageIndex > 0){ state.tablePageIndex--; renderTable(); }
});
document.getElementById('btnTablePageNext').addEventListener('click', ()=>{
  state.tablePageIndex++; renderTable();
});
document.getElementById('tablePageSizeSelect').addEventListener('change', function(){
  state.tablePageSize = parseInt(this.value) || 50;
  state.tablePageIndex = 0; // balik ke halaman pertama biar gak bingung posisinya geser
  renderTable();
});

function stripHtml(str){
  const tmp = document.createElement('div');
  tmp.innerHTML = str;
  return (tmp.textContent || tmp.innerText || '').replace(/\s+/g,' ').trim();
}

/* ---------------- copy all / paste all ---------------- */
function currentRows(){
  return state.notes.filter(n=>n.mid===state.currentMid);
}

function buildBlockText(rows){
  const model = state.models[state.currentMid];
  const selIdxs = (state.selectedFieldIdxs && state.selectedFieldIdxs.length) ? state.selectedFieldIdxs : [0];
  const refIdxs = state.referenceFieldIdxs || [];
  const body = (rows || currentRows()).map(n=>{
    if(selIdxs.length === 1){
      const val = n.fields[selIdxs[0]] || '';
      return `[[[ID:${n.id}]]]\n${val}`;
    }
    const parts = selIdxs.map(fi=>{
      const fname = (model && model.flds[fi]) || `Field${fi+1}`;
      const val = n.fields[fi] || '';
      return `[${fname}]\n${val}`;
    }).join('\n');
    return `[[[ID:${n.id}]]]\n${parts}`;
  }).join('\n\n');

  // Kalau ada field yang ditandain "sumber" (🔒), kasih instruksi eksplisit di atas teks biar
  // AI translator-nya gak salah nerjemahin field yang harusnya dibiarin sama persis. Digabung
  // sama instruksi khusus per-field (kalau user nulis, misal buat field "Notes") jadi satu
  // header [INSTRUKSI BUAT AI TRANSLATOR] di atas teks yang dicopy.
  const headerParts = [];

  if(refIdxs.length && model){
    const refNames = refIdxs.map(fi=> model.flds[fi]).filter(Boolean);
    const targetNames = selIdxs.filter(fi=> !refIdxs.includes(fi)).map(fi=> model.flds[fi]).filter(Boolean);
    if(refNames.length){
      headerParts.push(`Field ${refNames.map(n=>`"${n}"`).join(', ')} adalah SUMBER/REFERENSI — salin PERSIS SAMA APA ADANYA, JANGAN diterjemahin/diubah, cuma dipakai buat konteks/ngambil kosakata.${targetNames.length ? ` Isi hasil terjemahannya ditaruh di field ${targetNames.map(n=>`"${n}"`).join(', ')} aja.` : ''}`);
    }
  }

  if(model){
    const instrLines = [];
    selIdxs.filter(fi=> !refIdxs.includes(fi)).forEach(fi=>{
      const txt = state.fieldInstructionsByModel && state.fieldInstructionsByModel[state.currentMid] && state.fieldInstructionsByModel[state.currentMid][fi];
      if(txt && txt.trim()){
        const fname = model.flds[fi] || `Field${fi+1}`;
        instrLines.push(`• Field "${fname}":\n${txt.trim()}`);
      }
    });
    if(instrLines.length){
      headerParts.push(`Instruksi khusus buat tiap field (WAJIB diikutin pas ngisi field itu):\n${instrLines.join('\n\n')}`);
    }
  }

  if(headerParts.length){
    const tagNote = selIdxs.length > 1
      ? 'Jangan hapus baris [[[ID:...]]] dan tag [NamaField], dan jangan ubah urutan barisnya.'
      : 'Jangan hapus baris [[[ID:...]]], dan jangan ubah urutan barisnya.';
    const header = `[INSTRUKSI BUAT AI TRANSLATOR]\n${headerParts.join('\n\n')}\n\n${tagNote}\n\n`;
    return header + body;
  }
  return body;
}

document.getElementById('btnCopyAll').addEventListener('click', async ()=>{
  const rows = currentRows();
  const BIG_DECK_WARNING_THRESHOLD = 120;
  if(rows.length > BIG_DECK_WARNING_THRESHOLD){
    const lanjut = confirm(
      `Kartu tipe ini ada ${rows.length}, lumayan banyak buat ditranslate sekaligus.\n\n`+
      `Nge-paste teks sebanyak ini ke AI translator (ChatGPT/Google Translate dll) beresiko bikin AI-nya "geser" nomor urutan ID di tengah-tengah, jadi terjemahan salah pasang ke kartu yang lain (pernah kejadian!).\n\n`+
      `Disaranin pakai fitur "Copy per Batch" di bawah aja (misal 50 kartu per batch).\n\n`+
      `Tetap mau copy SEMUA ${rows.length} kartu sekaligus?`
    );
    if(!lanjut) return;
  }
  const text = buildBlockText(rows);
  try{
    await navigator.clipboard.writeText(text);
    toast(`${rows.length} field dicopy! Tinggal paste ke Google Translate / ChatGPT~`, '📋');
    say('Field-nya sudah aku copy ke clipboard! ✂️');
  }catch(e){
    // fallback
    const ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
    toast('Dicopy (mode fallback)!', '📋');
  }
});

const pasteModalBg = document.getElementById('pasteModalBg');
let pasteScopeRows = null; // null = paste bebas (semua kartu tipe ini); array = mode batch (ID harus persis cocok batch aktif)

function openPasteModal(scopeRows){
  pasteScopeRows = scopeRows || null;
  document.getElementById('pasteArea').value = '';
  const titleEl = document.getElementById('pasteModalTitle');
  const subEl = document.getElementById('pasteModalSub');
  if(pasteScopeRows){
    const { totalBatches } = getBatchBounds(currentRows().length);
    titleEl.textContent = `📥 Paste Batch ${state.batchIndex+1}/${totalBatches} (${pasteScopeRows.length} kartu)`;
    subEl.innerHTML = `Mode <b>Paste Batch</b> — tool ini bakal ngecek ketat: cuma ${pasteScopeRows.length} ID kartu di batch ${state.batchIndex+1} ini yang boleh muncul di teks yang kamu tempel. Kalau ada ID dari batch lain kebawa, atau ada ID batch ini yang malah gak ketemu, bakal ada peringatan biar gak ada yang ketuker.`;
  } else {
    titleEl.textContent = '📥 Paste Hasil Terjemahan';
    subEl.innerHTML = 'Tempel teks yang sama persis formatnya kayak waktu kamu copy tadi (jangan hapus baris <code>[[[ID:...]]]</code> dan tag <code>[NamaField]</code> kalau kamu gabung beberapa field), lalu klik Terapkan. Kalau kamu translate per batch, mendingan pakai tombol "Paste Batch Ini" di panel batch biar dicek ketat per batch — jangan digabung jadi satu paste raksasa.';
  }
  pasteModalBg.classList.add('show');
}

document.getElementById('btnPasteAll').addEventListener('click', ()=> openPasteModal(null));
document.getElementById('btnPasteBatch').addEventListener('click', ()=>{
  const rows = getBatchRows();
  if(!rows.length){ toast('Batch ini kosong~', '⚠️'); return; }
  if(state.doneBatches.has(batchKeyFor(rows))){
    const lanjut = confirm(
      `Batch ${state.batchIndex+1} ini KETANDA udah pernah di-apply sebelumnya.\n\n`+
      `Kalau kamu paste lagi, isi field yang sekarang bakal ketimpa sama teks baru ini.\n\n`+
      `Yakin mau lanjut nimpa?`
    );
    if(!lanjut) return;
  }
  openPasteModal(rows);
});
document.getElementById('btnCancelPaste').addEventListener('click', ()=> pasteModalBg.classList.remove('show'));

document.getElementById('btnApplyPaste').addEventListener('click', ()=>{
  const raw = document.getElementById('pasteArea').value;

  // Snapshot dulu SEBELUM diterapin -> biar bisa di-undo kalau ternyata hasilnya berantakan.
  // Mode Paste Batch: cuma snapshot kartu di batch ini. Mode Paste Bebas: snapshot semua kartu
  // tipe ini (karena ID mana aja yang bakal kena gak ketauan sebelum di-parse).
  const scopeForSnapshot = pasteScopeRows || currentRows();
  state.pasteSnapshot = {
    mid: state.currentMid,
    batchKey: pasteScopeRows ? batchKeyFor(pasteScopeRows) : null,
    entries: scopeForSnapshot.map(n=> ({ id: n.id, fields: n.fields.slice(), dirty: n.dirty }))
  };

  const applied = applyBlockText(raw, pasteScopeRows);
  pasteModalBg.classList.remove('show');
  renderTable();

  const undoBtn = document.getElementById('btnUndoPaste');
  if(undoBtn) undoBtn.disabled = false;

  if(pasteScopeRows){
    const { totalBatches } = getBatchBounds(currentRows().length);
    state.doneBatches.add(batchKeyFor(pasteScopeRows));
    toast(`Batch ${state.batchIndex+1}/${totalBatches}: ${applied} field diupdate!`, '✨');
    say(`Batch ${state.batchIndex+1} beres! Kalau udah yakin bener, lanjut ke batch berikutnya ya~ 🌟`);
  } else {
    toast(`${applied} field berhasil diupdate dari hasil terjemahan!`, '✨');
    say(`Wah keren, ${applied} field udah diterjemahin! 🌟`);
  }
  pasteScopeRows = null;
  updateBatchUI();
});

document.getElementById('btnUndoPaste').addEventListener('click', ()=>{
  const snap = state.pasteSnapshot;
  if(!snap){ toast('Gak ada paste yang bisa di-undo~', '⚠️'); return; }
  const byId = {};
  state.notes.forEach(n=>{ if(n.mid === snap.mid) byId[n.id] = n; });
  snap.entries.forEach(e=>{
    const note = byId[e.id];
    if(note){ note.fields = e.fields.slice(); note.dirty = e.dirty; }
  });
  if(snap.batchKey) state.doneBatches.delete(snap.batchKey);
  state.pasteSnapshot = null;
  document.getElementById('btnUndoPaste').disabled = true;
  renderTable();
  updateBatchUI();
  toast('Paste terakhir dibatalin, balik ke sebelum di-apply!', '↩️');
  say('Oke, aku balikin lagi kayak sebelum paste tadi~ 🔙');
});

function snippetOf(str, n){
  n = n || 50;
  const s = stripHtml(str || '');
  return s.length > n ? s.slice(0, n) + '…' : (s || '(kosong)');
}

// Referensi yang HARUS tetap sama persis walau bahasanya beda (nama file audio, gambar, link) --
// dipakai sebagai "sidik jari" konten buat nangkep kasus dua field ke-swap biar ID-nya sendiri
// tetep valid dua-duanya. Kalau includeFullText true (field ditandain SUMBER/REFERENSI oleh user),
// seluruh isi field itu sendiri juga dipakai sebagai "token" -- soalnya field sumber emang
// harusnya PERSIS SAMA, gak peduli isinya bahasa apa.
function extractInvariantTokens(str, includeFullText){
  const tokens = [];
  const s = str || '';
  let m;
  const reSound = /\[sound:[^\]]+\]/g;
  while((m = reSound.exec(s))) tokens.push(m[0]);
  const reImg = /<img[^>]*>/gi;
  while((m = reImg.exec(s))) tokens.push(m[0]);
  const reUrl = /https?:\/\/[^\s"'<>]+/g;
  while((m = reUrl.exec(s))) tokens.push(m[0]);
  if(includeFullText){
    const full = stripHtml(s).trim();
    if(full.length >= 3) tokens.push('FULLTEXT::' + full);
  }
  return tokens;
}

function applyBlockText(raw, scopeRows){
  const model = state.models[state.currentMid];
  const selIdxs = (state.selectedFieldIdxs && state.selectedFieldIdxs.length) ? state.selectedFieldIdxs : [0];
  const regex = /\[\[\[ID:(\d+)\]\]\]\n?([\s\S]*?)(?=\n*\[\[\[ID:\d+\]\]\]|$)/g;
  let match, count=0;
  const byId = {};
  currentRows().forEach(n=> byId[n.id]=n);

  // Preview tiap kartu (field LAIN di luar yang lagi ditranslate), diambil SEBELUM paste diterapin,
  // biar warning bisa nunjukin "kartu ini yang mana" tanpa harus scroll ke tabel.
  const notePreviewById = {};
  currentRows().forEach(n=>{
    const txt = n.fields.map((v,i)=> selIdxs.includes(i) ? null : stripHtml(v)).filter(v=>v!==null && v.trim()!=='').join(' · ');
    notePreviewById[n.id] = snippetOf(txt || '(kosong)', 70);
  });

  // Kalau dipanggil dari mode "Paste Batch", ID yang boleh diterapkan HARUS persis
  // anggota batch yang lagi aktif -- ID valid tapi dari batch lain tetap ditolak & dilaporkan,
  // biar terjemahan gak nyasar ke kartu di luar batch yang lagi dikerjain.
  const scopeIds = scopeRows ? new Set(scopeRows.map(n=> String(n.id))) : null;

  // ---- Pelacak buat validasi anti-pergeseran/misalignment ----
  const seenIds = new Set();
  const appliedOrder = [];   // urutan ID yang beneran diterapin (buat deteksi ke-geser/swap)
  const appliedChanges = []; // {id, fname, oldLen, newLen, oldSnippet, newSnippet, oldTokens, newTokens} tiap field yang diganti
  const warnings = {
    duplicateIds: [],      // ID:xxx muncul lebih dari sekali di teks yang di-paste
    unknownIds: [],        // ID:xxx ada di teks paste tapi gak ketemu di kartu yang lagi dibuka
    outOfScopeIds: [],     // ID:xxx valid tapi bukan anggota batch yang lagi aktif (mode Paste Batch)
    fieldNameMismatch: [], // {id, fname} nama tag [Field] gak cocok sama nama field asli notetype
    droppedFields: [],     // {id, fname} tag field-nya gak bisa dipetakan sama sekali (isinya dibuang)
    emptiedFields: [],     // {id, fname} field yang tadinya ada isi, sekarang jadi kosong abis di-paste
    tokenSwaps: [],        // {id, fname, token, foundInId, foundInFname} referensi (sound/img/url/field sumber) yang kayaknya nyasar ke ID lain
    referenceFieldChanged: [] // {id, fname, oldSnippet, newSnippet} field yang ditandain SUMBER (🔒) tapi ternyata isinya berubah
  };

  while((match = regex.exec(raw)) !== null){
    const id = match[1];
    let blockContent = match[2].replace(/\n+$/,'');

    if(seenIds.has(id)) warnings.duplicateIds.push(id);
    seenIds.add(id);

    const note = byId[id];
    if(!note){ warnings.unknownIds.push(id); continue; }
    if(scopeIds && !scopeIds.has(String(id))){ warnings.outOfScopeIds.push(id); continue; }

    appliedOrder.push(String(id));

    // Deteksi format multi-field: baris "[NamaField]" di awal tiap bagian
    const fieldTagRegex = /^\[(.+?)\]\r?\n([\s\S]*?)(?=\n\[.+?\]\r?\n|(?![\s\S]))/gm;
    const fieldMatches = [...blockContent.matchAll(fieldTagRegex)];

    if(fieldMatches.length){
      fieldMatches.forEach((fm, pos)=>{
        const fname = fm[1].trim();
        const fval = fm[2].replace(/\n+$/,'');
        let idx = model ? model.flds.findIndex(f=> f===fname) : -1;
        if(idx === -1){
          // Nama tag [Field] gak ketemu persis di notetype -> fallback ke posisi urutan.
          // Ini rawan salah pasang kalau AI translator ngerubah/ngilangin salah satu tag [Field],
          // makanya kita catat sebagai warning, bukan diterapin diem-diem.
          if(selIdxs[pos] !== undefined){
            idx = selIdxs[pos];
            warnings.fieldNameMismatch.push({ id, fname, fallbackField: model.flds[idx] });
          } else {
            warnings.droppedFields.push({ id, fname });
          }
        }
        if(idx !== -1){
          const oldVal = note.fields[idx] || '';
          const oldLen = stripHtml(oldVal).length;
          const newLen = stripHtml(fval).length;
          const isRef = (state.referenceFieldIdxs||[]).includes(idx);
          if(oldLen > 0 && newLen === 0){
            warnings.emptiedFields.push({ id, fname });
          }
          if(isRef && stripHtml(oldVal).trim() !== stripHtml(fval).trim()){
            warnings.referenceFieldChanged.push({ id, fname, oldSnippet: snippetOf(oldVal), newSnippet: snippetOf(fval) });
          }
          appliedChanges.push({ id, fname, oldTokens: extractInvariantTokens(oldVal, isRef), newTokens: extractInvariantTokens(fval, isRef) });
          note.fields[idx] = fval;
          note.dirty = true;
        }
      });
      count++;
    } else {
      // format lama (single field, tanpa tag nama field)
      const oldVal = note.fields[selIdxs[0]] || '';
      const oldLen = stripHtml(oldVal).length;
      const newLen = stripHtml(blockContent).length;
      if(oldLen > 0 && newLen === 0){
        warnings.emptiedFields.push({ id, fname: null });
      }
      appliedChanges.push({ id, fname: null, oldTokens: extractInvariantTokens(oldVal), newTokens: extractInvariantTokens(blockContent) });
      note.fields[selIdxs[0]] = blockContent;
      note.dirty = true;
      count++;
    }
  }

  // ---- Deteksi urutan ke-geser/swap ----
  // ID tetep dipakai sebagai sumber kebenaran (jadi field TETAP masuk ke kartu yang bener sesuai ID),
  // tapi kalau urutan blok di teks paste beda sama urutan aslinya pas di-copy, itu sinyal AI translator-nya
  // kemungkinan ngacak/geser baris -- pantas dicurigai walau ID-nya sendiri masih valid semua.
  const expectedSourceRows = scopeRows || currentRows();
  const expectedOrder = expectedSourceRows.map(n=> String(n.id)).filter(id=> appliedOrder.includes(id));
  const orderMismatchSample = [];
  let orderMismatchCount = 0;
  for(let i=0; i<appliedOrder.length; i++){
    if(appliedOrder[i] !== expectedOrder[i]){
      orderMismatchCount++;
      if(orderMismatchSample.length < 5){
        orderMismatchSample.push(`posisi ke-${i+1}: ketemu ID:${appliedOrder[i]}, harusnya ID:${expectedOrder[i]}`);
      }
    }
  }
  warnings.orderMismatchCount = orderMismatchCount;
  warnings.orderMismatchSample = orderMismatchSample;

  // ---- Deteksi konten yang kayaknya "seharusnya ada di ID lain" ----
  // Nama file audio/gambar/link itu gak diterjemahin AI, jadi kalau referensi itu ada di field
  // ASLI-nya ID X tapi ilang dari hasil translate ID X dan malah nongol di hasil translate ID lain,
  // itu bukti kuat dua field ini ke-swap -- bukan cuma dugaan panjang teks doang.
  appliedChanges.forEach(c=>{
    c.oldTokens.forEach(tok=>{
      if(c.newTokens.includes(tok)) return; // masih ada di tempat yang bener, aman
      const foundIn = appliedChanges.find(o=> o !== c && o.newTokens.includes(tok));
      if(foundIn){
        warnings.tokenSwaps.push({ id: c.id, fname: c.fname, token: tok, foundInId: foundIn.id, foundInFname: foundIn.fname });
      }
    });
  });

  // Kalau field sumber yang berubah tadi udah ketauan ke-swap-nya lewat tokenSwaps (di atas),
  // gak perlu dilaporin dobel di sini -- cukup satu kali dengan bukti yang lebih spesifik.
  const swappedPairs = new Set(warnings.tokenSwaps.map(w=> w.id+'|'+(w.fname||'')));
  warnings.referenceFieldChanged = warnings.referenceFieldChanged.filter(w=> !swappedPairs.has(w.id+'|'+(w.fname||'')));

  // Mode Paste Batch: kita TAU persis ID mana aja yang seharusnya ada -> bisa deteksi kalau
  // ada kartu di batch ini yang translationnya kelewat/gak ke-paste sama sekali.
  const missingFromBatch = scopeIds
    ? scopeRows.filter(n=> !seenIds.has(String(n.id))).map(n=> n.id)
    : [];

  const hasWarnings = warnings.duplicateIds.length || warnings.unknownIds.length ||
                       warnings.outOfScopeIds.length || warnings.fieldNameMismatch.length ||
                       warnings.droppedFields.length || missingFromBatch.length ||
                       warnings.emptiedFields.length ||
                       warnings.tokenSwaps.length || warnings.orderMismatchCount ||
                       warnings.referenceFieldChanged.length;
  if(hasWarnings){
    const lines = [];
    if(warnings.tokenSwaps.length){
      const dispToken = (t)=> t.startsWith('FULLTEXT::') ? `isi field sumber "${snippetOf(t.slice(10),40)}"` : t;
      lines.push(`🚨 ${warnings.tokenSwaps.length} referensi (audio/gambar/link/field sumber) kayaknya KETUKER ke ID lain — ini indikasi PALING KUAT:\n` +
        warnings.tokenSwaps.slice(0,6).map(w=>
          `• ${dispToken(w.token)} harusnya di ID:${w.id}${w.fname?` [${w.fname}]`:''} tapi malah ketemu di ID:${w.foundInId}${w.foundInFname?` [${w.foundInFname}]`:''}\n`+
          `   ↳ ID:${w.id} → ${notePreviewById[w.id] || '(?)'}\n`+
          `   ↳ ID:${w.foundInId} → ${notePreviewById[w.foundInId] || '(?)'}`
        ).join('\n') + (warnings.tokenSwaps.length>6?`\n...dan ${warnings.tokenSwaps.length-6} lainnya`:''));
    }
    if(warnings.duplicateIds.length){
      lines.push(`⚠️ ${warnings.duplicateIds.length} ID muncul dobel di teks yang kamu paste (blok terakhir yang menang, yang sebelumnya ketimpa): ${warnings.duplicateIds.slice(0,10).join(', ')}${warnings.duplicateIds.length>10?', ...':''}`);
    }
    if(warnings.unknownIds.length){
      lines.push(`⚠️ ${warnings.unknownIds.length} ID di teks paste gak ketemu kartunya (dilewatin, gak diterapin): ${warnings.unknownIds.slice(0,10).join(', ')}${warnings.unknownIds.length>10?', ...':''}`);
    }
    if(warnings.outOfScopeIds.length){
      lines.push(`⚠️ ${warnings.outOfScopeIds.length} ID valid tapi BUKAN anggota batch yang lagi aktif (mungkin ini hasil terjemahan dari batch lain yang ketuker/ke-paste di sini): ${warnings.outOfScopeIds.slice(0,10).join(', ')}${warnings.outOfScopeIds.length>10?', ...':''} — ini SEMUA dilewatin, gak diterapin. Cek lagi kamu lagi di batch berapa & paste hasil translate batch yang bener.`);
    }
    if(missingFromBatch.length){
      lines.push(`⚠️ ${missingFromBatch.length} kartu di batch ini gak ketemu ID-nya sama sekali di teks yang kamu paste (kemungkinan kelewat/gak sempet diterjemahin AI-nya): ${missingFromBatch.slice(0,10).join(', ')}${missingFromBatch.length>10?', ...':''} — field kartu ini TETAP isi lama, belum ke-update.`);
    }
    if(warnings.fieldNameMismatch.length){
      lines.push(`⚠️ ${warnings.fieldNameMismatch.length} bagian punya tag [NamaField] yang gak persis sama kayak nama field aslinya, jadi ditebak berdasarkan urutan aja — ini TANDA PALING KUAT kalau AI translator-nya ngerubah/ngilangin sebagian tag pas nerjemahin, dan berpotensi bikin field ketuker ke kartu yang salah. Cek manual bagian ini dulu sebelum lanjut simpan!`);
    }
    if(warnings.droppedFields.length){
      lines.push(`⚠️ ${warnings.droppedFields.length} bagian field gak bisa dipetakan sama sekali & isinya DIBUANG (bukan ke kartu lain, cuma hilang): ${warnings.droppedFields.slice(0,10).map(w=>`ID:${w.id} [${w.fname}]`).join(', ')}${warnings.droppedFields.length>10?', ...':''}`);
    }
    if(warnings.orderMismatchCount){
      lines.push(`⚠️ Urutan ${warnings.orderMismatchCount} blok ID di teks paste BEDA sama urutan aslinya pas kamu copy (${warnings.orderMismatchSample.join('; ')}${warnings.orderMismatchCount>warnings.orderMismatchSample.length?', ...':''}). Field tetap diterapin sesuai ID yang tertulis (jadi gak nyasar ke kartu lain), tapi urutan yang geser gini sering nandain AI translator-nya ngacak baris — cek manual dulu sebelum yakin bener.`);
    }
    if(warnings.emptiedFields.length){
      lines.push(`⚠️ ${warnings.emptiedFields.length} field yang tadinya ADA isinya, sekarang jadi KOSONG abis di-paste: ${warnings.emptiedFields.slice(0,10).map(w=>`ID:${w.id}${w.fname?` [${w.fname}]`:''} (kartu: ${notePreviewById[w.id]||'(?)'})`).join('; ')}${warnings.emptiedFields.length>10?', ...':''} — kemungkinan translation-nya kelewat, atau ketuker ke tempat lain.`);
    }
    if(warnings.referenceFieldChanged.length){
      lines.push(`⚠️ ${warnings.referenceFieldChanged.length} field yang ditandain 🔒 SUMBER (harusnya gak berubah) ternyata isinya beda dari aslinya — kemungkinan AI-nya ikut nerjemahin/ngedit field ini padahal harusnya dibiarin persis sama:\n` +
        warnings.referenceFieldChanged.slice(0,8).map(w=>
          `• ID:${w.id}${w.fname?` [${w.fname}]`:''} (kartu: ${notePreviewById[w.id]||'(?)'})\n`+
          `   dulu: "${w.oldSnippet}"\n`+
          `   jadi: "${w.newSnippet}"`
        ).join('\n') + (warnings.referenceFieldChanged.length>8?`\n...dan ${warnings.referenceFieldChanged.length-8} lainnya`:''));
    }
    lines.push(`\nSaran: kalau ini kejadian pas kamu paste batch gede, coba pecah jadi batch lebih kecil (pakai fitur "Copy per Batch") biar AI translator-nya gak gampang keliru jagain urutan ID. Kalau ternyata hasilnya berantakan, tombol "↩️ Undo Paste Terakhir" bisa balikin ke sebelum paste ini diterapin.`);
    ahShowErrorPopup(lines.join('\n\n'));
  }

  return count;
}

/* ---------------- export csv/txt ---------------- */
function downloadBlob(content, filename, type){
  const blob = new Blob([content], {type});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

document.getElementById('btnExportCsv').addEventListener('click', ()=>{
  const model = state.models[state.currentMid];
  const selIdxs = (state.selectedFieldIdxs && state.selectedFieldIdxs.length) ? state.selectedFieldIdxs : [0];
  let rows;
  if(selIdxs.length === 1){
    rows = currentRows().map(n=> ({ id:n.id, text:n.fields[selIdxs[0]]||'' }));
  } else {
    rows = currentRows().map(n=>{
      const row = { id: n.id };
      selIdxs.forEach(fi=>{
        const fname = (model && model.flds[fi]) || `field${fi+1}`;
        row[fname] = n.fields[fi] || '';
      });
      return row;
    });
  }
  const csv = Papa.unparse(rows);
  downloadBlob(csv, 'anki_field_export.csv', 'text/csv;charset=utf-8;');
  toast('CSV berhasil didownload!', '⬇️');
});

document.getElementById('btnExportTxt').addEventListener('click', ()=>{
  downloadBlob(buildBlockText(), 'anki_field_export.txt', 'text/plain;charset=utf-8;');
  toast('TXT berhasil didownload!', '⬇️');
});

/* ---------------- import csv/txt ---------------- */
const importFileInput = document.getElementById('importFileInput');
document.getElementById('btnImportFile').addEventListener('click', ()=> importFileInput.click());
importFileInput.addEventListener('change', async e=>{
  const f = e.target.files[0];
  if(!f) return;
  const text = await f.text();
  let applied = 0;
  const model = state.models[state.currentMid];
  const selIdxs = (state.selectedFieldIdxs && state.selectedFieldIdxs.length) ? state.selectedFieldIdxs : [0];
  if(f.name.toLowerCase().endsWith('.csv')){
    const parsed = Papa.parse(text, {header:true});
    const byId = {};
    currentRows().forEach(n=> byId[String(n.id)]=n);
    parsed.data.forEach(row=>{
      const id = row.id;
      const note = id ? byId[id] : null;
      if(!note) return;
      if(selIdxs.length === 1){
        note.fields[selIdxs[0]] = row.text || '';
        note.dirty = true;
        applied++;
      } else {
        let any = false;
        selIdxs.forEach(fi=>{
          const fname = (model && model.flds[fi]) || `field${fi+1}`;
          if(Object.prototype.hasOwnProperty.call(row, fname)){
            note.fields[fi] = row[fname] || '';
            any = true;
          }
        });
        if(any){ note.dirty = true; applied++; }
      }
    });
  } else {
    applied = applyBlockText(text);
  }
  renderTable();
  toast(`${applied} field berhasil diimport!`, '📥');
  say(`Field-nya udah aku update dari file kamu! 💾`);
  importFileInput.value = '';
});

/* ---------------- save final apkg ---------------- */
document.getElementById('btnDownloadApkg').addEventListener('click', async ()=>{
  if(!state.db){ toast('Belum ada deck yang dibuka!', '😿'); return; }
  const btn = document.getElementById('btnDownloadApkg');
  const origLabel = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="loader"><span></span><span></span><span></span></span> Menyimpan...';
  say('Lagi masak ulang deck-nya, sabar ya~ 🍳');
  try{
    let updatedCount = state.notes.filter(n=>n.dirty).length;

    if(!state.isLatest){
      // Format lama: UPDATE flds+tags di database yang sama. Semua note ditulis ulang
      // (bukan cuma yang dirty) supaya tag watermark ikut ke-suntik ke semuanya.
      const stmt = state.db.prepare("UPDATE notes SET flds=?, tags=?, mod=? WHERE id=?");
      const now = Math.floor(Date.now()/1000);
      state.notes.forEach(n=>{
        const flds = n.fields.join('\x1f');
        const tags = injectWmIntoTags(n.tags);
        stmt.run([flds, tags, now, n.id]);
      });
      stmt.free();

      applyDeckRenamesLegacy();
      await applyCardBackgroundLegacy();

      const newDbData = state.db.export();
      state.zip.file(state.collectionFileName, newDbData);
      const blob = await state.zip.generateAsync({type:'blob'});
      downloadBlob(blob, state.originalFileName, 'application/octet-stream');
    } else {
      // Format terbaru (zstd/schema v18): rebuild jadi paket format Legacy (schema 11)
      // supaya bisa ditulis ulang tanpa perlu re-compress zstd. Note id/guid/tag serta
      // baris cards & revlog (jadwal belajar) dipindah apa adanya biar minim data hilang.
      const blob = await rebuildAsLegacyApkg();
      downloadBlob(blob, state.originalFileName, 'application/octet-stream');
    }

    toast(`Deck baru siap didownload! (${updatedCount} note diupdate) 🎉`, '💾');
    say('Selesai~ deck barunya udah bisa diimport ke Anki! 🎊');
  }catch(err){
    console.error(err);
    toast('Gagal menyimpan: '+(err.message||err), '😿');
    say('Waduh ada error pas nyimpen huhu 😿');
  }finally{
    btn.disabled = false;
    btn.innerHTML = origLabel;
  }
});

/* ---------------- rebuild ke format Legacy (schema 11) ---------------- */

// modelType: 0 = standard, 1 = cloze (dari m.type note type asli — dipertahankan
// biar note Cloze yang jatuh ke fallback ini tetep dirender pake {{cloze:...}},
// bukan ketampilin mentah sebagai teks "{{c1::...}}" ala note type biasa.
// templateCount: jumlah template minimum yang dibutuhkan, dihitung dari ord
// tertinggi yang beneran dipakai di tabel cards (lihat rebuildAsLegacyApkg) —
// note type standar custom yang punya >1 kartu per note (mis. "and reversed")
// butuh template sejumlah itu juga, atau kartu ber-ord>=1 bakal nunjuk ke
// template yang gak ada pas diimport ke Anki. Cloze SELALU 1 template
// (jumlah kartu-nya diatur Anki sendiri lewat banyaknya c1/c2/dst, bukan
// lewat banyaknya template), jadi templateCount diabaikan kalau modelType===1.
function buildLegacyModel(mid, deckId, modelName, fieldNames, modelType, templateCount){
  modelType = modelType === 1 ? 1 : 0;
  templateCount = Math.max(1, templateCount || 1);
  const flds = fieldNames.map((name,i)=>({name, ord:i, sticky:false, rtl:false, font:"Arial", size:20, media:[]}));

  let tmpls, req;
  if(modelType === 1){
    // Cloze: field pertama dianggap field cloze utama (paling umum, mis. "Text").
    const clozeField = fieldNames[0] || 'Text';
    const qfmt = `{{cloze:${clozeField}}}`;
    const afmt = `{{cloze:${clozeField}}}` + fieldNames.slice(1).map(f=>`<br>{{${f}}}`).join('');
    tmpls = [{name:"Cloze", ord:0, qfmt, afmt, bqfmt:"", bafmt:"", did:null, bfont:"", bsize:0}];
    req = [[0, "any", [0]]];
  } else {
    tmpls = [];
    for(let i=0;i<templateCount;i++){
      let qfmt, afmt;
      if(fieldNames.length >= 2){
        qfmt = `{{${fieldNames[0]}}}`;
        afmt = `{{FrontSide}}<hr id="answer">` + fieldNames.slice(1).map(f=>`{{${f}}}`).join('<hr>');
      } else {
        qfmt = `{{${fieldNames[0]||'Front'}}}`;
        afmt = `{{FrontSide}}<hr id="answer">`;
      }
      tmpls.push({name:`Card ${i+1}`, ord:i, qfmt, afmt, bqfmt:"", bafmt:"", did:null, bfont:"", bsize:0});
    }
    req = tmpls.map((t,i)=>[i, "any", [0]]);
  }

  return {
    id: mid, name: modelName, type: modelType, mod: Math.floor(Date.now()/1000), usn: 0, sortf: 0, did: deckId,
    tmpls,
    flds,
    css: ".card {\n font-family: arial;\n font-size: 20px;\n text-align: center;\n color: black;\n background-color: white;\n}\n",
    latexPre: "\\documentclass[12pt]{article}\n\\special{papersize=3in,5in}\n\\usepackage[utf8]{inputenc}\n\\usepackage{amssymb,amsmath}\n\\pagestyle{empty}\n\\setlength{\\parindent}{0in}\n\\begin{document}\n",
    latexPost: "\\end{document}",
    latexsvg: false,
    req,
    tags: [], vers: []
  };
}

// Sama kayak buildLegacyModel, tapi pake desain kartu ASLI (qfmt/afmt/css) yang
// berhasil ditangkap dari deck sumbernya, bukan bikin template generik baru.
function buildLegacyModelFromDesign(mid, deckId, modelName, fieldNames, m){
  const flds = fieldNames.map((name,i)=>({name, ord:i, sticky:false, rtl:false, font:"Arial", size:20, media:[]}));
  const tmpls = m.tmpls
    .map((t,i)=>({
      name: t.name || ('Card '+(i+1)),
      ord: (typeof t.ord === 'number' ? t.ord : i),
      qfmt: t.qfmt, afmt: t.afmt,
      bqfmt: t.bqfmt||'', bafmt: t.bafmt||'', did:null,
      bfont: t.bfont||'', bsize: t.bsize||0
    }))
    .sort((a,b)=> a.ord - b.ord);
  return {
    id: mid, name: modelName, type: m.type||0, mod: Math.floor(Date.now()/1000), usn: 0, sortf: 0, did: deckId,
    tmpls,
    flds,
    css: m.css && m.css.trim() ? m.css : ".card {\n font-family: arial;\n font-size: 20px;\n text-align: center;\n color: black;\n background-color: white;\n}\n",
    latexPre: "\\documentclass[12pt]{article}\n\\special{papersize=3in,5in}\n\\usepackage[utf8]{inputenc}\n\\usepackage{amssymb,amsmath}\n\\pagestyle{empty}\n\\setlength{\\parindent}{0in}\n\\begin{document}\n",
    latexPost: "\\end{document}",
    latexsvg: false,
    req: tmpls.map((t,i)=>[i, "any", [0]]),
    tags: [], vers: []
  };
}

function buildLegacyDeck(id, name, now, desc){
  return {id, mod:now, name, usn:0, lrnToday:[0,0], revToday:[0,0], newToday:[0,0], timeToday:[0,0], collapsed:false, browserCollapsed:false, desc: desc||"", dyn:0, conf:1, extendNew:0, extendRev:0};
}

function buildLegacyDconf(){
  return { "1": {
    id:1, mod:0, name:"Default", usn:0, maxTaken:60, autoplay:true, timer:0, replayq:true,
    new:{bury:false, delays:[1,10], initialFactor:2500, ints:[1,4,7], order:1, perDay:20},
    rev:{bury:false, ease4:1.3, ivlFct:1, maxIvl:36500, perDay:200, fuzz:0.05, minSpace:1},
    lapse:{delays:[10], leechAction:0, leechFails:8, minInt:1, mult:0},
    dyn:0
  }};
}

// FIX: pengganti fzstd.decompress(bytes) satu-shot. fzstd butuh tau ukuran hasil
// decompress di awal (dari header frame ATAU dari buffer yang kita kasih manual) --
// kalau frame-nya "streaming" (content size gak ketulis di header, yang ternyata
// beneran dipakai Anki buat media per-file), fzstd.decompress() bakal throw, atau
// lebih parah lagi diam-diam ngasih hasil KEPOTONG kalau kita paksa kasih buffer
// yang kekecilan. Solusinya: pakai API streaming (fzstd.Decompress) yang emang
// didesain buat nerima frame tanpa content-size di depan -- dia terima data
// sepotong demi sepotong (di sini kita kasih sekaligus) & ngumpulin chunk hasil
// decompress apa adanya, jadi ga pernah nebak-nebak ukuran buffer.
function zstdDecompressSafe(bytes){
  const chunks = [];
  const stream = new fzstd.Decompress(chunk => chunks.push(chunk));
  stream.push(bytes, true);
  if(chunks.length === 1) return chunks[0];
  let total = 0;
  for(const c of chunks) total += c.length;
  const out = new Uint8Array(total);
  let off = 0;
  for(const c of chunks){ out.set(c, off); off += c.length; }
  return out;
}

// Coba parse mapping media (skema baru simpan sebagai Protobuf MediaEntries: repeated {name, size, sha1}).
// Best-effort: kalau parsing gagal / hasilnya ga masuk akal, balikin null biar caller fallback aman.
function tryParseMediaProtobuf(bytes){
  let pos = 0;
  function readVarint(buf){
    let result = 0, shift = 0, b;
    do{
      b = buf[pos++];
      if(b === undefined) throw new Error('kehabisan byte pas baca varint');
      result += (b & 0x7f) * Math.pow(2, shift);
      shift += 7;
    } while(b & 0x80);
    return result;
  }
  const map = {};
  let idx = 0;
  while(pos < bytes.length){
    try{
      const tag = readVarint(bytes);
      const fieldNum = tag >>> 3, wireType = tag & 0x7;
      if(fieldNum === 1 && wireType === 2){
        const len = readVarint(bytes);
        const entryEnd = pos + len;
        let name = null;
        while(pos < entryEnd){
          const t2 = readVarint(bytes);
          const fn2 = t2 >>> 3, wt2 = t2 & 0x7;
          if(fn2 === 1 && wt2 === 2){
            const l2 = readVarint(bytes);
            name = new TextDecoder().decode(bytes.slice(pos, pos+l2));
            pos += l2;
          } else if(wt2 === 0){
            readVarint(bytes);
          } else if(wt2 === 2){
            const l3 = readVarint(bytes);
            pos += l3;
          } else { throw new Error('wiretype tak dikenal di dalam entry: '+wt2); }
        }
        pos = entryEnd;
        if(name) map[idx] = name;
        idx++;
      } else if(wireType === 0){
        readVarint(bytes);
      } else if(wireType === 2){
        const len = readVarint(bytes);
        pos += len;
      } else {
        throw new Error('wiretype tak dikenal di level atas: '+wireType);
      }
    }catch(e){
      // PENTING (fix): dulu satu error DI MANA PUN di 2500+ entry bikin SEMUA
      // mapping ke-buang (balik null -> caller pake '{}' -> semua nama file media
      // ilang, audio/gambar jadi gak kebaca sama sekali di Anki). Sekarang begitu
      // ketemu entry yang gagal di-decode, kita cuma STOP baca dari titik itu
      // (gak bisa lanjut karena batas entry berikutnya jadi gak jelas), tapi
      // entry-entry SEBELUMNYA yang udah berhasil ke-parse tetap dipertahankan &
      // dibalikin -- best-effort partial jauh lebih baik daripada kehilangan semua.
      console.warn('parse media protobuf berhenti di entry ke-'+idx+' (best-effort, entry sebelumnya tetap disimpan):', e);
      break;
    }
  }
  return Object.keys(map).length ? map : null;
}

async function rebuildAsLegacyApkg(){
  const now = Math.floor(Date.now()/1000);
  const nowMs = Date.now();

  // 1. Ambil cards & revlog apa adanya (kolomnya stabil lintas skema v11-v18)
  const cardsRows = readRowsSafe(state.db,
    "SELECT id,nid,did,ord,mod,usn,type,queue,due,ivl,factor,reps,lapses,left,odue,odid,flags,data FROM cards");
  const revlogRows = readRowsSafe(state.db,
    "SELECT id,cid,usn,ease,ivl,lastIvl,factor,time,type FROM revlog");

  // 2. Siapkan database baru dengan skema 11 (Legacy 2, kompatibel semua versi Anki)
  const db = new state.SQL.Database();
  db.run(`
    CREATE TABLE col (id integer primary key, crt integer not null, mod integer not null, scm integer not null, ver integer not null, dty integer not null, usn integer not null, ls integer not null, conf text not null, models text not null, decks text not null, dconf text not null, tags text not null);
    CREATE TABLE notes (id integer primary key, guid text not null, mid integer not null, mod integer not null, usn integer not null, tags text not null, flds text not null, sfld text not null, csum integer not null, flags integer not null, data text not null);
    CREATE TABLE cards (id integer primary key, nid integer not null, did integer not null, ord integer not null, mod integer not null, usn integer not null, type integer not null, queue integer not null, due integer not null, ivl integer not null, factor integer not null, reps integer not null, lapses integer not null, left integer not null, odue integer not null, odid integer not null, flags integer not null, data text not null);
    CREATE TABLE revlog (id integer primary key, cid integer not null, usn integer not null, ease integer not null, ivl integer not null, lastIvl integer not null, factor integer not null, time integer not null, type integer not null);
    CREATE TABLE graves (usn integer not null, oid integer not null, type integer not null);
    CREATE INDEX ix_notes_usn ON notes (usn);
    CREATE INDEX ix_cards_usn ON cards (usn);
    CREATE INDEX ix_revlog_usn ON revlog (usn);
    CREATE INDEX ix_cards_nid ON cards (nid);
    CREATE INDEX ix_cards_sched ON cards (did, queue, due);
    CREATE INDEX ix_revlog_cid ON revlog (cid);
    CREATE INDEX ix_notes_csum ON notes (csum);
  `);

  // 3. Rebuild models & decks JSON (nama & urutan field/deck dipertahankan, ID numeriknya juga sama
  //    persis dengan aslinya supaya relasi mid/did di notes & cards tetap valid)
  const usedMids = [...new Set(state.notes.map(n=>n.mid))];

  // PENTING: cards dipindah apa adanya (row[3] = ord = index template kartu itu).
  // Kalau note type-nya jatuh ke fallback generik (modelHasOriginalDesign gagal) dan
  // note type itu aslinya punya >1 template (misal custom note type ala "Basic and
  // reversed"), template generik yang cuma dibikin 1 ("Card 1") bikin kartu dengan
  // ord>=1 nunjuk ke template yang gak ada pas diimport ke Anki. Makanya kita itung
  // dulu jumlah template minimum yang dibutuhkan tiap mid dari ord tertinggi yang
  // beneran dipakai di tabel cards, biar fallback generik ikut bikin sejumlah itu.
  const nidToMid = {};
  state.notes.forEach(n=>{ nidToMid[n.id] = n.mid; });
  const templateCountByMid = {};
  cardsRows.forEach(row=>{
    const mid = nidToMid[row[1]];
    if(mid === undefined) return;
    const ord = row[3] || 0;
    templateCountByMid[mid] = Math.max(templateCountByMid[mid] || 1, ord + 1);
  });

  let models = {};
  usedMids.forEach(mid=>{
    const m = state.models[mid];
    if(!m) return;
    const fieldNames = m.flds && m.flds.length ? m.flds : ['Front','Back'];
    const deckIdForModel = Object.keys(state.decksMap)[0] || 1;
    const neededTemplateCount = templateCountByMid[mid] || 1;
    models[mid] = modelHasOriginalDesign(m)
      ? buildLegacyModelFromDesign(parseInt(mid), parseInt(deckIdForModel), m.name || 'Note Type', fieldNames, m)
      : buildLegacyModel(parseInt(mid), parseInt(deckIdForModel), m.name || 'Note Type', fieldNames, m.type || 0, neededTemplateCount);
    if(String(mid) === String(state.currentMid)){
      const cfg = state.cardBg;
      const hasBg = ahHasBgImage(cfg) && (cfg.front || cfg.back);
      applyCardBackgroundToModel(models[mid], hasBg ? cfg : { front:false, back:false });
    }
    applyWatermarkToModel(models[mid]);
  });
  if(Object.keys(models).length === 0){
    models['1'] = buildLegacyModel(1, 1, 'Basic', ['Front','Back']);
    applyWatermarkToModel(models['1']);
  }

  // PENTING: Anki nyocokin deck pas import berdasarkan ID, bukan nama — kalau ID
  // deck di file ini sama kayak deck yang UDAH ADA di koleksi Anki user (dan memang
  // begitu, karena file ini asalnya export dari deck itu sendiri), nama baru bakal
  // DIABAIKAN & tetep pake nama lama pas diimport. Makanya buat deck yang namanya
  // diganti, kasih ID BARU (belum pernah ada) biar Anki nganggep itu deck baru &
  // beneran pake nama custom-nya. Kartu-kartu yang tadinya nempel di ID lama ikut
  // dipindah ke ID baru (jadwal belajar aman, itu disimpen di tabel cards, bukan di deck).
  let deckIdRemap = {}; // old did (string) -> new did (number)
  let offset = 0;
  Object.keys(state.deckNameOverrides).forEach(id=>{
    const newName = state.deckNameOverrides[id];
    if(state.decksMap[id] && state.decksMap[id] !== newName){
      deckIdRemap[id] = Date.now() + (offset++);
    }
  });
  const remappedCardsRows = cardsRows.map(row=>{
    const oldDid = String(row[2]);
    if(deckIdRemap[oldDid] !== undefined){
      const newRow = row.slice();
      newRow[2] = deckIdRemap[oldDid];
      return newRow;
    }
    return row;
  });

  let decks = {};
  const usedDids = [...new Set(remappedCardsRows.map(r=>r[2]))];
  if(!state.decksMap['1'] && !deckIdRemap['1']) decks['1'] = buildLegacyDeck(1, 'Default', now, ahApplyDeckDesc(''));
  Object.keys(state.decksMap).forEach(id=>{
    const origDesc = (state.decksDescMap && state.decksDescMap[id]) || '';
    if(deckIdRemap[id] !== undefined){
      const newId = deckIdRemap[id];
      decks[String(newId)] = buildLegacyDeck(newId, state.deckNameOverrides[id], now, ahApplyDeckDesc(origDesc));
    } else {
      decks[id] = buildLegacyDeck(parseInt(id), state.decksMap[id], now, ahApplyDeckDesc(origDesc));
    }
  });
  usedDids.forEach(id=>{ if(!decks[id]) decks[id] = buildLegacyDeck(id, 'Imported Deck', now, ahApplyDeckDesc('')); });
  if(Object.keys(decks).length === 0) decks['1'] = buildLegacyDeck(1,'Default',now, ahApplyDeckDesc(''));

  const dconf = buildLegacyDconf();
  const firstDeckId = Object.keys(decks).find(id=>id!=='1') || Object.keys(decks)[0] || '1';
  const firstModelId = Object.keys(models)[0] || '1';
  const conf = {nextPos:1, estTimes:true, activeDecks:[parseInt(firstDeckId)], sortType:"noteFld", timeLim:0, sortBackwards:false, addToCur:true, curDeck:parseInt(firstDeckId), newBury:true, newSpread:0, dueCounts:true, curModel:String(firstModelId), collapseTime:1200};

  db.run("INSERT INTO col VALUES (1,?,?,?,11,0,0,0,?,?,?,?,'{}')", [
    now, nowMs, nowMs, JSON.stringify(conf), JSON.stringify(models), JSON.stringify(decks), JSON.stringify(dconf)
  ]);

  // 4. Pindahin notes (pakai flds yang sudah diedit), cards, & revlog apa adanya
  db.run('BEGIN TRANSACTION');
  const noteStmt = db.prepare("INSERT INTO notes VALUES (?,?,?,?,?,?,?,?,?,?,?)");
  state.notes.forEach(n=>{
    const flds = n.fields.join('\x1f');
    const sfld = stripHtml(n.fields[0] || '');
    const tags = injectWmIntoTags(n.tags);
    noteStmt.run([n.id, n.guid || ('n'+n.id.toString(36)), parseInt(n.mid), now, -1, tags, flds, sfld, simpleChecksumLocal(sfld), 0, '']);
  });
  noteStmt.free();

  if(remappedCardsRows.length){
    const cardStmt = db.prepare("INSERT INTO cards VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)");
    remappedCardsRows.forEach(row=> cardStmt.run(row));
    cardStmt.free();
  }
  if(revlogRows.length){
    const revStmt = db.prepare("INSERT INTO revlog VALUES (?,?,?,?,?,?,?,?,?)");
    revlogRows.forEach(row=> revStmt.run(row));
    revStmt.free();
  }
  db.run('COMMIT');

  const dbBytes = db.export();
  db.close();

  // 5. Susun ulang zip: database baru + media apa adanya dari zip asli (best-effort untuk mapping-nya)
  const newZip = new JSZip();
  newZip.file('collection.anki2', dbBytes);

  const mediaEntry = state.zip.file('media');
  let mediaJson = '{}';
  if(mediaEntry){
    let mediaBytes = await mediaEntry.async('uint8array');
    // FIX (bug utama ilangnya semua nama file media): di format anki21b, file
    // manifest 'media' ITU SENDIRI ternyata bisa ikut dikompres zstd, sama kayak
    // file media bernomor. Sebelumnya ini kelewat dicek -- protobuf parser dikasih
    // byte zstd mentah (bukan protobuf), langsung gagal di entry pertama, dan
    // caller fallback ke '{}' -> SEMUA 2500+ nama file (audio/gambar) ke-drop,
    // padahal isi filenya sendiri masih utuh. Deteksi & bongkar dulu di sini,
    // baru diproses sebagai JSON/protobuf seperti biasa.
    if(mediaBytes.length >= 4 && mediaBytes[0]===0x28 && mediaBytes[1]===0xb5 && mediaBytes[2]===0x2f && mediaBytes[3]===0xfd){
      try{ mediaBytes = zstdDecompressSafe(mediaBytes); }
      catch(e){
        console.warn('gagal decompress manifest media zstd (best-effort):', e);
        ahShowErrorPopup('Gagal membongkar daftar nama file media (manifest "media") dari deck ini.\nError: ' + (e.message||e));
      }
    }
    // Coba baca langsung sebagai JSON dulu (kalau ternyata bukan protobuf)
    try{
      const asText = new TextDecoder().decode(mediaBytes);
      JSON.parse(asText);
      mediaJson = asText;
    }catch(e){
      const parsed = tryParseMediaProtobuf(mediaBytes);
      if(parsed) mediaJson = JSON.stringify(parsed);
    }
  }
  newZip.file('media', mediaJson);

  // Salin semua file media bernomor (gambar/audio). PENTING (fix): di format Anki
  // terbaru (anki21b), file media individual ITU SENDIRI juga dikompres zstd
  // (bukan cuma collection-nya) -- kalau dicopy "apa adanya" tanpa dibongkar,
  // hasilnya bukan audio/gambar valid, jadi gak kebaca sama sekali oleh Anki
  // manapun walau nama filenya benar. Deteksi lewat magic number zstd (4 byte
  // pertama = 28 B5 2F FD) & bongkar pake fzstd (sama kayak collection.anki21b).
  const mediaFiles = Object.keys(state.zip.files).filter(name => /^\d+$/.test(name));
  const mediaDecompressFailed = [];
  for(const name of mediaFiles){
    let bytes = await state.zip.file(name).async('uint8array');
    if(bytes.length >= 4 && bytes[0]===0x28 && bytes[1]===0xb5 && bytes[2]===0x2f && bytes[3]===0xfd){
      try{ bytes = zstdDecompressSafe(bytes); }
      catch(e){
        console.warn('gagal decompress media zstd (best-effort), file='+name, e);
        mediaDecompressFailed.push(name);
      }
    }
    newZip.file(name, bytes);
  }
  if(mediaDecompressFailed.length){
    const contoh = mediaDecompressFailed.slice(0, 10).join(', ') + (mediaDecompressFailed.length > 10 ? ', ...' : '');
    ahShowErrorPopup(
      mediaDecompressFailed.length + ' dari ' + mediaFiles.length + ' file media (audio/gambar) gagal dibongkar & mungkin gak kebaca di Anki.\n' +
      'Nomor file: ' + contoh
    );
  }

  // Sisipin foto background (kalau ada & mode upload) sebagai file media baru + update mapping-nya.
  // Mode URL gak butuh ini sama sekali karena CSS-nya langsung nunjuk ke link internet.
  const bgCfg = state.cardBg;
  if(bgCfg.mode !== 'url' && bgCfg.dataUrl && bgCfg.bytes && (bgCfg.front || bgCfg.back)){
    let mediaMap = {};
    try{ mediaMap = JSON.parse(mediaJson); }catch(e){ mediaMap = {}; }
    const usedNums = mediaFiles.map(n=>parseInt(n)).concat(Object.keys(mediaMap).map(n=>parseInt(n))).filter(n=>!isNaN(n));
    const maxNum = Math.max(-1, ...usedNums);
    const key = String(maxNum+1);
    mediaMap[key] = bgCfg.mediaFilename;
    newZip.file(key, bgCfg.bytes);
    newZip.file('media', JSON.stringify(mediaMap));
  }

  return await newZip.generateAsync({type:'blob'});
}

function simpleChecksumLocal(str){
  str = str || '';
  let hash = 2166136261;
  for(let i=0;i<str.length;i++){ hash ^= str.charCodeAt(i); hash = Math.imul(hash, 16777619); }
  return hash >>> 0;
}
</script>
</body>
</html>
