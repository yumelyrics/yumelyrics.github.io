<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;600;700;800&family=Fredoka:wght@500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/papaparse/5.4.1/papaparse.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.10.2/sql-wasm.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fzstd@0.1.1/umd/index.js"></script>
<style>
:root{
  --pink: #ff8fc7;
  --pink-deep: #ff6bb3;
  --lavender: #b8a6ff;
  --mint: #8fe3c0;
  --cream: #fff8fb;
  --blush: #ffe8f3;
  --ink: #4a3358;
  --ink-soft: #8a7398;
  --white: #ffffff;
  --shadow: 0 8px 24px rgba(255,143,199,0.25);
  --radius: 22px;
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
html{ -webkit-text-size-adjust:100%; text-size-adjust:100%; }
body{
  margin:0;
  min-height:100vh;
  min-height:100svh;
  font-family:'Nunito', sans-serif;
  color:var(--ink);
  background:
    radial-gradient(circle at 10% 10%, #ffe0f0 0%, transparent 40%),
    radial-gradient(circle at 90% 20%, #e6ddff 0%, transparent 45%),
    radial-gradient(circle at 30% 90%, #d7fbe8 0%, transparent 40%),
    var(--cream);
  background-attachment: scroll;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
@media (min-width:641px){
  body{ background-attachment: fixed; }
}
.sparkle-layer{
  position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden;
}
.sparkle{
  position:absolute; font-size:18px; opacity:.55; animation:float 9s ease-in-out infinite;
}
@keyframes float{
  0%,100%{ transform: translateY(0) rotate(0deg); }
  50%{ transform: translateY(-26px) rotate(15deg); }
}
.wrap{ position:relative; z-index:1; max-width:980px; margin:0 auto; padding:28px 18px 80px; }

header.hero{
  display:flex; align-items:center; gap:18px; margin-bottom:26px; flex-wrap:wrap;
  background:var(--white); border-radius: 28px; padding:22px 26px;
  box-shadow: var(--shadow); border:3px solid #ffd3ea;
}
.mascot{ width:86px; height:86px; flex:none; }
.hero-text{ min-width:0; }
.hero-text h1{
  font-family:'Baloo 2', cursive; font-size:1.7rem; margin:0 0 4px;
  color:var(--pink-deep); letter-spacing:.3px;
}
.hero-text p{ margin:0; color:var(--ink-soft); font-weight:700; font-size:.95rem; }

.speech{
  position:relative; background:var(--blush); border-radius:16px; padding:10px 14px;
  font-weight:700; font-size:.85rem; color:var(--pink-deep); margin-left:auto; max-width:230px;
  border:2px dashed var(--pink);
}
.speech:after{
  content:""; position:absolute; left:-9px; top:50%; transform:translateY(-50%);
  border:8px solid transparent; border-right-color:var(--blush);
}

.card{
  background:var(--white); border-radius: var(--radius); padding:24px;
  box-shadow: var(--shadow); border:3px solid #ffe3f2; margin-bottom:22px;
}
.card h2{
  font-family:'Baloo 2', cursive; font-size:1.15rem; margin:0 0 14px; color:var(--ink);
  display:flex; align-items:center; gap:8px;
}
.card h2.collapsible-header{
  cursor:pointer; user-select:none; margin-bottom:0; padding:2px 0;
}
.card h2.collapsible-header:hover{ color:var(--pink-deep); }
.collapsible-header .collapse-chevron{
  margin-left:auto; font-size:1rem; color:var(--pink-deep); transition:transform .25s ease; flex:none;
}
.collapsible-header.open .collapse-chevron{ transform:rotate(90deg); }
.collapsible-header .collapse-hint{
  font-size:.68rem; font-weight:700; color:var(--ink-soft); text-transform:none; letter-spacing:0; margin-left:4px;
}
.collapsible-body{ margin-top:14px; }
.badge{
  display:inline-block; background:var(--lavender); color:#fff; font-size:.65rem;
  font-weight:800; padding:3px 10px; border-radius:999px; font-family:'Nunito';
}

/* dropzone */
.dropzone{
  border:3px dashed var(--pink); border-radius:20px; padding:38px 20px; text-align:center;
  cursor:pointer; background:linear-gradient(160deg,#fff,#fff0f7); transition:.2s;
  font-weight:700; color:var(--pink-deep);
}
.dropzone.drag{ background:var(--blush); transform:scale(1.01); }
.dropzone small{ display:block; margin-top:6px; color:var(--ink-soft); font-weight:600; }
.dropzone input{ display:none; }
.dz-emoji{ font-size:2.6rem; display:block; margin-bottom:8px; }

/* buttons */
.btn{
  font-family:'Baloo 2', cursive; border:none; cursor:pointer; border-radius:999px;
  padding:10px 20px; font-size:.9rem; font-weight:700; color:#fff;
  background:linear-gradient(135deg, var(--pink), var(--pink-deep));
  box-shadow:0 5px 0 #d6559a; transition:.12s; letter-spacing:.2px;
  min-height:44px;
}
.btn:hover{ transform: translateY(-2px); }
.btn:active{ transform: translateY(2px); box-shadow:0 2px 0 #d6559a; }
.btn.alt{ background:linear-gradient(135deg, var(--lavender), #9a82ff); box-shadow:0 5px 0 #7c63e0; }
.btn.mint{ background:linear-gradient(135deg, var(--mint), #5fcf9d); box-shadow:0 5px 0 #3fae80; color:#0e4230; }
.btn.ghost{ background:#fff; color:var(--pink-deep); border:2px solid var(--pink); box-shadow:0 4px 0 #ffd3ea; }
.btn:disabled{ opacity:.45; cursor:not-allowed; transform:none; }
.btn-row{ display:flex; flex-wrap:wrap; gap:10px; margin-top:6px; }
.btn small{ display:block; font-family:'Nunito'; font-weight:600; font-size:.65rem; opacity:.85; }

select, textarea, input[type=text]{
  font-family:'Nunito'; border:2px solid #ffd3ea; border-radius:14px; padding:10px 12px;
  font-weight:700; color:var(--ink); background:#fff; width:100%;
}
select:focus, textarea:focus, input:focus{ outline:2px solid var(--pink); }
label.field-label{ font-weight:800; font-size:.8rem; color:var(--ink-soft); display:block; margin-bottom:5px; }
.deck-name-row{ margin-bottom:10px; }
.deck-name-row:last-child{ margin-bottom:0; }
.deck-name-row .deck-name-orig{ font-size:.72rem; font-weight:700; color:var(--ink-soft); margin-bottom:3px; opacity:.75; }

input[type=range]{
  -webkit-appearance:none; appearance:none; width:100%; height:8px; border-radius:999px;
  background:linear-gradient(90deg, var(--pink), var(--lavender)); outline:none; margin-top:4px; cursor:pointer;
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none; appearance:none; width:20px; height:20px; border-radius:50%;
  background:#fff; border:3px solid var(--pink-deep); cursor:pointer; box-shadow:0 2px 6px rgba(0,0,0,.2);
}
input[type=range]::-moz-range-thumb{
  width:20px; height:20px; border-radius:50%; background:#fff; border:3px solid var(--pink-deep); cursor:pointer; box-shadow:0 2px 6px rgba(0,0,0,.2);
}

.bg-preview-wrap{ display:flex; flex-direction:column; align-items:center; gap:12px; margin-bottom:16px; }
.bg-preview-card{
  position:relative; width:100%; max-width:480px; aspect-ratio:3/2; border-radius:22px; overflow:hidden;
  border:3px solid #ffd3ea; background:#fdf3f8; cursor:grab; user-select:none; -webkit-user-select:none;
  display:flex; align-items:center; justify-content:center; box-shadow:var(--shadow); touch-action:none;
  transition:aspect-ratio .25s, max-width .25s;
}
.bg-preview-card:active{ cursor:grabbing; }
.bg-preview-card.device-mobile{ max-width:230px; aspect-ratio:9/16; }
.bg-preview-device-badge{
  position:absolute; top:10px; right:10px; z-index:3; font-family:'Baloo 2', cursive; font-weight:700;
  font-size:.68rem; color:#fff; background:rgba(74,51,88,.65); padding:4px 11px; border-radius:999px;
  letter-spacing:.3px; pointer-events:none;
}
.bg-preview-img{
  position:absolute; inset:0; background-size:cover; background-position:center; background-repeat:no-repeat;
  opacity:.9; transition:opacity .18s, filter .18s;
}
.bg-preview-overlay{ position:absolute; inset:0; background:rgba(0,0,0,.25); transition:background .18s; }
.bg-preview-content{ position:relative; z-index:2; text-align:center; padding:22px; max-width:88%; }
.bg-preview-side-label{
  display:inline-block; font-family:'Baloo 2', cursive; font-weight:700; font-size:.72rem; letter-spacing:.5px;
  text-transform:uppercase; color:#fff; background:rgba(0,0,0,.4); padding:4px 14px; border-radius:999px; margin-bottom:12px;
  text-shadow:none;
}
.bg-preview-text{
  font-family:Arial, sans-serif; font-size:1.1rem; font-weight:700; color:#fff; line-height:1.55;
  text-shadow:0 1px 3px rgba(0,0,0,.9), 0 0 14px rgba(0,0,0,.6), 0 0 2px rgba(0,0,0,1);
  max-height:170px; overflow:hidden;
}
.bg-preview-hint{
  position:absolute; bottom:10px; left:50%; transform:translateX(-50%); z-index:2;
  font-size:.66rem; font-weight:700; color:#fff; background:rgba(0,0,0,.4); padding:4px 12px; border-radius:999px; opacity:.9;
}
.bg-preview-card.empty .bg-preview-img,
.bg-preview-card.empty .bg-preview-overlay{ opacity:0 !important; }
.bg-preview-card.empty .bg-preview-hint{ background:#ffe1ef; color:var(--pink-deep); }
.bg-preview-side-label.applied{ background:rgba(20,150,95,.65); }

.bg-preview-dots{ display:flex; gap:8px; }
.bg-preview-dot{
  width:10px; height:10px; border-radius:50%; border:none; background:#ffd3ea; cursor:pointer; padding:0; transition:.15s;
}
.bg-preview-dot.active{ background:var(--pink-deep); width:28px; border-radius:999px; }
.btn.applied{ box-shadow:0 0 0 3px var(--mint) inset, 0 5px 0 #7c63e0; }

/* ---- template & styling editor ---- */
.tpl-editor{
  width:100%; min-height:220px; border-radius:16px; border:2px solid #ffd3ea; padding:14px;
  font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace; font-size:.82rem;
  line-height:1.55; color:var(--ink); background:#fffcfe; resize:vertical; tab-size:2;
}
.tpl-editor:focus{ outline:none; border-color:var(--pink-deep); }
.tpl-preview-wrap{ margin-top:16px; }
.tpl-preview-label{ font-family:'Baloo 2',cursive; font-weight:700; color:var(--pink-deep); font-size:.85rem; margin-bottom:8px; }
.tpl-preview-frame{
  width:100%; height:260px; border-radius:16px; border:3px solid #ffd3ea; background:#fff;
  box-shadow:var(--shadow);
}
.tpl-field-hint{
  display:inline-block; background:var(--blush); color:var(--pink-deep); font-weight:700; font-size:.7rem;
  padding:2px 9px; border-radius:999px; margin:2px 3px 0 0; cursor:pointer; border:none;
}
.tpl-field-hint:hover{ background:var(--pink); color:#fff; }

.grid2{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
@media (max-width:640px){ .grid2{ grid-template-columns:1fr; } }

.field-checks{ display:flex; flex-wrap:wrap; gap:8px; }
.field-chip{
  display:inline-flex; align-items:center; gap:7px; background:#fff; border:2px solid #ffd3ea;
  border-radius:999px; padding:8px 14px; font-weight:700; font-size:.8rem; color:var(--ink);
  cursor:pointer; transition:.15s; user-select:none;
}
.field-chip:hover{ border-color:var(--pink); }
.field-chip input{ accent-color:var(--pink-deep); width:15px; height:15px; cursor:pointer; margin:0; }
.field-chip.active{ background:var(--blush); border-color:var(--pink-deep); color:var(--pink-deep); }
.field-lock{
  font-size:.85rem; opacity:.4; cursor:pointer; line-height:1; padding:2px;
}
.field-lock:hover{ opacity:.8; }
.field-lock.active{ opacity:1; }
.field-instr.active{ opacity:1; filter: drop-shadow(0 0 0 transparent); }
.field-instr.active::after{ content:''; display:inline-block; width:6px; height:6px; border-radius:50%; background:var(--mint,#5fcf9d); margin-left:2px; vertical-align:top; }

.field-mini-label{
  font-size:.66rem; font-weight:800; color:var(--pink-deep); text-transform:uppercase; letter-spacing:.4px;
  margin:0 0 3px; opacity:.85;
}
.edit-cell .field-mini-label:not(:first-child){ margin-top:12px; padding-top:10px; border-top:1px dashed #ffd3ea; }

.stats{ display:flex; gap:10px; flex-wrap:wrap; margin-top:14px; }
.stat-pill{
  background:var(--blush); border-radius:14px; padding:8px 14px; font-weight:800; font-size:.8rem;
  color:var(--pink-deep); border:2px solid #ffd3ea;
}

/* table */
.table-wrap{ max-height:520px; overflow:auto; border-radius:16px; border:2px solid #ffe3f2; }
table{ width:100%; border-collapse:collapse; font-size:.85rem; }
thead th{
  position:sticky; top:0; background:var(--pink-deep); color:#fff; font-family:'Baloo 2';
  text-align:left; padding:10px 12px; z-index:2; font-weight:700;
}
tbody tr:nth-child(even){ background:#fff8fb; }
tbody tr:hover{ background:#ffeef7; }
td{ padding:8px 12px; vertical-align:top; border-bottom:1px solid #ffe9f3; }
.id-cell{ color:var(--ink-soft); font-weight:800; width:64px; }
.preview-cell{ color:var(--ink-soft); max-width:220px; }
.preview-cell .mini{
  display:block; font-size:.78rem; line-height:1.4;
}
.edit-cell{ min-width:260px; }
.edit-cell textarea{
  min-height:54px; resize:vertical; border-radius:10px; font-size:.85rem; font-weight:600;
}
.edit-cell textarea.dirty{ border-color:var(--mint); background:#f2fff9; }
.row-dot{ width:9px; height:9px; border-radius:50%; display:inline-block; margin-right:6px; }
.row-dot.clean{ background:#e0d5ea; }
.row-dot.dirty{ background:#5fcf9d; }

.modal-bg{
  position:fixed; inset:0; background:rgba(74,51,88,.45); display:none; align-items:center; justify-content:center;
  z-index:50; padding:20px;
}
.modal-bg.show{ display:flex; }
.modal{
  background:#fff; border-radius:24px; padding:22px; max-width:640px; width:100%;
  max-height:82vh; overflow:auto; box-shadow:0 20px 50px rgba(0,0,0,.25); border:3px solid var(--pink);
}
.modal h3{ font-family:'Baloo 2'; color:var(--pink-deep); margin-top:0; }
.modal textarea{ min-height:260px; font-family:'Fredoka', monospace; font-size:.8rem; }
.modal-actions{ display:flex; justify-content:flex-end; gap:10px; margin-top:14px; }

.toast{
  position:fixed; bottom:26px; left:50%; transform:translateX(-50%) translateY(20px);
  background:var(--ink); color:#fff; padding:12px 22px; border-radius:999px; font-weight:700;
  font-family:'Baloo 2'; box-shadow:0 10px 30px rgba(0,0,0,.25); opacity:0; transition:.25s; z-index:80;
  display:flex; align-items:center; gap:8px;
}
.toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

.footer-note{ text-align:center; color:var(--ink-soft); font-size:.78rem; margin-top:30px; font-weight:700; line-height:1.6; }
.hidden{ display:none !important; }

.wm-badge{
  position:fixed; right:16px; bottom:16px; z-index:70;
  display:inline-flex; align-items:center; gap:5px;
  background:rgba(255,255,255,.88); backdrop-filter:blur(4px);
  border:2px solid #ffd3ea; border-radius:999px; padding:7px 14px;
  font-family:'Baloo 2', cursive; font-size:.72rem; font-weight:700; color:var(--pink-deep);
  text-decoration:none; box-shadow:0 4px 14px rgba(255,143,199,.28);
  transition:.15s; letter-spacing:.2px;
}
.wm-badge span{ color:var(--lavender); }
.wm-badge:hover{ transform:translateY(-2px); border-color:var(--pink-deep); }
@media (max-width:640px){
  .wm-badge{ right:10px; bottom:10px; font-size:.62rem; padding:6px 11px; }
}

.loader{
  display:inline-flex; gap:4px; align-items:center;
}
.loader span{
  width:7px; height:7px; border-radius:50%; background:var(--pink-deep); animation:bounce 1s infinite ease-in-out;
}
.loader span:nth-child(2){ animation-delay:.15s; }
.loader span:nth-child(3){ animation-delay:.3s; }
@keyframes bounce{ 0%,80%,100%{ transform:scale(.5); opacity:.5;} 40%{ transform:scale(1); opacity:1; } }

/* Progress bar animasi buat fitur Auto-Translate/Jelasin Kosakata -- nunjukkin kartu ke berapa
   yang lagi diproses AI-nya, plus shimmer bar biar keliatan jelas "lagi jalan" (bukan macet). */
.at-progress-track{
  width:100%; height:9px; border-radius:999px; background:var(--blush); overflow:hidden; margin-top:6px;
}
.at-progress-fill{
  height:100%; border-radius:999px; width:0%;
  background:linear-gradient(90deg, var(--pink-deep), var(--lavender), var(--pink-deep));
  background-size:200% 100%;
  transition:width .3s ease;
  animation: ah-progress-shimmer 1.3s linear infinite;
}
.at-progress-fill.done{ animation:none; background:var(--mint); background-size:auto; }
@keyframes ah-progress-shimmer{ 0%{background-position:0% 50%;} 100%{background-position:200% 50%;} }

.step-num{
  display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px;
  border-radius:50%; background:var(--pink); color:#fff; font-size:.7rem; font-weight:800; margin-right:6px;
}

/* ============ MOBILE FRIENDLY & PERFORMANCE ============ */
@media (max-width:640px){
  .wrap{ padding:16px 12px 64px; }

  header.hero{ gap:12px; padding:16px 16px; border-radius:22px; margin-bottom:16px; }
  .mascot{ width:56px; height:56px; }
  .hero-text h1{ font-size:1.25rem; }
  .hero-text p{ font-size:.8rem; }
  .speech{ margin-left:0; max-width:100%; font-size:.78rem; flex:1 0 100%; }
  .speech:after{ display:none; }

  .card{ padding:16px; border-radius:18px; margin-bottom:14px; }
  .card h2{ font-size:1rem; }
  .collapsible-header .collapse-hint{ display:none; }

  .dropzone{ padding:26px 14px; }
  .dz-emoji{ font-size:2rem; }
  .dropzone small{ font-size:.78rem; }

  .btn-row{ gap:8px; }
  .btn{ padding:10px 16px; font-size:.82rem; flex:1 1 auto; text-align:center; }
  .btn small{ font-size:.6rem; }

  .table-wrap{ max-height:420px; border-radius:12px; }
  table{ font-size:.78rem; }
  thead th{ padding:8px 8px; }
  td{ padding:6px 8px; }
  .preview-cell{ max-width:120px; }
  .edit-cell{ min-width:180px; }
  .edit-cell textarea{ min-height:46px; font-size:.8rem; }

  .modal{ padding:16px; border-radius:18px; max-height:88vh; }
  .modal textarea{ min-height:180px; }

  .toast{ bottom:16px; padding:10px 16px; font-size:.85rem; max-width:90vw; }

  .footer-note{ font-size:.72rem; margin-top:20px; }

  .bg-preview-card{ max-width:100%; border-radius:18px; }
  .bg-preview-text{ font-size:.92rem; max-height:130px; }
  .bg-preview-side-label{ font-size:.64rem; padding:3px 11px; }
  .bg-preview-content{ padding:16px; }
  .bg-preview-hint{ font-size:.6rem; }
}

@media (max-width:380px){
  .hero-text h1{ font-size:1.1rem; }
  .btn{ font-size:.78rem; padding:9px 14px; }
}

/* Kurangi jumlah elemen dekoratif berat & animasi di layar kecil biar tetap ringan/mulus */
@media (max-width:640px){
  .sparkle:nth-child(n+10){ display:none; }
}

/* Hormati preferensi pengguna yang memilih mengurangi animasi (aksesibilitas + hemat baterai) */
@media (prefers-reduced-motion: reduce){
  .sparkle{ animation:none; opacity:.35; }
  .btn, .btn:hover, .btn:active{ transform:none; }
  *{ scroll-behavior:auto !important; }
}
</style>
</head>
<body>
<script>
(function(){
  // Domain lock: cuma nampilin tool ini kalau diakses dari domain resmi.
  // Catatan: ini proteksi client-side doang, gampang dilewatin kalau orangnya
  // ngerti buka View Source & hapus baris ini — cuma nyegah copas kasual.
  var allowedHosts = ['yumelyrics.my.id', 'www.yumelyrics.my.id', 'yumelyrics.github.io'];
  var host = location.hostname;
  if(host && allowedHosts.indexOf(host) === -1){
    var ov = document.createElement('div');
    ov.style.cssText = 'position:fixed;inset:0;z-index:999999;background:#1a0e17;color:#fff;'
      + 'display:flex;flex-direction:column;align-items:center;justify-content:center;'
      + 'text-align:center;padding:30px;font-family:Arial,sans-serif;';
    ov.innerHTML =
      '<div style="font-size:46px;margin-bottom:12px;">🔒</div>'
      + '<h1 style="font-size:19px;margin:0 0 10px;font-weight:800;">AnkiHoney cuma bisa dipakai di situs resminya</h1>'
      + '<p style="opacity:.75;max-width:420px;margin:0 0 22px;font-size:14px;line-height:1.5;">Kamu lagi buka salinan yang di-hosting di luar situs asli. Buka versi resminya di sini ya:</p>'
      + '<a href="https://yumelyrics.my.id" style="background:linear-gradient(90deg,#ff5f6d,#a855f7);color:#fff;'
      + 'padding:11px 26px;border-radius:999px;font-weight:700;text-decoration:none;font-size:14px;">yumelyrics.my.id</a>';
    var lock = function(){ document.body.appendChild(ov); };
    if(document.body) lock(); else document.addEventListener('DOMContentLoaded', lock);
  }
})();
</script>

<div class="sparkle-layer" id="sparkleLayer"></div>

<div class="wrap">

  <header class="hero">
    <svg class="mascot" viewBox="0 0 100 100" id="mascotSvg">
      <ellipse cx="50" cy="88" rx="26" ry="6" fill="#ffd3ea" opacity=".6"/>
      <path d="M28 30 L20 8 L40 22 Z" fill="#ffb6d9"/>
      <path d="M72 30 L80 8 L60 22 Z" fill="#ffb6d9"/>
      <path d="M31 28 L25 14 L38 24 Z" fill="#fff"/>
      <path d="M69 28 L75 14 L62 24 Z" fill="#fff"/>
      <circle cx="50" cy="55" r="34" fill="#fff" stroke="#ffb6d9" stroke-width="3"/>
      <circle cx="37" cy="53" r="5" fill="#4a3358" id="eyeL"/>
      <circle cx="63" cy="53" r="5" fill="#4a3358" id="eyeR"/>
      <circle cx="38.5" cy="51.5" r="1.4" fill="#fff"/>
      <circle cx="64.5" cy="51.5" r="1.4" fill="#fff"/>
      <ellipse cx="27" cy="62" rx="6" ry="4" fill="#ffb6d9" opacity=".7"/>
      <ellipse cx="73" cy="62" rx="6" ry="4" fill="#ffb6d9" opacity=".7"/>
      <path d="M44 66 Q50 71 56 66" stroke="#4a3358" stroke-width="2.4" fill="none" stroke-linecap="round"/>
      <path d="M20 44 Q14 40 18 34" stroke="#ffb6d9" stroke-width="2" fill="none" stroke-linecap="round"/>
      <path d="M80 44 Q86 40 82 34" stroke="#ffb6d9" stroke-width="2" fill="none" stroke-linecap="round"/>
    </svg>
    <div class="hero-text">
      <h1>AnkiHoney ♡</h1>
      <p>Ambil field, terjemahin, suntik balik ke .apkg~</p>
    </div>
    <div class="speech" id="mascotSpeech">Yuk upload deck kamu dulu, nya~ 🍡</div>
  </header>

  <!-- STEP 1: UPLOAD -->
  <div class="card" id="uploadCard">
    <h2><span class="step-num">1</span> Upload Deck .apkg</h2>
    <div class="dropzone" id="dropzone">
      <span class="dz-emoji">📦</span>
      Seret file .apkg ke sini, atau klik untuk pilih
      <small>Support semua format Anki — klasik (anki2/anki21) maupun format terbaru yang zstd-compressed (anki21b) ✨</small>
      <input type="file" id="fileInput" accept=".apkg" />
    </div>
    <div id="uploadStatus" style="margin-top:12px; font-weight:700; color:var(--ink-soft);"></div>
    <div id="formatWarning" class="hidden" style="margin-top:12px; background:#fff6da; border:2px solid #ffd97a; border-radius:14px; padding:12px 16px; font-weight:700; font-size:.82rem; color:#8a6a1f;"></div>
  </div>

  <!-- STEP 2: PILIH NOTE TYPE + FIELD -->
  <div class="card hidden" id="selectCard">
    <h2><span class="step-num">2</span> Pilih Note Type &amp; Field</h2>
    <div class="grid2">
      <div>
        <label class="field-label">Note Type</label>
        <select id="modelSelect"></select>
      </div>
      <div>
        <label class="field-label">Field yang mau diterjemahin <span style="font-weight:600; color:var(--ink-soft); text-transform:none;">(boleh centang lebih dari 1 buat digabung)</span></label>
        <div class="field-checks" id="fieldChecks"></div>
        <small style="display:block; margin-top:6px; color:var(--ink-soft); font-weight:600; font-size:.7rem;">🔒/🔓 di tiap field = tandain field itu SUMBER (misal Kanji asli yang cuma dipakai AI buat konteks & harusnya gak berubah) — beda sama field target yang emang diisi hasil terjemahan. Ini bikin tool bisa ngingetin kalau field sumber ternyata ikut berubah pas paste (tanda ke-translate/ke-swap gak sengaja).</small>
      </div>
    </div>
    <div class="stats" id="statsRow"></div>
  </div>

  <!-- STEP 2.5: CARD BACKGROUND -->
  <div class="card hidden" id="bgCard">
    <h2 class="collapsible-header" id="bgCardHeader" data-target="bgCardBody"><span class="step-num">✨</span> Background Kartu <span class="badge" style="background:var(--mint); color:#0e4230;">Opsional</span><span class="collapse-hint">klik buat buka/tutup</span><span class="collapse-chevron">▸</span></h2>
    <div class="collapsible-body hidden" id="bgCardBody">
    <p style="font-weight:700; color:var(--ink-soft); font-size:.82rem; margin-top:0;">Ganti background tampilan kartu di Anki pakai foto sendiri. Berlaku buat note type <b id="bgModelName">-</b> yang lagi dipilih di atas.</p>

    <div style="background:#fff8e6; border:2px dashed #ffcf6b; border-radius:14px; padding:12px 14px; margin-bottom:14px; font-size:.78rem; font-weight:700; color:#8a6a1a; line-height:1.5;">
      ⚠️ <b>Penting kalau note type ini udah dipakai di deck lain</b> yang udah ada duluan di Anki kamu (misal note type yang sama dipakai bareng-bareng di banyak deck): Anki cuma nge-update tampilan note type pas import kalau ada perubahan baru yang kedeteksi. Tool ini udah otomatis nanganin itu, tapi kalau setelah import background <b>tetep</b> gak muncul, biasanya karena Anki nyimpen versi lama note type-nya. Coba <b>hapus dulu deck versi lama dari Anki</b> (atau note type-nya lewat Manage Note Types) sebelum import ulang file yang baru, biar gak bentrok sama versi lama.
    </div>

    <div class="btn-row" style="margin-bottom:12px;">
      <button type="button" class="btn ghost applied" id="bgModeUpload" style="flex:1;">📤 Upload Foto</button>
      <button type="button" class="btn ghost" id="bgModeUrl" style="flex:1;">🔗 Pakai Link Gambar</button>
    </div>

    <div class="dropzone" id="bgDropzone" style="padding:22px 16px;">
      <span class="dz-emoji">🖼️</span>
      Pilih atau seret foto ke sini
      <small>JPG/PNG, otomatis dikompres biar file .apkg tetap ringan</small>
      <input type="file" id="bgFileInput" accept="image/*" />
    </div>
    <small style="display:block; margin:6px 2px 4px; color:var(--ink-soft); font-weight:600; font-size:.72rem;">
      ✅ Foto ikut kesimpen di dalam .apkg, jadi tetep muncul walau offline. Kalau note type ini udah kepake di deck lain yang lebih lama di Anki kamu, baca peringatan kuning di atas dulu ya.
    </small>

    <div class="hidden" id="bgUrlWrap" style="margin-bottom:4px;">
      <label class="field-label">Link Gambar (harus bisa diakses publik dari internet)</label>
      <input type="text" id="bgUrlInput" placeholder="https://contoh.com/foto-kamu.jpg" />
      <small style="display:block; margin-top:6px; color:var(--ink-soft); font-weight:600; font-size:.72rem;">
        ⚠️ Foto harus tetap online selamanya biar background gak ilang pas dipelajari. Gambar juga gak ikut kesimpen ke dalam .apkg (jadi butuh internet nyala pas belajar di Anki), tapi cara ini paling anti-gagal karena gak nyentuh media/note type sama sekali.
      </small>
    </div>

    <div class="hidden" id="bgControls" style="margin-top:16px;">
      <div class="bg-preview-wrap">
        <div class="bg-preview-card empty" id="bgPreviewCard">
          <div class="bg-preview-img" id="bgPreviewImg"></div>
          <div class="bg-preview-overlay" id="bgPreviewOverlay"></div>
          <span class="bg-preview-device-badge" id="bgPreviewDeviceBadge">🖥️ Desktop</span>
          <div class="bg-preview-content">
            <span class="bg-preview-side-label" id="bgPreviewSideLabel">Depan (Front)</span>
            <div class="bg-preview-text" id="bgPreviewText">Contoh teks kartu</div>
          </div>
          <div class="bg-preview-hint">🖐️ Seret gambar buat atur posisi · ketuk buat lihat sisi lain</div>
        </div>
        <div class="bg-preview-dots">
          <button type="button" class="bg-preview-dot active" id="dotFront" title="Depan"></button>
          <button type="button" class="bg-preview-dot" id="dotBack" title="Belakang"></button>
        </div>
      </div>

      <div class="btn-row" style="margin-bottom:16px;">
        <button class="btn alt" id="btnApplyFront">🃏 Terapkan ke Depan</button>
        <button class="btn alt" id="btnApplyBack">🃏 Terapkan ke Belakang</button>
        <button class="btn ghost" id="btnClearBg">🗑️ Hapus Background</button>
      </div>


      <div class="grid2">
        <div>
          <label class="field-label">Mode Tampilan Foto</label>
          <select id="bgFit">
            <option value="cover">Penuhi (Cover)</option>
            <option value="contain">Pas / Utuh (Contain)</option>
            <option value="stretch">Regangkan (Stretch)</option>
          </select>
        </div>
        <div>
          <label class="field-label">Lagi Atur Posisi Buat</label>
          <div class="btn-row" style="gap:6px;">
            <button type="button" class="btn ghost applied" id="bgDeviceDesktop" style="flex:1; font-size:.72rem; padding:9px 6px;">🖥️ Desktop</button>
            <button type="button" class="btn ghost" id="bgDeviceMobile" style="flex:1; font-size:.72rem; padding:9px 6px;">📱 Mobile</button>
          </div>
        </div>
      </div>

      <div style="margin-top:10px; display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap;">
        <small style="color:var(--ink-soft); font-weight:600; font-size:.72rem; flex:1; min-width:220px;">
          🖐️ <b id="bgPosReadout">Posisi: 50%, 50%</b> — seret langsung di gambar preview di atas ke arah mana aja buat pas-in posisinya. Posisi <b>Desktop</b> &amp; <b>Mobile</b> kesimpen <b>terpisah</b>, jadi pindah tab di atas buat atur masing-masing device — pas dibuka di Anki HP, foto otomatis pake posisi tab Mobile.
        </small>
        <button type="button" class="btn ghost" id="btnResetBgPos" style="font-size:.72rem; white-space:nowrap;">↺ Reset ke Tengah</button>
      </div>

      <div style="margin-top:16px;">
        <label class="field-label">Kecerahan Foto (Opacity) — <span id="bgOpacityVal">90</span>%</label>
        <input type="range" id="bgOpacity" min="10" max="100" value="90" />
      </div>
      <div style="margin-top:12px;">
        <label class="field-label">Overlay Gelap (biar teks tetep kebaca) — <span id="bgOverlayVal">25</span>%</label>
        <input type="range" id="bgOverlay" min="0" max="80" value="25" />
      </div>
      <div style="margin-top:12px;">
        <label class="field-label">Blur — <span id="bgBlurVal">0</span>px</label>
        <input type="range" id="bgBlur" min="0" max="12" value="0" />
      </div>

      <div style="margin-top:18px; padding-top:14px; border-top:2px dashed #ffd3ea;">
        <label class="field-label" style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
          <span>✍️ Outline / Shadow Teks Vocab <span style="font-weight:600; color:var(--ink-soft); text-transform:none;">(biar kutipan tetep kebaca)</span></span>
          <label style="display:inline-flex; align-items:center; gap:6px; font-weight:700; font-size:.72rem; cursor:pointer; text-transform:none;">
            <input type="checkbox" id="bgTextFxEnabled" checked style="width:16px; height:16px; cursor:pointer;" />
            Aktif
          </label>
        </label>
        <small style="display:block; margin:2px 2px 10px; color:var(--ink-soft); font-weight:600; font-size:.72rem;">
          Nambahin outline/bayangan gelap-terang di sekitar teks yang di-<b>bold</b> di field kamu, biar kosakata yang dikutip tetep gampang dibaca walaupun foto background-nya diganti-ganti.
        </small>

        <div id="bgTextFxControls">
          <div class="grid2">
            <div>
              <label class="field-label">Gaya</label>
              <select id="bgTextFxStyle">
                <option value="glow">Glow (bayangan lembut)</option>
                <option value="outline">Outline (garis tegas)</option>
              </select>
            </div>
            <div>
              <label class="field-label">Berlaku Untuk</label>
              <select id="bgTextFxTarget">
                <option value="bold">Vocab yang di-bold aja</option>
                <option value="all">Semua teks di kartu</option>
              </select>
            </div>
          </div>

          <div class="grid2" style="margin-top:12px; align-items:end;">
            <div>
              <label class="field-label">Warna — <span id="bgTextFxColorVal">#000000</span></label>
              <input type="color" id="bgTextFxColor" value="#000000" style="width:100%; height:38px; border-radius:10px; border:2px solid #ffd3ea; cursor:pointer; padding:2px; background:#fff;" />
            </div>
            <div class="btn-row" style="margin:0; gap:6px;">
              <button type="button" class="btn ghost" id="bgTextFxPresetBlack" style="flex:1; padding:8px 4px; font-size:.7rem;">⚫ Hitam</button>
              <button type="button" class="btn ghost" id="bgTextFxPresetWhite" style="flex:1; padding:8px 4px; font-size:.7rem;">⚪ Putih</button>
            </div>
          </div>

          <div style="margin-top:12px;">
            <label class="field-label">Ketebalan — <span id="bgTextFxStrengthVal">3</span></label>
            <input type="range" id="bgTextFxStrength" min="1" max="6" value="3" />
          </div>

          <div style="display:flex; gap:10px; margin-top:14px; flex-wrap:wrap;">
            <div style="flex:1; min-width:130px; border-radius:14px; padding:20px 10px; text-align:center; background:linear-gradient(135deg,#ffe9c7,#ffd3ea);">
              <span id="bgTextFxDemoLight" style="font-weight:800; font-size:1rem; color:#7c2d12;">夢 (yume)</span>
            </div>
            <div style="flex:1; min-width:130px; border-radius:14px; padding:20px 10px; text-align:center; background:linear-gradient(135deg,#241733,#3a1f45);">
              <span id="bgTextFxDemoDark" style="font-weight:800; font-size:1rem; color:#ff9fce;">夢 (yume)</span>
            </div>
          </div>
          <small style="display:block; margin-top:6px; color:var(--ink-soft); font-weight:600; font-size:.7rem;">
            👆 Simulasi di background terang &amp; gelap — coba geser-geser pengaturan di atas sampai kosakatanya keliatan jelas di dua-duanya.
          </small>
        </div>
      </div>

      <div id="bgStatus" style="margin-top:14px; font-weight:800; font-size:.82rem; color:var(--ink-soft);"></div>
    </div>
    </div>
  </div>

  <!-- STEP 2.7: TEMPLATE & STYLING EDITOR -->
  <div class="card hidden" id="tplCard">
    <h2 class="collapsible-header" id="tplCardHeader" data-target="tplCardBody"><span class="step-num">🎨</span> Edit Template &amp; Styling Kartu <span class="badge" style="background:var(--mint); color:#0e4230;">Opsional</span><span class="collapse-hint">klik buat buka/tutup</span><span class="collapse-chevron">▸</span></h2>
    <div class="collapsible-body hidden" id="tplCardBody">
    <p style="font-weight:700; color:var(--ink-soft); font-size:.82rem; margin-top:0;">Edit langsung HTML tampilan kartu Depan/Belakang & CSS-nya, lengkap sama preview real-time. Berlaku buat note type <b id="tplModelName">-</b> yang lagi dipilih di atas.</p>

    <div class="grid2" style="margin-bottom:12px;">
      <div>
        <label class="field-label">Kartu (Card Template)</label>
        <select id="tplCardSelect"></select>
      </div>
      <div>
        <label class="field-label">Preview Sisi</label>
        <div class="btn-row" style="gap:6px;">
          <button type="button" class="btn ghost applied" id="tplPreviewFront" style="flex:1;">👁️ Depan</button>
          <button type="button" class="btn ghost" id="tplPreviewBack" style="flex:1;">👁️ Belakang</button>
        </div>
      </div>
    </div>

    <div class="btn-row" style="margin-bottom:10px;">
      <button type="button" class="btn ghost applied" id="tplTabFront" style="flex:1;">📝 Front Template</button>
      <button type="button" class="btn ghost" id="tplTabBack" style="flex:1;">📝 Back Template</button>
      <button type="button" class="btn ghost" id="tplTabCss" style="flex:1;">🎨 Styling (CSS)</button>
    </div>

    <textarea id="tplEditorFront" class="tpl-editor" spellcheck="false" rows="10"></textarea>
    <textarea id="tplEditorBack" class="tpl-editor hidden" spellcheck="false" rows="10"></textarea>
    <textarea id="tplEditorCss" class="tpl-editor hidden" spellcheck="false" rows="10"></textarea>

    <div style="margin-top:8px;">
      <small style="display:block; color:var(--ink-soft); font-weight:600; font-size:.72rem; margin-bottom:4px;">💡 Field yang bisa dipakai (klik buat nyalin ke clipboard):</small>
      <div id="tplFieldHints"></div>
    </div>

    <div class="btn-row" style="margin-top:14px;">
      <button type="button" class="btn ghost" id="tplBtnReset">↺ Kembalikan ke Desain Asli</button>
    </div>

    <div class="tpl-preview-wrap">
      <div class="tpl-preview-label">👁️ Preview Real-time</div>
      <iframe id="tplPreviewFrame" class="tpl-preview-frame" title="Preview kartu" sandbox="allow-same-origin"></iframe>
      <small style="display:block; margin-top:6px; color:var(--ink-soft); font-weight:600; font-size:.7rem;">⚡ Preview ini pakai data dari note pertama di tabel & rendering handlebars sederhana (best-effort), termasuk nampilin gambar &amp; muterin audio ASLI yang ada di dalam deck kamu — bisa aja gak 100% sama persis kayak Anki asli buat template yang rumit banget, tapi cukup buat ngecek perubahan HTML/CSS-nya realtime.</small>
    </div>
    </div>
  </div>

  <!-- STEP 3: TABLE PREVIEW / EDIT -->
  <div class="card hidden" id="tableCard">
    <h2><span class="step-num">3</span> Preview &amp; Edit <span class="badge" id="dirtyBadge">0 diubah</span></h2>
    <div class="btn-row">
      <button class="btn ghost" id="btnCopyAll">📋 Copy SEMUA Field<small>buat ditranslate</small></button>
      <button class="btn alt" id="btnPasteAll">📥 Paste Hasil Terjemahan</button>
      <button class="btn ghost" id="btnUndoPaste" disabled>↩️ Undo Paste Terakhir<small>balikin paste sebelumnya</small></button>
      <button class="btn ghost" id="btnExportCsv">⬇️ Export CSV</button>
      <button class="btn ghost" id="btnExportTxt">⬇️ Export TXT</button>
      <button class="btn ghost" id="btnImportFile">⬆️ Import CSV/TXT</button>
      <input type="file" id="importFileInput" accept=".csv,.txt" class="hidden" />
    </div>

    <div id="autoTranslatePanel" style="margin-top:14px; padding:14px 16px; border-radius:16px; background:var(--blush); border:2px dashed var(--pink);">
      <label class="field-label" style="margin-bottom:8px;">🌐 Translate Otomatis <span style="font-weight:600; color:var(--ink-soft); text-transform:none;">(opsional — translate atau jelasin kosakata langsung semua field yang dicentang di atas, tanpa copy-paste manual)</span></label>

      <div class="btn-row" style="gap:6px; margin-bottom:10px;">
        <button type="button" class="btn ghost applied" id="atOpTranslate" style="flex:1;">🌐 Terjemahin<small>translate isi field apa adanya</small></button>
        <button type="button" class="btn ghost" id="atOpExplain" style="flex:1;">🧠 Jelasin Kosakata (AI)<small>AI jelasin makna/nuansa, hasilnya ditaruh di field lain</small></button>
      </div>

      <div class="grid2">
        <div>
          <label class="field-label" id="atEngineLabel">Engine Translate</label>
          <select id="atEngineSelect">
            <option value="google-free" id="atEngineOptGoogleFree">🆓 Google Translate (gratis, tanpa API key)</option>
            <option value="google-cloud" id="atEngineOptGoogleCloud">🔑 Google Cloud Translate API</option>
            <option value="openai">🔑 OpenAI (ChatGPT) API</option>
            <option value="claude">🔑 Anthropic (Claude) API</option>
            <option value="gemini">🔑 Google Gemini API</option>
            <option value="deepseek">🔑 DeepSeek API</option>
          </select>
          <p id="atEngineExplainNote" class="hidden" style="font-size:.7rem; color:var(--ink-soft); font-weight:600; margin:6px 0 0;">⚠️ Mode "Jelasin Kosakata" butuh AI beneran buat ngerti instruksinya, jadi Google Translate (gratis/Cloud) gak kepilih -- pilih salah satu dari OpenAI/Claude/Gemini/DeepSeek ya~</p>
        </div>
        <div id="atApiKeyWrap" class="hidden">
          <label class="field-label">API Key</label>
          <input type="password" id="atApiKey" placeholder="Tempel API key kamu di sini" autocomplete="off" />
        </div>
      </div>

      <div class="grid2" style="margin-top:10px;">
        <div>
          <label class="field-label" id="atSourceLangLabel">Bahasa Sumber</label>
