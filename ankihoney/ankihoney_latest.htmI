// Resize + kompres foto ke JPEG biar file .apkg hasil akhir tetap ringan
function prepareBackgroundImage(file){
  return new Promise((resolve, reject)=>{
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = ()=>{
      const maxDim = 1600;
      let w = img.width, h = img.height;
      if(w > maxDim || h > maxDim){
        const scale = maxDim / Math.max(w,h);
        w = Math.round(w*scale); h = Math.round(h*scale);
      }
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, w, h);
      canvas.toBlob(blob=>{
        URL.revokeObjectURL(url);
        if(!blob){ reject(new Error('Gagal memproses gambar')); return; }
        const reader = new FileReader();
        reader.onload = ()=> resolve({ dataUrl: reader.result, blob });
        reader.onerror = ()=> reject(new Error('Gagal baca hasil kompresi'));
        reader.readAsDataURL(blob);
      }, 'image/jpeg', 0.82);
    };
    img.onerror = ()=>{ URL.revokeObjectURL(url); reject(new Error('File bukan gambar yang valid')); };
    img.src = url;
  });
}

async function handleBgImage(file){
  if(!file.type || !file.type.startsWith('image/')){ toast('File harus foto/gambar ya~', '😿'); return; }
  toast('Lagi proses fotonya...', '🖼️');
  try{
    const { dataUrl, blob } = await prepareBackgroundImage(file);
    state.cardBg.dataUrl = dataUrl;
    state.cardBg.bytes = new Uint8Array(await blob.arrayBuffer());
    // PENTING: nama file media dibikin unik berdasarkan isi foto (hash), bukan nama
    // statis kayak sebelumnya. Ini nyegah Anki nge-rename file diem-diem pas import
    // kalau kebetulan ada file lama dengan nama sama tapi isi beda di collection.media
    // user (dari percobaan/export sebelumnya) — yang bikin CSS jadi nunjuk ke file yang salah.
    state.cardBg.mediaFilename = '_ankihoney_bg_' + ahHashBytes(state.cardBg.bytes) + '.jpg';
    document.getElementById('bgControls').classList.remove('hidden');
    updateBgPreview();
    updateBgStatus();
    toast('Foto siap! Atur tampilannya, terus klik Terapkan~', '📸');
    say('Foto background udah siap dipasang! ✨');
  }catch(err){
    console.error(err);
    toast('Gagal proses foto: '+(err.message||err), '😿');
  }
}

