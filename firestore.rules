rules_version = '2';
// YumeSubs — hardened rules (audit May 2026)
// Deploy: Firebase Console → Firestore → Rules → Publish

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'khoirustsani143@gmail.com' ||
        request.auth.token.email == 'admin@yumesubs.com'
      );
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    function banDoc() {
      return get(/databases/$(database)/documents/banned_users/$(request.auth.uid));
    }

    function isBanActive() {
      return exists(/databases/$(database)/documents/banned_users/$(request.auth.uid))
        && (
          !('bannedUntil' in banDoc().data)
          || banDoc().data.bannedUntil == null
          || request.time.toMillis() < banDoc().data.bannedUntil
        );
    }

    function notBanned() {
      return isLoggedIn() && !isBanActive();
    }

    function notSpamming() {
      return !exists(/databases/$(database)/documents/comment_ratelimit/$(request.auth.uid))
        || get(/databases/$(database)/documents/comment_ratelimit/$(request.auth.uid)).data.lastComment
           < request.time.toMillis() - 5000;
    }

    function notSpammingReply() {
      return !exists(/databases/$(database)/documents/comment_ratelimit/$(request.auth.uid))
        || get(/databases/$(database)/documents/comment_ratelimit/$(request.auth.uid)).data.lastReply
           < request.time.toMillis() - 5000;
    }

    function validOnlineSessionId(sessionId) {
      return sessionId.matches('^u_[a-zA-Z0-9]{8,120}$');
    }

    function validNotificationCreate() {
      return request.resource.data.toUid is string
        && request.resource.data.toUid.size() > 0
        && request.resource.data.toUid.size() < 128
        && request.resource.data.ts is number
        && (!('fromUid' in request.resource.data) || request.resource.data.fromUid == request.auth.uid)
        && (!('replyText' in request.resource.data) || (
          request.resource.data.replyText is string
          && request.resource.data.replyText.size() < 500
        ));
    }

    // ── Lagu ──
    match /songs/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['thumbsUp', 'thumbsDown']);
    }

    match /comments/{id} {
      allow read: if true;
      allow create: if isAdmin()
                    || (
                      isLoggedIn()
                      && notBanned()
                      && (
                        (!('parentId' in request.resource.data) || request.resource.data.parentId == null)
                        ? notSpamming()
                        : notSpammingReply()
                      )
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.text is string
                      && (request.resource.data.text.size() > 0 || 'imgUrl' in request.resource.data)
                      && request.resource.data.text.size() < 1000
                      && request.resource.data.songId is string
                    );
      allow update, delete: if isAdmin()
                    || (isLoggedIn() && resource.data.uid == request.auth.uid);
      allow update: if isLoggedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['thumbsUp', 'thumbsDown']);
    }

    match /submissions/{id} {
      allow read: if true;
      allow create: if (
        request.resource.data.keys().hasAll(['text'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 2000
      ) || (
        request.resource.data.keys().hasAll(['title', 'artist'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.artist is string
        && request.resource.data.artist.size() > 0
      ) || (
        request.resource.data.keys().hasAll(['msg'])
        && request.resource.data.msg is string
        && request.resource.data.msg.size() > 0
        && request.resource.data.msg.size() < 2000
      );
      allow update, delete: if isAdmin();

      match /replies/{replyId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /stories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /story_comments/{id} {
      allow read: if true;
      allow create: if isAdmin()
                    || (
                      isLoggedIn()
                      && notBanned()
                      && (
                        (!('parentId' in request.resource.data) || request.resource.data.parentId == null)
                        ? notSpamming()
                        : notSpammingReply()
                      )
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.storyId is string
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() < 1000
                    );
      allow update, delete: if isAdmin()
                    || (isLoggedIn() && resource.data.uid == request.auth.uid);
    }

    match /resources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /anki_progress/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Latihan: tanpa login — validasi ketat (anti skor/nama sampah)
    match /leaderboard/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'score', 'ts'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.score is number
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 100
                    && request.resource.data.ts is number
                    && (!('compositeScore' in request.resource.data)
                        || (request.resource.data.compositeScore is number
                            && request.resource.data.compositeScore >= 0
                            && request.resource.data.compositeScore <= 1000000));
      allow update, delete: if isAdmin();
    }

    match /banned_users/{uid} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    match /user_profiles/{uid} {
      allow read: if true;
      allow write: if isLoggedIn() && request.auth.uid == uid;
    }

    match /notifications/{id} {
      allow read, update, delete: if isLoggedIn() && resource.data.toUid == request.auth.uid;
      allow create: if isAdmin()
                    || (isLoggedIn() && validNotificationCreate());
    }

    match /user_roles/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /role_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /custom_roles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /comment_ratelimit/{uid} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;
    }

    match /song_thumbs/{songId}/votes/{voterId} {
      allow read: if true;
      allow write: if isLoggedIn() && request.auth.uid == voterId;
    }

    match /comment_thumbs/{cmId}/votes/{voterId} {
      allow read: if true;
      allow write: if isLoggedIn() && request.auth.uid == voterId;
    }

    // Counter online: format sessionId u_xxx + field terbatas
    match /online_users/{sessionId} {
      allow read: if true;
      allow create, update: if validOnlineSessionId(sessionId)
        && request.resource.data.keys().hasOnly(['ts', 'page'])
        && (!('page' in request.resource.data) || (
          request.resource.data.page is string
          && request.resource.data.page.size() < 300
        ));
      allow delete: if validOnlineSessionId(sessionId);
    }

    match /group_chat/{msgId} {
      allow read: if true;
      allow create: if isLoggedIn()
                    && notBanned()
                    && request.resource.data.uid == request.auth.uid
                    && (request.resource.data.text is string || 'imgUrl' in request.resource.data)
                    && (!('text' in request.resource.data) || request.resource.data.text.size() < 500);
      allow update: if isLoggedIn() && resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /chat_reports/{id} {
      allow create: if isLoggedIn()
                    && notBanned()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

  }
}
