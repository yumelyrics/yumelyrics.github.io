/* ---------------- custom outline/shadow teks vocab ---------------- */
function ahHexToRgb(hex){
  hex = (hex || '#000000').replace('#','');
  if(hex.length === 3) hex = hex.split('').map(c=>c+c).join('');
  const num = parseInt(hex, 16);
  if(isNaN(num)) return { r:0, g:0, b:0 };
  return { r:(num>>16)&255, g:(num>>8)&255, b:num&255 };
}

// Bangun value CSS text-shadow (tanpa prefix "text-shadow:") berdasarkan config custom.
// Dipakai bareng buat live preview di browser & buat CSS beneran yang disuntik ke Anki.
// Bangun deklarasi CSS (bukan cuma text-shadow) buat efek teks vocab.
// 'outline' = garis tepi tegas ala komik: isi huruf putih polos, cuma
//   PINGGIRANNYA doang yang kena warna custom. Pake -webkit-text-stroke
//   (stroke digambar di tengah tepi glyph) + paint-order:stroke fill supaya
//   fill putih ditumpuk DI ATAS separuh stroke yang ada di dalam huruf, jadi
//   yang keliatan cuma separuh luar strokenya -> persis kayak garis outline.
//   Ga pake blur sama sekali, jadi gak nyebar/numpuk ke karakter sebelahnya.
// 'glow'    = bayangan lembut ngeblur di sekeliling teks, warna asli teks
//   tetep dipertahankan (dipakai kalau user mau efek lebih soft, bukan outline).
function ahBuildTextFxCss(cfg){
  const fx = (cfg && cfg.textFx) || {};
  const s = Math.max(1, Math.min(6, fx.strength || 3));
  const color = fx.color || '#000000';
  const { r, g, b } = ahHexToRgb(color);
  const rgba = a => `rgba(${r},${g},${b},${a})`;

  if(fx.styleMode === 'outline'){
    const strokeWidth = (s * 0.45).toFixed(2); // 0.45px - 2.7px, tetep tipis & tegas
    return [
      `color: #ffffff`,
      `-webkit-text-stroke: ${strokeWidth}px ${color}`,
      `text-stroke: ${strokeWidth}px ${color}`,
      `paint-order: stroke fill`,
      `text-shadow: none`
    ];
  }

  // glow (default): bayangan lembut, warna huruf asli dipertahankan
  const shadow = [
    `0 0 ${s}px ${rgba(.95)}`,
    `0 0 ${s*2}px ${rgba(.85)}`,
    `0 1px ${s}px ${rgba(.95)}`,
    `0 -1px ${s}px ${rgba(.95)}`,
    `1px 0 ${s}px ${rgba(.95)}`,
    `-1px 0 ${s}px ${rgba(.95)}`
  ].join(', ');
  return [ `text-shadow: ${shadow}` ];
}

function updateTextFxPreview(){
  const fx = state.cardBg.textFx;
  const controls = document.getElementById('bgTextFxControls');
  if(!controls) return;
  controls.style.opacity = fx.enabled ? '1' : '.4';
  controls.style.pointerEvents = fx.enabled ? '' : 'none';

  const declarations = fx.enabled ? ahBuildTextFxCss(state.cardBg).join('; ') + ';' : '';

  // demo mini di background terang & gelap -- font-weight:800 dipertahankan,
  // sisanya (color/stroke/shadow) di-reset dulu baru ditimpa declarations baru
  ['bgTextFxDemoLight','bgTextFxDemoDark'].forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.style.cssText = 'font-weight:800; font-size:1rem;' + (declarations ? ' ' + declarations : '');
  });

  // vocab bold di preview kartu utama (cuma yang di dalam field, bukan seluruh kartu)
  const target = document.querySelectorAll('#bgPreviewText b, #bgPreviewText strong');
  target.forEach(el=>{ el.style.cssText = declarations; });
}

