          <label class="field-label" id="atTargetLangLabel">Bahasa Target</label>
          <input type="text" id="atTargetLang" list="atLangList" value="id" placeholder="id" />
        </div>
      </div>

      <div id="atExplainInstrWrap" class="hidden" style="margin-top:12px;">
        <label class="field-label">🧠 Instruksi Buat AI Jelasin Kosakata</label>
        <p style="font-size:.72rem; color:var(--ink-soft); font-weight:600; margin:2px 0 8px;">Instruksi ini sama konsepnya kayak "Instruksi Khusus Field" (tombol 📝 di daftar field buat field kayak Notes) -- bedanya di sini AI-nya beneran manggil API &amp; hasilnya langsung ditaruh ke field Tujuan yang kamu pilih di bawah, gak perlu copy-paste manual lagi.</p>
        <textarea id="atExplainInstrArea" style="min-height:200px;"></textarea>
        <button type="button" class="btn ghost" id="atExplainUseTemplate" style="margin-top:6px;">📋 Reset ke template default</button>

        <div style="margin-top:14px;">
          <label class="field-label">📖 Field Konteks Tambahan (opsional)</label>
          <p style="font-size:.72rem; color:var(--ink-soft); font-weight:600; margin:2px 0 8px;">Kalau field <b>Sumber</b> di atas cuma berisi kosakata/kata tunggal (misal field Kosakata), field ini boleh diisi field lain yang berisi KALIMAT lengkapnya (misal SentKanji) -- isinya DIBACA doang dan dikasih ke AI sebagai konteks tambahan, biar penjelasannya nyambung sama gimana kosakata itu dipakai di kalimatnya, bukan cuma makna umum kamusnya doang.</p>
          <select id="atExplainContextField"><option value="">(Gak pakai field konteks tambahan)</option></select>
        </div>
      </div>

      <datalist id="atLangList">
        <option value="auto">Deteksi Otomatis</option>
        <option value="id">Indonesia</option>
        <option value="en">English</option>
        <option value="ja">Japanese</option>
        <option value="ko">Korean</option>
        <option value="zh-CN">Chinese (Simplified)</option>
        <option value="zh-TW">Chinese (Traditional)</option>
        <option value="es">Spanish</option>
        <option value="fr">French</option>
        <option value="de">German</option>
        <option value="pt">Portuguese</option>
        <option value="ru">Russian</option>
        <option value="ar">Arabic</option>
        <option value="th">Thai</option>
        <option value="vi">Vietnamese</option>
        <option value="hi">Hindi</option>
        <option value="it">Italian</option>
      </datalist>

      <div style="margin-top:12px;">
        <label class="field-label" id="atFieldSectionLabel">Field yang Ditranslate</label>
        <div class="btn-row" style="gap:6px; margin-bottom:8px;">
          <button type="button" class="btn ghost applied" id="atModeInplace" style="flex:1;">🔁 Field yang sama<small>timpa isi field yang dicentang di atas</small></button>
          <button type="button" class="btn ghost" id="atModeMapped" style="flex:1;">➡️ Field beda<small>ambil dari field A, taruh hasilnya ke field B</small></button>
        </div>
        <div id="atMappedWrap" class="hidden">
          <div id="atMappedList"></div>
          <button type="button" class="btn ghost" id="atAddMapping" style="margin-top:2px;">+ Tambah Pasangan Field</button>
        </div>
      </div>

      <p style="font-size:.72rem; color:var(--ink-soft); font-weight:600; margin:10px 0 0;" id="atModeHint">⚠️ Yang ditranslate cuma field yang <b>dicentang tapi BUKAN ditandain 🔒 sumber</b>. API key (kalau diisi) cuma kesimpen lokal di browser kamu sendiri, dan teksnya dikirim LANGSUNG dari browser kamu ke server engine yang dipilih (bukan lewat server AnkiHoney) — jadi dobel-cek hasilnya sebelum disimpen, apalagi buat field yang banyak tag HTML/gambar/audio.</p>

      <div class="btn-row" style="margin-top:10px;">
        <button class="btn mint" id="btnAutoTranslate" type="button"><span id="btnAutoTranslateLabel">🌐 Translate Semua Field yang Dicentang</span></button>
        <button class="btn ghost hidden" id="btnAutoTranslateCancel" type="button">⏹️ Batalin</button>
        <button class="btn ghost" id="btnAutoTranslateUndo" type="button" disabled><span id="btnAutoTranslateUndoLabel">↩️ Undo Translate Terakhir</span></button>
        <button class="btn ghost hidden" id="btnAutoTranslateRetryFailed" type="button">🔁 <span id="btnAutoTranslateRetryFailedLabel">Mulai Ulang yang Gagal</span></button>
      </div>
      <div id="atProgress" style="margin-top:8px; font-weight:800; font-size:.8rem; color:var(--ink-soft);"></div>
      <div id="atProgressTrackWrap" class="hidden"><div id="atProgressBar" class="at-progress-track"><div class="at-progress-fill"></div></div></div>
    </div>

    <div id="batchPanel" style="margin-top:14px; padding:14px 16px; border-radius:16px; background:var(--blush); border:2px dashed var(--pink);">
      <label class="field-label" style="margin-bottom:8px;">✂️ Copy per Batch <span style="font-weight:600; color:var(--ink-soft); text-transform:none;">(disaranin buat deck gede — biar AI translate-nya gak keliru geser urutan pas kebanyakan teks sekaligus)</span></label>
      <div class="grid2" style="align-items:end;">
        <div>
          <label class="field-label">Jumlah kartu per batch</label>
          <input type="number" id="batchSizeInput" min="1" step="1" value="50" />
        </div>
        <div class="btn-row" style="margin:0;">
          <button class="btn ghost" id="btnBatchPrev" type="button">◀ Sebelumnya</button>
          <button class="btn ghost" id="btnBatchNext" type="button">Berikutnya ▶</button>
        </div>
      </div>
      <div id="batchInfo" style="margin-top:10px; font-weight:800; font-size:.82rem; color:var(--ink-soft);"></div>
      <div class="btn-row" style="margin-top:10px;">
        <button class="btn mint" id="btnCopyBatch" type="button">📋 Copy Batch Ini<small>lebih aman buat deck gede</small></button>
        <button class="btn alt" id="btnPasteBatch" type="button">📥 Paste Batch Ini<small>khusus buat batch yang aktif</small></button>
        <button class="btn mint" id="btnAutoTranslateBatch" type="button"><span id="btnAutoTranslateBatchLabel">🌐 Translate Batch Ini</span><small>pakai pengaturan Translate Otomatis di atas</small></button>
      </div>
    </div>
    <div class="btn-row" style="margin-top:16px; align-items:center;">
      <span style="font-weight:800; font-size:.82rem; color:var(--ink-soft);" id="tablePageInfo"></span>
      <div style="flex:1;"></div>
      <span style="font-weight:800; font-size:.75rem; color:var(--ink-soft); text-transform:uppercase; margin-right:2px;">Baris per halaman</span>
      <select id="tablePageSizeSelect" style="width:auto; padding:8px 10px;">
        <option value="25">25</option>
        <option value="50" selected>50</option>
        <option value="100">100</option>
        <option value="200">200</option>
      </select>
      <button class="btn ghost" id="btnTablePagePrev" type="button" style="padding:8px 14px;">◀</button>
      <button class="btn ghost" id="btnTablePageNext" type="button" style="padding:8px 14px;">▶</button>
    </div>
    <p style="font-size:.7rem; color:var(--ink-soft); font-weight:600; margin:4px 0 0;">💡 Tabel di bawah ini dibagi per halaman biar gak ngelag pas deck-nya gede -- ini CUMA buat tampilan, translate/jelasin/copy-paste tetep jalan ke SEMUA note yang dicentang, bukan cuma yang keliatan di halaman ini.</p>
    <div class="table-wrap" style="margin-top:10px;">
      <table>
        <thead>
          <tr>
            <th style="width:20px;"></th>
            <th class="id-cell">ID</th>
            <th class="preview-cell">Preview Note</th>
            <th class="edit-cell">Field (bisa diedit langsung)</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

  <!-- STEP 4: SAVE -->
  <div class="card hidden" id="saveCard">
    <h2><span class="step-num">4</span> Simpan Deck Baru</h2>
    <p style="font-weight:700; color:var(--ink-soft); margin-top:0;">Setelah field-nya diganti sama hasil terjemahan, download ulang jadi .apkg buat diimport ke Anki lagi ✨</p>
    <div id="deckNameCard" style="margin-bottom:16px;">
      <label class="field-label">Nama Deck yang bakal tampil di Anki</label>
      <p style="font-size:.76rem; color:var(--ink-soft); opacity:.85; margin-top:-4px; margin-bottom:8px;">⚠️ Kalau nama deck ini diganti dari nama aslinya, pas diimport ke Anki bakal <b>kebuat deck BARU</b> dengan nama itu (bukan nge-update nama deck yang lama). Deck lama tetap ada di Anki tapi jadi kosong (kartunya pindah semua ke deck baru) — bisa dihapus manual kalau udah gak kepake.</p>
      <div id="deckNameList"></div>
    </div>
    <div class="btn-row">
      <button class="btn mint" id="btnDownloadApkg">💾 Download .apkg Hasil Update</button>
    </div>
  </div>

  <p class="footer-note">Semua proses jalan 100% di browser kamu — file .apkg ga pernah dikirim ke server manapun 🔒💕<br>Dibuat oleh <b>yumelyrics</b> × <b>yumesubs</b></p>
</div>

<a class="wm-badge" id="wmBadge" href="https://yumelyrics.my.id/" target="_blank" rel="noopener">✨ yumelyrics <span>×</span> yumesubs</a>

<!-- PASTE MODAL -->
<div class="modal-bg" id="pasteModalBg">
  <div class="modal">
    <h3 id="pasteModalTitle">📥 Paste Hasil Terjemahan</h3>
    <p id="pasteModalSub" style="font-weight:700; color:var(--ink-soft); font-size:.85rem;">Tempel teks yang sama persis formatnya kayak waktu kamu copy tadi (jangan hapus baris <code>[[[ID:...]]]</code> dan tag <code>[NamaField]</code> kalau kamu gabung beberapa field), lalu klik Terapkan. Kalau kamu translate per batch, tempel & terapkan satu batch dulu sebelum copy batch berikutnya ya — jangan digabung jadi satu paste raksasa, biar ID-nya gak gampang ketuker sama AI translator-nya.</p>
    <textarea id="pasteArea" placeholder="[[[ID:12345]]]&#10;[SentKanji]&#10;teks terjemahan di sini...&#10;[SentEng]&#10;teks terjemahan lainnya...&#10;&#10;[[[ID:12346]]]&#10;..."></textarea>
    <div class="modal-actions">
      <button class="btn ghost" id="btnCancelPaste">Batal</button>
      <button class="btn mint" id="btnApplyPaste">✨ Terapkan</button>
    </div>
  </div>
</div>


<div class="toast" id="toast"></div>

<script>
/* ---------------- collapsible optional card sections ---------------- */
/* Background Kartu & Edit Template/Styling disembunyiin default (biar hemat
   ruang), user klik headernya buat buka/tutup. State per-card diinget di
   localStorage biar gak collapse lagi tiap reload/upload deck baru. */
(function initCollapsibleCards(){
  document.querySelectorAll('.collapsible-header[data-target]').forEach(header=>{
    const body = document.getElementById(header.dataset.target);
    if(!body) return;
    const storeKey = 'ah_collapse_' + header.dataset.target;
    function setOpen(open){
      body.classList.toggle('hidden', !open);
      header.classList.toggle('open', open);
      header.setAttribute('aria-expanded', open ? 'true' : 'false');
      try{ localStorage.setItem(storeKey, open ? '1' : '0'); }catch(e){}
    }
    let saved = null;
    try{ saved = localStorage.getItem(storeKey); }catch(e){}
    setOpen(saved === '1'); // default tertutup kecuali user pernah buka & disimpen kebuka
    header.addEventListener('click', ()=> setOpen(body.classList.contains('hidden')));
  });
})();

/* ---------------- decorative sparkles ---------------- */
(function sparkles(){
  const reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(reduceMotion) return;
  const layer = document.getElementById('sparkleLayer');
  const icons = ['✨','🎀','💮','🌸','⭐','🍡','💗'];
  const count = window.innerWidth < 640 ? 8 : 18;
  for(let i=0;i<count;i++){
    const s = document.createElement('div');
    s.className='sparkle';
    s.textContent = icons[Math.floor(Math.random()*icons.length)];
    s.style.left = Math.random()*100+'vw';
    s.style.top = Math.random()*100+'vh';
    s.style.animationDelay = (Math.random()*6)+'s';
    s.style.animationDuration = (7+Math.random()*6)+'s';
    layer.appendChild(s);
  }
})();

function say(msg){
  document.getElementById('mascotSpeech').textContent = msg;
}
function blink(){
  const l = document.getElementById('eyeL'), r = document.getElementById('eyeR');
  [l,r].forEach(e=> e.setAttribute('ry','0.5'));
  setTimeout(()=>{ [l,r].forEach(e=> e.removeAttribute('ry')); }, 140);
}
setInterval(blink, 3400);

function toast(msg, emoji='💗'){
  const t = document.getElementById('toast');
  t.innerHTML = emoji+' '+msg;
  t.classList.add('show');
  clearTimeout(toast._tm);
  toast._tm = setTimeout(()=> t.classList.remove('show'), 2600);
}

// Popup buat error teknis (bukan sekadar console.warn) -- beda sama toast() yang
// buat notif ringan & cepet ilang, ini nunggu di-dismiss manual & ngarahin user
// buat lapor ke Discord kalau mereka nemuin kasus ini, soalnya biasanya artinya
// ada bentuk data baru yang belum ke-handle sama tool ini.
const AH_DISCORD_URL = 'https://discord.gg/SW9bTRHK8H';
function ahShowErrorPopup(msg){
  let bg = document.getElementById('ahErrorModalBg');
  if(!bg){
    bg = document.createElement('div');
    bg.id = 'ahErrorModalBg';
    bg.className = 'modal-bg';
    bg.innerHTML = `
      <div class="modal">
        <h3>😿 Ada bagian yang gagal diproses</h3>
        <p id="ahErrorModalMsg" style="white-space:pre-wrap; font-size:.85rem; color:var(--ink-soft);"></p>
        <p style="font-size:.85rem;">Deck kamu tetep kesimpen & bisa lanjut dipakai, tapi bagian yang gagal tadi mungkin gak sempurna. Boleh banget dilaporin ke Discord kita biar bisa dicek & diperbaiki:<br>
          <a href="${AH_DISCORD_URL}" target="_blank" rel="noopener" style="color:#5865F2; font-weight:700; text-decoration:none; border-bottom:1.5px dashed #5865F2;">${AH_DISCORD_URL}</a>
        </p>
        <div class="modal-actions">
          <button class="btn ghost" id="ahErrorModalClose" type="button">Oke, ngerti</button>
        </div>
      </div>`;
    document.body.appendChild(bg);
    bg.querySelector('#ahErrorModalClose').addEventListener('click', ()=> bg.classList.remove('show'));
    bg.addEventListener('click', e=>{ if(e.target === bg) bg.classList.remove('show'); });
  }
  bg.querySelector('#ahErrorModalMsg').textContent = msg;
  bg.classList.add('show');
}

// Popup khusus kalau kecium ada engine AI translate (OpenAI/Claude/Gemini/DeepSeek) yang
// nolak request-nya gara-gara NAMA MODEL udah dihapus/diganti sama provider-nya (lihat
// ahMakeEngineError). Beda sama ahShowErrorPopup biasa -- ini negesin jelas ke user kalau
// ini BUKAN salah mereka & bukan salah API key, tapi tool ini yang butuh diupdate nama
// modelnya. Cuma nongol SEKALI per proses translate (dipicu dari kegagalan pertama yang
// kedeteksi modelIssue), biar gak spam popup kalau banyak field yang gagal bareng-bareng.
function ahShowModelIssuePopup(provider, errMsg){
  let bg = document.getElementById('ahModelIssueModalBg');
  if(!bg){
    bg = document.createElement('div');
    bg.id = 'ahModelIssueModalBg';
    bg.className = 'modal-bg';
    bg.innerHTML = `
      <div class="modal">
        <h3>🤖 Model AI-nya kayaknya udah usang</h3>
        <p style="font-size:.85rem; color:var(--ink-soft);">Provider <b id="ahModelIssueProvider"></b> nolak request translate-nya dengan pesan yang nunjukkin nama model AI yang dipakai tool ini <b>udah gak didukung lagi</b> (dihapus/diganti/deprecated). Ini <b>bukan salah kamu</b> dan bukan salah API key kamu -- provider AI emang sering banget ganti-ganti nama model, jadi tool ini yang perlu diupdate ngikutin nama model terbarunya.</p>
        <p id="ahModelIssueDetail" style="white-space:pre-wrap; font-size:.75rem; color:var(--ink-soft); opacity:.8; background:rgba(0,0,0,.04); padding:8px 10px; border-radius:8px;"></p>
        <p style="font-size:.85rem;">Field yang gagal tadi dibiarin apa adanya (gak ketimpa), jadi aman buat dicoba lagi nanti kalau tool-nya udah diupdate. Boleh banget bantu lapor ke Discord kita biar cepet dibenerin:<br>
          <a href="${AH_DISCORD_URL}" target="_blank" rel="noopener" style="color:#5865F2; font-weight:700; text-decoration:none; border-bottom:1.5px dashed #5865F2;">${AH_DISCORD_URL}</a>
        </p>
        <div class="modal-actions">
          <button class="btn ghost" id="ahModelIssueModalClose" type="button">Oke, ngerti</button>
        </div>
      </div>`;
    document.body.appendChild(bg);
    bg.querySelector('#ahModelIssueModalClose').addEventListener('click', ()=> bg.classList.remove('show'));
    bg.addEventListener('click', e=>{ if(e.target === bg) bg.classList.remove('show'); });
  }
  bg.querySelector('#ahModelIssueProvider').textContent = provider || 'AI';
  bg.querySelector('#ahModelIssueDetail').textContent = (errMsg||'').slice(0,300);
  bg.classList.add('show');
}

// Popup buat kegagalan proses Translate Otomatis / Jelasin Kosakata (AI) yang BUKAN
// kasus "model usang" (lihat ahShowModelIssuePopup di atas buat itu) -- misal timeout,
// rate limit, atau error lain dari engine-nya. Beda sama ahShowErrorPopup generik: ini
// nunjukkin CONTOH nyata field mana aja yang gagal + pesan errornya, dan nyediain tombol
// buat langsung ngulang proses TAPI CUMA buat field yang gagal doang (gak perlu dari nol).
function ahShowFailedRetryPopup(op, entries, onRetry){
  if(!entries || !entries.length) return;
  let bg = document.getElementById('ahFailedRetryModalBg');
  if(!bg){
    bg = document.createElement('div');
    bg.id = 'ahFailedRetryModalBg';
    bg.className = 'modal-bg';
    bg.innerHTML = `
      <div class="modal">
        <h3 id="ahFailedRetryTitle">😿 Ada field yang gagal diproses</h3>
        <p style="font-size:.85rem; color:var(--ink-soft);">Field yang gagal DIBIARIN apa adanya (gak ketimpa/gak ilang), jadi aman buat dicoba lagi. Ini beberapa contoh kegagalannya:</p>
        <div id="ahFailedRetryList" style="max-height:220px; overflow:auto; font-size:.76rem; color:var(--ink-soft); background:rgba(0,0,0,.04); padding:8px 10px; border-radius:8px; white-space:pre-wrap;"></div>
        <p style="font-size:.8rem; margin-top:10px;">Bisa langsung diulang CUMA buat yang gagal (gak perlu ulang dari awal semua kartu), atau lapor ke Discord kalau keulang-ulang terus gagalnya:<br>
          <a href="${AH_DISCORD_URL}" target="_blank" rel="noopener" style="color:#5865F2; font-weight:700; text-decoration:none; border-bottom:1.5px dashed #5865F2;">${AH_DISCORD_URL}</a>
        </p>
        <div class="modal-actions">
          <button class="btn ghost" id="ahFailedRetryClose" type="button">Nanti aja</button>
          <button class="btn mint" id="ahFailedRetryBtn" type="button"></button>
        </div>
      </div>`;
    document.body.appendChild(bg);
    bg.querySelector('#ahFailedRetryClose').addEventListener('click', ()=> bg.classList.remove('show'));
    bg.addEventListener('click', e=>{ if(e.target === bg) bg.classList.remove('show'); });
  }
  const model = state.models[state.currentMid];
  const verbed = op === 'explain' ? 'dijelasin' : 'ditranslate';
  const verbUlang = op === 'explain' ? 'Jelasin' : 'Translate';
  const emoji = op === 'explain' ? '🧠' : '🌐';
  bg.querySelector('#ahFailedRetryTitle').textContent = `😿 ${entries.length} field gagal ${verbed}`;
  const shown = entries.slice(0, 8);
  const lines = shown.map(e=>{
    const fname = (model && model.flds && model.flds[e.dst]) || ('Field '+(e.dst+1));
    return `Kartu #${e.id} — ${fname}:\n${(e.err||'Error gak diketahui').slice(0,180)}`;
  });
  if(entries.length > shown.length) lines.push(`...dan ${entries.length - shown.length} field lainnya yang gagal`);
  bg.querySelector('#ahFailedRetryList').textContent = lines.join('\n\n');
  const retryBtnEl = bg.querySelector('#ahFailedRetryBtn');
  retryBtnEl.textContent = `${emoji} Mulai ${verbUlang} Ulang yang Gagal (${entries.length})`;
  retryBtnEl.onclick = ()=>{ bg.classList.remove('show'); onRetry(); };
  bg.classList.add('show');
}

// Template default buat field kayak "Notes" -- dipasang otomatis pas pertama kali user
// buka modal instruksi field yang namanya keliatan kayak field catatan/penjelasan, biar
// gak nulis dari nol. Tetep bisa diedit/dihapus bebas sama user.
const AH_DEFAULT_NOTES_INSTRUCTION =
`Isi field ini dengan penjelasan SUPER LENGKAP & MENDALAM tentang kosakata/kalimat yang lagi diterjemahin -- posisikan diri kamu kayak GURU BAHASA yang lagi nerangin ke murid secara tatap muka: sabar, telaten, runtut, dan pastiin muridnya bener-bener paham dari akar sampai daun, bukan cuma dikasih arti mentah terus selesai. Tiap poin di bawah ini WAJIB dijabarin dengan kalimat penjelasan yang jelas (bukan cuma disebut judulnya doang atau dijawab satu kata) -- kalau memang suatu poin gak relevan sama sekali buat kata/kalimat yang lagi dibahas (misal poin konjugasi buat kata benda), boleh dilewatin, tapi selebihnya WAJIB diisi:
- Arti & nuansa: jelasin makna detailnya, bukan cuma terjemahan kata per kata. Kalau kata/kalimatnya punya makna ganda atau makna kiasan, sebutin semua kemungkinannya & jelasin kapan makna yang mana yang biasanya dipakai.
- Tingkat kesulitan/level: kalau ada tolok ukur level yang relevan buat bahasanya (misal JLPT N5-N1 buat bahasa Jepang, CEFR A1-C2, dll), sebutin perkiraan levelnya -- biar murid punya gambaran ini kosakata dasar atau udah level lanjut.
- Frekuensi pemakaian: kosakata ini sering dipakai di percakapan sehari-hari, atau jarang/terkesan sastra-formal-kaku?
- Konteks pemakaian: biasanya dipakai di situasi apa (ngobrol santai sama teman, situasi formal/kerja, tulisan/surat, percakapan keluarga, dll) dan kapan pas dipakainya.
- Tingkat kesopanan: ini bentuk sopan (teineigo/keigo) atau bentuk biasa/kasual (futsuukei)? Kasih tau juga versi sopan/kasualnya kalau ada padanannya.
- Cara penulisan: kalau kata ini bisa ditulis dengan lebih dari satu cara (misal pakai kanji vs cukup hiragana/kana aja, atau ada varian ejaan lain), jelasin kapan sebaiknya pakai yang mana & apa bedanya kesan yang ditimbulin (misal kanji kesannya lebih formal/tertulis, hiragana kesannya lebih lembut/kasual).
- Pelafalan/aksen (kalau relevan & krusial buat dibedain, misal ada kata yang beda makna karena beda aksen/nada baca), sebutin secukupnya -- gak usah dipaksain kalau bahasanya gak punya sistem aksen yang signifikan.
- Perubahan bentuk/konjugasi: kalau kata ini kata kerja, kata sifat, atau kata yang punya bentuk berubah-ubah, kasih beberapa bentuk pentingnya (misal bentuk kamus, bentuk -masu/sopan, bentuk lampau, bentuk negatif, bentuk te/menyambung, dll sesuai yang relevan sama bahasanya) biar murid liat polanya, bukan cuma satu bentuk doang.
- Breakdown/struktur: kalau berupa kalimat, frasa, atau kata gabungan (kata majemuk, kata + imbuhan, kata + partikel, pola tata bahasa, dll), PECAH jadi bagian-bagian kecilnya satu-satu terus jelasin fungsi/arti tiap bagian itu -- tujuannya biar murid ngerti KENAPA gabungan itu bisa berarti begitu secara logis, bukan cuma disuruh ngapalin utuh-utuh tanpa tau alasannya.
- Contoh kalimat: kasih MINIMAL 2 contoh kalimat pemakaian nyata (usahain beda situasi/konteks satu sama lain, dan kalau ada bentuk konjugasi yang beda-beda, coba wakilin beberapa bentuk itu di contohnya), lengkap sama terjemahan Indonesia-nya, biar keliatan gimana kata/pola ini beneran dipakai dalam kalimat utuh sehari-hari, bukan cuma berdiri sendiri sebagai definisi kamus.
- Kosakata/ungkapan yang mirip: sebutin kata atau frasa lain yang artinya mirip atau sering ketuker, terus jelasin bedanya apa (nuansa, tingkat formalitas, konteks pemakaian, atau kapan salah satu lebih natural dipakai dibanding yang lain).
- Lawan kata (kalau ada): sebutin antonim/lawan katanya biar makin kebayang posisi makna kata ini dibanding kata yang berlawanan.
- Kesalahan umum pembelajar: kalau ada, sebutin kesalahan yang sering dibuat pembelajar terkait kata/pola ini (misal ketuker sama kata yang mirip, salah tingkat kesopanan, salah partikel, salah konjugasi, salah konteks pemakaian, dll) biar bisa diantisipasi/dihindarin dari awal.
- Cara gampang inget (opsional): kalau ada cara yang natural buat bantu inget kata/pola ini (misal asosiasi bunyi, keterkaitan sama kanji/kata lain yang udah familiar, cerita singkat, dll), kasih 1 tips singkat -- tapi JANGAN dipaksain kalau emang gak ada asosiasi yang masuk akal.
- Kalau ada nuansa budaya, kolokasi umum (kata yang sering bareng), atau catatan pemakaian unik lainnya (misal cuma dipakai di kalimat tertentu, gender tertentu, atau ada di dialek tertentu), sebutin juga sesingkat & sejelas mungkin.
- Ringkasan penutup: tutup penjelasan dengan 1-2 kalimat ringkasan singkat (semacam "intinya") yang ngerangkum poin paling penting dari kata/kalimat ini, biar kalau murid buru-buru ngulang, tetep nangkep inti yang paling wajib diinget.
- Kanji & furigana: kalau ada kanji di penjelasan (termasuk di contoh kalimat), WAJIB kasih cara baca furigana-nya, dengan format PERSIS begini: kanji (atau blok kanji beruntun yang sama-sama dibaca jadi satu furigana) diikuti kurung siku berisi hiragana-nya, contoh: 私[わたし]。 Jangan pakai tanda kurung biasa ( ) atau format lain. Kurung siku-nya HARUS nempel PERSIS cuma ngelingkupin blok kanji-nya doang, JANGAN sampe furigana-nya keanggep nyebar ke karakter lain yang nempel SEBELUM blok kanji itu (baik itu hiragana atau kanji lain) — caranya, kasih SATU spasi pemisah sebelum karakter PALING DEPAN dari blok kanji yang mau dikasih furigana (bukan di antara kanji-kanji di dalam bloknya sendiri, itu tetep nempel gak pake spasi). Contoh kasus hiragana+kanji: たった今 (dibaca たったいま, cuma "今" yang kanji) ditulis jadi "たった 今[いま]", BUKAN "たった今[いま]" atau "たった[いま]今". Contoh kasus kanji ketemu kanji (blok kanji-nya lebih dari 1 karakter): 巫山戯る (dibaca ふざける, "巫山戯" bertiga sama-sama masuk satu bacaan ふざけ) ditulis jadi "巫山戯[ふざけ]る" tapi kalau sebelum "巫" ada karakter lain yang nempel (misal hiragana atau kanji kata sebelumnya atau romaji, atau tidak ada karakter sama sekali), WAJIB kasih spasi sebelum "巫"-nya aja (bukan di antara 巫/山/戯), biar furigana-nya cuma ngelingkupin 3 kanji itu dan gak ikut nyebar ke kata sebelumnya.
Tulis dengan nada guru yang hangat, sabar, & enak diikutin -- boleh panjang demi kelengkapan (jangan dipotong-potong/diringkas berlebihan), tapi tetap runtut per poin, gak muter-muter, dan jangan bertele-tele di luar topik. Jangan kaku kayak kamus, dan jangan cuma nge-list istilah tanpa penjelasan.`;

// Instruksi default buat fitur "Jelasin Kosakata (AI)" di panel Translate Otomatis --
// sengaja dipakein isi yang SAMA kayak template Notes di atas, karena tujuannya emang
// sama (AI ngejelasin kosakata/kalimat secara lengkap), cuma beda jalur eksekusinya:
// yang ini langsung manggil API & nulis ke field tujuan, bukan cuma nempel pas copy-paste.
const AH_DEFAULT_EXPLAIN_INSTRUCTION = AH_DEFAULT_NOTES_INSTRUCTION;

// Engine yang boleh dipakai buat mode "Jelasin Kosakata" -- cuma yang beneran AI chat model
// (Google Translate gratis/Cloud itu API terjemahan literal, gak bisa diinstruksiin bebas).
// Didefinisiin di sini (bukan deket ahExplainDispatch di bawah) biar udah kebaca duluan
// sebelum initAutoTranslatePanel IIFE manggil ahAtSetOp() pas halaman pertama kali dimuat.
const AH_EXPLAIN_ENGINES = ['openai', 'claude', 'gemini', 'deepseek'];

function ahLooksLikeNotesField(fieldName){
  const n = (fieldName||'').toLowerCase();
  return n.includes('note') || n.includes('catatan') || n.includes('keterangan') || n.includes('penjelasan');
}

// Instruksi khusus per field disimpen TERPISAH per note type (mid), biar instruksi yang
// udah ditulis buat note type A gak ke-reset/ilang kalau user pindah ke note type B lalu
// balik lagi ke A (dulu ke-reset jadi {} tiap ganti note type -- bug, sekarang dibikin
// persisten selama deck yang sama masih kebuka).
function ahCurrentFieldInstructions(){
  const mid = state.currentMid;
  if(!state.fieldInstructionsByModel[mid]) state.fieldInstructionsByModel[mid] = {};
  return state.fieldInstructionsByModel[mid];
}

// Modal buat nulis/edit instruksi khusus per field, yang bakal ikut ditempelin ke
// [INSTRUKSI BUAT AI TRANSLATOR] pas user copy teks buat ditranslate -- jadi AI-nya
// langsung tau field itu mau diisi kayak gimana (misal Notes: jelasin lengkap + furigana).
function openFieldInstructionModal(idx, fieldName, onSaved){
  let bg = document.getElementById('ahFieldInstrModalBg');
  if(!bg){
    bg = document.createElement('div');
    bg.id = 'ahFieldInstrModalBg';
    bg.className = 'modal-bg';
    bg.innerHTML = `
      <div class="modal">
        <h3 id="ahFieldInstrTitle">📝 Instruksi Khusus Field</h3>
        <p style="font-weight:700; color:var(--ink-soft); font-size:.85rem;">Instruksi ini bakal ikut nempel di teks yang kamu copy buat ditranslate, jadi AI-nya (ChatGPT/Google Translate dll) langsung tau field ini harus diisi kayak gimana. Kosongin lalu simpan kalau mau hapus instruksinya.</p>
        <textarea id="ahFieldInstrArea" style="min-height:240px;" placeholder="Contoh: jelasin lengkap makna kosakatanya, formal/kasual, kosakata mirip, furigana, dst..."></textarea>
        <div class="modal-actions" style="justify-content:space-between;">
          <button class="btn ghost" id="ahFieldInstrUseTemplate" type="button">📋 Pakai template Notes</button>
          <div style="display:flex; gap:10px;">
            <button class="btn ghost" id="ahFieldInstrCancel" type="button">Batal</button>
            <button class="btn mint" id="ahFieldInstrSave" type="button">💾 Simpan</button>
          </div>
        </div>
      </div>`;
    document.body.appendChild(bg);
    bg.addEventListener('click', e=>{ if(e.target === bg) bg.classList.remove('show'); });
  }
  bg.querySelector('#ahFieldInstrTitle').textContent = `📝 Instruksi Khusus Field "${fieldName}"`;
  const ta = bg.querySelector('#ahFieldInstrArea');
  const existing = ahCurrentFieldInstructions()[idx];
  ta.value = existing !== undefined ? existing : (ahLooksLikeNotesField(fieldName) ? AH_DEFAULT_NOTES_INSTRUCTION : '');

  // clone tombol biar listener lama (dari field lain yang sebelumnya dibuka) kebuang, gak numpuk
  const oldCancel = bg.querySelector('#ahFieldInstrCancel');
  const oldSave = bg.querySelector('#ahFieldInstrSave');
  const oldTemplate = bg.querySelector('#ahFieldInstrUseTemplate');
  const cancelBtn = oldCancel.cloneNode(true); oldCancel.replaceWith(cancelBtn);
  const saveBtn = oldSave.cloneNode(true); oldSave.replaceWith(saveBtn);
  const templateBtn = oldTemplate.cloneNode(true); oldTemplate.replaceWith(templateBtn);

  // Klik tombol ini LANGSUNG ganti isi textarea jadi template Notes lengkap (bukan copy ke
  // clipboard) -- biar field custom (misal "Extra", "Info") bisa pakai template yang sama
  // kayak field yang namanya kedetect otomatis sebagai "Notes", tinggal diedit lalu Simpan.
  templateBtn.addEventListener('click', (e)=>{
    e.preventDefault();
    ta.value = AH_DEFAULT_NOTES_INSTRUCTION;
    ta.focus();
    toast('Template Notes udah kepasang di textarea~ Edit dulu kalau perlu, terus Simpan.', '📋');
  });

  cancelBtn.addEventListener('click', ()=> bg.classList.remove('show'));
  saveBtn.addEventListener('click', ()=>{
    const val = ta.value.trim();
    if(val){
      state.fieldInstructionsByModel[state.currentMid] = state.fieldInstructionsByModel[state.currentMid] || {};
      state.fieldInstructionsByModel[state.currentMid][idx] = val;
    } else {
      if(state.fieldInstructionsByModel[state.currentMid]) delete state.fieldInstructionsByModel[state.currentMid][idx];
    }
    bg.classList.remove('show');
    if(onSaved) onSaved();
    toast(val ? `Instruksi buat "${fieldName}" disimpen~` : `Instruksi buat "${fieldName}" dihapus~`, '📝');
  });

  bg.classList.add('show');
}

/* ---------------- state ---------------- */
const state = {
  SQL: null,
  zip: null,
  db: null,
  collectionFileName: null,   // nama file collection yang dipakai buat SIMPLE re-save (format lama)
  isLatest: false,            // true kalau deck aslinya format terbaru (anki21b, zstd)
  models: {},       // mid -> {name, flds:[names...]}
  decksMap: {},     // did -> deck name
  decksDescMap: {}, // did -> deck description asli
  deckNameOverrides: {}, // did -> custom deck name (override, dari form user)
  notes: [],         // {id, guid, mid, tags, fields:[...], dirty}
  currentMid: null,
  selectedFieldIdxs: [0],
  referenceFieldIdxs: [], // subset dari selectedFieldIdxs yang ditandain SUMBER/REFERENSI -- field yang dipakai AI buat konteks tapi HARUSNYA gak berubah (misal SentKanji/VocabKanji asli), beda sama field TARGET yang emang diisi hasil terjemahan (SentEng/VocabDef/Notes)
  fieldSelectionByModel: {}, // mid -> {selected:[idx,...], reference:[idx,...]} -- inget centang & tanda 🔒 sumber per note type biar gak ilang pas gonta-ganti note type
  fieldInstructionsByModel: {}, // mid -> { idx field -> teks instruksi khusus buat AI translator pas ngisi field itu (misal: "jelasin lengkap kosakatanya + furigana") }, ikut kecopy ke [INSTRUKSI BUAT AI TRANSLATOR]. Dipisah per note type (mid) biar instruksi note type A gak ilang pas pindah ke note type B lalu balik lagi.
  batchSize: 50,
  batchIndex: 0,
  tablePageSize: 50,   // buat pagination tabel Preview & Edit doang (biar gak ngelag di deck gede) -- terpisah dari batchSize/batchIndex di atas, yang itu buat fitur Copy/Paste/Translate per Batch
  tablePageIndex: 0,
  doneBatches: new Set(),  // kumpulan "kunci batch" (gabungan ID terurut) yang udah pernah di-apply, biar ketauan kalau paste ulang bakal nimpa
  pasteSnapshot: null,     // {mid, batchKey, entries:[{id, fields, dirty}]} -- buat fitur Undo Paste Terakhir
  cardBg: {
    mode: 'upload',        // 'upload' (file lokal) atau 'url' (link gambar online)
    imageUrl: '',           // dipakai kalau mode === 'url'
    dataUrl: null,        // buat preview di browser
    bytes: null,           // Uint8Array (JPEG terkompres) buat disisipin ke media apkg
    mediaFilename: '_ankihoney_card_bg.jpg',
    fit: 'cover',
    posX: 50,          // posisi geser horizontal (%) khusus buat DESKTOP
    posY: 50,          // posisi geser vertikal (%) khusus buat DESKTOP
    mobilePosX: 50,    // posisi geser horizontal (%) khusus buat MOBILE (AnkiDroid/AnkiMobile) -- terpisah dari Desktop
    mobilePosY: 50,    // posisi geser vertikal (%) khusus buat MOBILE -- terpisah dari Desktop
    previewDevice: 'desktop', // 'desktop' | 'mobile' -- device mana yang lagi diatur/dipreview posisinya di form
    opacity: 90,
    overlay: 25,
    blur: 0,
    front: false,
    back: false,
    previewSide: 'front',
    textFx: {
      enabled: true,       // aktif/nonaktif outline/shadow custom
      styleMode: 'glow',   // 'glow' (bayangan lembut) atau 'outline' (garis tegas)
      color: '#000000',    // warna outline/shadow
      strength: 3,         // ketebalan, 1-6
      target: 'bold'       // 'bold' (cuma vocab yang di-bold) atau 'all' (semua teks)
    }
  },
  originalFileName: 'deck.apkg',
  templateOriginals: {}, // mid -> {css, tmpls:[...]} snapshot "asli" (sebelum diedit user), buat tombol Reset
  templateEditor: { ord: 0, side: 'front', tab: 'front' }, // state UI editor Template & Styling (bukan bagian dari deck)
  mediaBlobUrlCache: {}, // nama file media -> blob: URL (dibikin on-demand), dipakai buat nampilin gambar/muterin audio asli di preview realtime
  _mediaMapPromise: null, // cache promise pemetaan nomor file <-> nama file media asli di dalam .apkg
  autoTranslate: { cancel: false, mode: 'inplace', op: 'translate', lastFailedEntries: [] }, // mode: 'inplace' (timpa field yg sama) atau 'mapped' (field A -> field B). op: 'translate' (terjemahin apa adanya) atau 'explain' (AI jelasin kosakata sesuai instruksi custom, ditaruh di field tujuan). lastFailedEntries: [{id,src,dst,err}] dari proses TERAKHIR, dipake buat tombol "Mulai Ulang yang Gagal"
  autoTranslateSnapshot: null // snapshot fields SEBELUM auto-translate jalan (buat tombol Undo Translate Terakhir)
};

/* ---------------- init sql.js ---------------- */
let sqlReadyPromise = initSqlJs({
  locateFile: file => `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.10.2/${file}`
}).then(SQL => { state.SQL = SQL; return SQL; });

// Konfirmasi kalau user coba nutup tab / refresh SETELAH file .apkg berhasil dimuat --
// semua kerjaan (translate, edit field, dll) cuma kesimpen di memori browser aja, belum
// ada auto-save ke server/disk, jadi kalau ke-close/refresh tanpa sengaja progress-nya ilang.
// Browser modern gak nampilin teks custom ini (cuma dialog konfirmasi bawaan browser),
// tapi listener-nya harus tetep dipasang biar dialognya nongol sama sekali.
window.addEventListener('beforeunload', (e)=>{
  if(state.notes && state.notes.length){
    e.preventDefault();
    e.returnValue = 'Progress kamu (deck yang lagi dibuka & belum di-download ulang) bakal ilang kalau halaman ini ditutup/direfresh. Yakin mau lanjut?';
    return e.returnValue;
  }
});

/* ---------------- upload / parse ---------------- */
const dropzone = document.getElementById('dropzone');
const fileInput = document.getElementById('fileInput');

dropzone.addEventListener('click', ()=> fileInput.click());
['dragover','dragenter'].forEach(ev=> dropzone.addEventListener(ev, e=>{ e.preventDefault(); dropzone.classList.add('drag'); }));
['dragleave','drop'].forEach(ev=> dropzone.addEventListener(ev, e=>{ e.preventDefault(); dropzone.classList.remove('drag'); }));
dropzone.addEventListener('drop', e=>{
  const f = e.dataTransfer.files[0];
  if(f) handleApkgFile(f);
});
fileInput.addEventListener('change', e=>{
  const f = e.target.files[0];
  if(f) handleApkgFile(f);
});

async function handleApkgFile(file){
  const statusEl = document.getElementById('uploadStatus');
  const warnEl = document.getElementById('formatWarning');
  warnEl.classList.add('hidden');
  try{
    state.originalFileName = file.name.replace(/\.apkg$/i, '') + '_translated.apkg';
    statusEl.innerHTML = '<span class="loader"><span></span><span></span><span></span></span> Membuka file...';
    say('Lagi buka paket-nya, tunggu sebentar ya~ 📦');

    const [SQL] = await Promise.all([sqlReadyPromise]);
    const buf = await file.arrayBuffer();
    const zip = await JSZip.loadAsync(buf);
    state.zip = zip;

    // Deck format Anki terbaru (2.1.50+) simpan data asli di collection.anki21b
    // yang dikompres zstd. File collection.anki21/anki2 di sebelahnya cuma dummy
    // kompatibilitas (1 kartu placeholder). Makanya anki21b harus dicek duluan.
    const newEntry = zip.file('collection.anki21b');
    const legacyEntry = zip.file('collection.anki21') || zip.file('collection.anki2');

    let dbBytes;
    state.isLatest = false;

    if(newEntry){
      state.isLatest = true;
      statusEl.innerHTML = '<span class="loader"><span></span><span></span><span></span></span> Format Anki terbaru terdeteksi, lagi bongkar kompresinya...';
      await new Promise(r=>setTimeout(r,30));
      if(typeof fzstd === 'undefined'){
        statusEl.innerHTML = '😿 Library pembongkar zstd gagal dimuat. Coba refresh halaman ya~';
        return;
      }
      const compressed = await newEntry.async('uint8array');
      try{
        dbBytes = zstdDecompressSafe(compressed);
      }catch(zerr){
        console.error(zerr);
        statusEl.innerHTML = '😿 Gagal membongkar format terbaru ini. Coba export ulang dari Anki dengan opsi "Support older Anki versions" dicentang ya~ (' + (zerr.message||zerr) + ')';
        ahShowErrorPopup('Gagal membongkar isi deck (collection.anki21b).\nError: ' + (zerr.message||zerr) + '\n\nCoba export ulang deck dari Anki dengan opsi "Support older Anki versions" dicentang.');
        return;
      }
    } else if(legacyEntry){
      dbBytes = await legacyEntry.async('uint8array');
      state.collectionFileName = zip.file('collection.anki21') ? 'collection.anki21' : 'collection.anki2';
    } else {
      statusEl.innerHTML = '😿 Ga ketemu file collection di dalam .apkg ini. Pastikan ini file .apkg asli dari Anki ya.';
      return;
    }

    statusEl.innerHTML = '<span class="loader"><span></span><span></span><span></span></span> Lagi baca kartu-kartunya...';
    await new Promise(r=>setTimeout(r,20));

    const db = new SQL.Database(dbBytes);
    state.db = db;

    state.models = getModelsAnyVersion(db);
    state.decksMap = getDecksAnyVersion(db);
    state.usedDeckIds = [];
    try{
      const cardsDidRes = db.exec("SELECT DISTINCT did FROM cards");
      if(cardsDidRes.length) state.usedDeckIds = cardsDidRes[0].values.map(r=>String(r[0]));
    }catch(e){ console.warn('gagal baca did dari cards', e); }

    // load notes (kolom ini stabil di semua versi skema Anki)
    const notesRes = db.exec("SELECT id, guid, mid, tags, flds FROM notes");
    state.notes = [];
    if(notesRes.length){
      notesRes[0].values.forEach(row=>{
        const [id, guid, mid, tags, flds] = row;
        state.notes.push({
          id, guid: String(guid||''), mid: String(mid), tags: String(tags||''),
          fields: String(flds).split('\x1f').map(f=> ahStripWmHtml(f)),
          dirty: false
        });
      });
    }

    if(!state.notes.length){
      statusEl.innerHTML = '😿 Deck ini kosong, gak ada kartu yang ketemu.';
      return;
    }

    if(state.isLatest){
      const usedMidsPreview = [...new Set(state.notes.map(n=>n.mid))];
      const allDesignsCaptured = usedMidsPreview.length > 0 && usedMidsPreview.every(mid=> modelHasOriginalDesign(state.models[mid]));
      warnEl.classList.remove('hidden');
      if(allDesignsCaptured){
        warnEl.innerHTML = '⚠️ Deck ini pakai format Anki terbaru (zstd). Bisa dibaca &amp; diedit kok! Pas disimpan ulang, file-nya bakal dikonversi ke format kompatibel (Legacy) — isi kartu, tag, jadwal belajar (due/interval), <b>dan desain tampilan kartu (template depan/belakang + CSS) berhasil ditangkap &amp; ikut kesimpen</b>. Mapping media/gambar tetap bisa sedikit kurang akurat di kasus tertentu. Kalau ternyata pas dibuka di Anki desainnya masih meleset, export ulang dari Anki dengan opsi "Support older Anki versions" dicentang ya~ 🙏';
      } else {
        warnEl.innerHTML = '⚠️ Deck ini pakai format Anki terbaru (zstd). Bisa dibaca &amp; diedit kok! Isi kartu, tag, dan jadwal belajar (due/interval) tetap aman. AnkiHoney nyoba nangkep <b>desain tampilan kartu (template depan/belakang)</b> asli juga, tapi buat sebagian note type di deck ini gagal ke-baca, jadi bakal jatuh ke tampilan sederhana generik. Kalau desain templatenya penting banget, lebih aman export ulang dari Anki dengan opsi "Support older Anki versions" dicentang dulu ya~ 🙏';
      }
    }

    statusEl.innerHTML = `✅ Deck kebuka! Ketemu <b>${state.notes.length}</b> catatan (notes).` + (state.isLatest ? ' <span style="color:#c98a00;">(format terbaru, lihat catatan di bawah)</span>' : '');
    say(`Yeay~ ${state.notes.length} kartu berhasil dimuat! 🎉`);
    toast('Deck berhasil dibuka!', '🎉');

    state.templateOriginals = {}; // reset cache "desain asli" tiap kali buka deck baru
    state.fieldInstructionsByModel = {}; // reset instruksi khusus field juga -- deck baru = note type baru semua
    state.fieldSelectionByModel = {}; // reset juga cache centang/lock field per note type
    Object.values(state.mediaBlobUrlCache).forEach(url=>{ try{ URL.revokeObjectURL(url); }catch(e){} });
    state.mediaBlobUrlCache = {};
    state._mediaMapPromise = null;

    populateModelSelect();
    populateDeckNameInputs();
    document.getElementById('selectCard').classList.remove('hidden');
    document.getElementById('bgCard').classList.remove('hidden');
    document.getElementById('tplCard').classList.remove('hidden');
    document.getElementById('tableCard').classList.remove('hidden');
    document.getElementById('saveCard').classList.remove('hidden');

  }catch(err){
    console.error(err);
    statusEl.innerHTML = '😿 Gagal baca file: ' + (err.message || err);
    say('Aduh error nya... coba file lain? 😿');
  }
}

function ahHashBytes(bytes){
  let h1 = 2166136261, h2 = 2166136261;
  for(let i=0;i<bytes.length;i++){
    h1 ^= bytes[i]; h1 = Math.imul(h1, 16777619);
    h2 ^= bytes[bytes.length-1-i]; h2 = Math.imul(h2, 16777619);
  }
  return (h1>>>0).toString(16).padStart(8,'0') + (h2>>>0).toString(16).padStart(8,'0');
}
/* ---------------- background kartu (front/back) ---------------- */
function ahHasBgImage(cfg){
  if(!cfg) return false;
  return cfg.mode === 'url' ? !!(cfg.imageUrl && cfg.imageUrl.trim()) : !!(cfg.dataUrl && cfg.bytes);
}
function ahBgImageRef(cfg){
  return cfg.mode === 'url' ? cfg.imageUrl.trim() : cfg.mediaFilename;
}
